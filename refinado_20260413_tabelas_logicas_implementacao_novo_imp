# 4. Modelo SQL conceitual em Athena

Agora vou te dar um esqueleto que você consegue adaptar.

---

## 4.1 CTE de parâmetros mensais

```sql
with parametros as (
    select
        date '2026-04-01' as dt_inicio_mes,
        date '2026-04-30' as dt_fim_mes,
        5  as dia_util_corte_pleno,
        15 as dia_util_corte_parcial
),
```

Na prática, idealmente isso viria de uma tabela calendário com dia útil.

---

## 4.2 Base de casos e gatilhos

```sql
base_casos as (
    select
        processo_id,
        contrato_id,
        escritorio_id,
        praca,
        ticket_faixa,
        tp_carteira, -- ATIVO / WO
        gatilho,
        dt_entrada_escritorio,
        dt_primeira_elegibilidade_gatilho,
        dt_execucao_gatilho,
        dt_baixa_excecao,
        motivo_baixa_excecao,
        sla_dias_gatilho,
        peso_gatilho
    from sua_base_processo_gatilho
),
```

---

## 4.3 Enriquecimento mensal

```sql
base_mes as (
    select
        b.*,
        p.dt_inicio_mes,
        p.dt_fim_mes,

        case
            when b.dt_entrada_escritorio < p.dt_inicio_mes then 1 else 0
        end as flag_estoque_inicial_mes,

        case
            when b.dt_entrada_escritorio between p.dt_inicio_mes and p.dt_fim_mes then 1 else 0
        end as flag_entrada_nova_mes,

        case
            when b.dt_primeira_elegibilidade_gatilho <= p.dt_fim_mes then 1 else 0
        end as flag_elegivel_mes
    from base_casos b
    cross join parametros p
),
```

---

## 4.4 Classificação da entrada no mês

Aqui vou simplificar com diferença em dias corridos. Depois você pode trocar por dia útil via calendário.

```sql
classificacao_janela as (
    select
        *,
        date_diff('day', dt_inicio_mes, coalesce(dt_entrada_escritorio, dt_inicio_mes)) as dias_desde_inicio_mes_entrada,
        date_diff('day', dt_inicio_mes, coalesce(dt_primeira_elegibilidade_gatilho, dt_inicio_mes)) as dias_desde_inicio_mes_elegibilidade,

        case
            when flag_entrada_nova_mes = 1
             and date_diff('day', dt_inicio_mes, dt_entrada_escritorio) <= 5
                then 1 else 0
        end as flag_entrada_elegivel_plena_mes,

        case
            when flag_entrada_nova_mes = 1
             and date_diff('day', dt_inicio_mes, dt_entrada_escritorio) > 5
             and date_diff('day', dt_inicio_mes, dt_entrada_escritorio) <= 15
                then 1 else 0
        end as flag_entrada_elegivel_parcial_mes,

        case
            when flag_entrada_nova_mes = 1
             and date_diff('day', dt_inicio_mes, dt_entrada_escritorio) > 15
                then 1 else 0
        end as flag_entrada_tardia_mes
    from base_mes
),
```

---

## 4.5 Regras de exceção, execução e trabalho

```sql
regras_atuacao as (
    select
        *,

        case
            when dt_baixa_excecao between dt_inicio_mes and dt_fim_mes
             and motivo_baixa_excecao in (
                 'PAGAMENTO',
                 'ENCERRAMENTO',
                 'RETROACAO',
                 'PERDA_ELEGIBILIDADE',
                 'SUSPENSAO_JURIDICA'
             )
                then 1 else 0
        end as flag_excecao_mes,

        case
            when dt_execucao_gatilho between dt_inicio_mes and dt_fim_mes
                then 1 else 0
        end as flag_executado_mes
    from classificacao_janela
),
```

---

## 4.6 Elegibilidade líquida e trabalho

```sql
regras_finais as (
    select
        *,

        case
            when flag_elegivel_mes = 1 and flag_excecao_mes = 0 then 1 else 0
        end as flag_elegivel_liquido_mes,

        case
            when flag_executado_mes = 1 or flag_excecao_mes = 1 then 1 else 0
        end as flag_trabalhado_mes,

        case
            when flag_executado_mes = 1
                then date_diff('day', dt_primeira_elegibilidade_gatilho, dt_execucao_gatilho)
            else null
        end as dias_ate_execucao,

        case
            when flag_executado_mes = 1
             and date_diff('day', dt_primeira_elegibilidade_gatilho, dt_execucao_gatilho) <= sla_dias_gatilho
                then 1 else 0
        end as flag_dentro_sla_mes,

        case
            when flag_executado_mes = 1
             and date_diff('day', dt_primeira_elegibilidade_gatilho, dt_execucao_gatilho) > sla_dias_gatilho
                then 1 else 0
        end as flag_fora_sla_mes,

        case
            when flag_elegivel_mes = 1
                then date_diff('day', dt_primeira_elegibilidade_gatilho, dt_fim_mes)
            else null
        end as idade_gatilho_em_dias_fechamento
    from regras_atuacao
),
```

---

## 4.7 Backlog final

```sql
backlog as (
    select
        *,

        case
            when flag_elegivel_mes = 1
             and flag_executado_mes = 0
             and flag_excecao_mes = 0
             and idade_gatilho_em_dias_fechamento > sla_dias_gatilho
                then 1 else 0
        end as flag_backlog_mes
    from regras_finais
),
```

---

## 4.8 Penalidade de tempo e score do evento

Vou usar um redutor simples em faixas, mais explicável para advogado.

```sql
score as (
    select
        *,

        case
            when flag_executado_mes = 0 then 0.0
            when dias_ate_execucao <= sla_dias_gatilho then 1.0
            when dias_ate_execucao <= sla_dias_gatilho + 10 then 0.7
            when dias_ate_execucao <= sla_dias_gatilho + 30 then 0.4
            else 0.2
        end as penalidade_tempo,

        cast(flag_executado_mes as double) * peso_gatilho *
        case
            when flag_executado_mes = 0 then 0.0
            when dias_ate_execucao <= sla_dias_gatilho then 1.0
            when dias_ate_execucao <= sla_dias_gatilho + 10 then 0.7
            when dias_ate_execucao <= sla_dias_gatilho + 30 then 0.4
            else 0.2
        end as score_evento
    from backlog
)
```

---

## 4.9 Agregado mensal por escritório, praça, ticket, carteira e gatilho

```sql
select
    date_format(dt_inicio_mes, '%Y%m') as mes_ref,
    escritorio_id,
    praca,
    ticket_faixa,
    tp_carteira,
    gatilho,

    sum(flag_estoque_inicial_mes) as qtd_estoque_inicial,
    sum(flag_entrada_nova_mes) as qtd_entradas_novas,
    sum(flag_entrada_elegivel_plena_mes) as qtd_entradas_plenas,
    sum(flag_entrada_elegivel_parcial_mes) as qtd_entradas_parciais,
    sum(flag_entrada_tardia_mes) as qtd_entradas_tardias,

    sum(flag_elegivel_mes) as qtd_elegiveis,
    sum(flag_elegivel_liquido_mes) as qtd_elegiveis_liquidos,
    sum(flag_trabalhado_mes) as qtd_trabalhados,
    sum(flag_executado_mes) as qtd_executados,
    sum(flag_excecao_mes) as qtd_excecoes,

    sum(flag_dentro_sla_mes) as qtd_dentro_sla,
    sum(flag_backlog_mes) as qtd_backlog_final,

    cast(sum(flag_trabalhado_mes) as double) / nullif(sum(flag_elegivel_mes), 0) as cobertura,
    cast(sum(flag_executado_mes) as double) / nullif(sum(flag_elegivel_liquido_mes), 0) as execucao_real,
    cast(sum(flag_dentro_sla_mes) as double) / nullif(sum(flag_executado_mes), 0) as sla_compliance,
    cast(sum(flag_backlog_mes) as double) / nullif(sum(flag_elegivel_mes), 0) as backlog_final,

    sum(score_evento) as score_evento_total,
    sum(cast(flag_elegivel_mes as double) * peso_gatilho) as score_maximo_teorico,

    sum(score_evento) / nullif(sum(cast(flag_elegivel_mes as double) * peso_gatilho), 0) as score_base,

    (
        sum(score_evento) / nullif(sum(cast(flag_elegivel_mes as double) * peso_gatilho), 0)
    ) * (
        1 - cast(sum(flag_backlog_mes) as double) / nullif(sum(flag_elegivel_mes), 0)
    ) as score_final
from score
group by 1,2,3,4,5,6
;
```

