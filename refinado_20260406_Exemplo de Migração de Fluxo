# 📊 CONSULTA AGREGADA (SEM contrato/produto) — ⭐ PEDIDO

👉 Ideal para QuickSight / comitê  
👉 MECE por movimento + dimensões

```sql
WITH base AS (
    SELECT * FROM final_enriquecido
)

SELECT
    mes_anterior,
    mes_atual,

    segmento_anterior,
    segmento_atual,

    novas_filas_adm_anterior,
    novas_filas_adm_atual,

    faixa_atraso_anterior,
    faixa_atraso_atual,

    status_existencia,
    mov_segmento,
    mov_novas_filas_adm,

    COUNT(DISTINCT chave_contrato_produto) AS qtd_dist_contrato_produto,

    SUM(COALESCE(saldo_anterior,0)) AS saldo_anterior_total,
    SUM(COALESCE(saldo_atual,0))    AS saldo_atual_total,
    SUM(COALESCE(delta_saldo,0))    AS delta_saldo_total,

    SUM(COALESCE(delta_risco,0))    AS soma_delta_risco,

    AVG(ticket_medio_anterior) AS ticket_medio_anterior,
    AVG(ticket_medio_atual)    AS ticket_medio_atual,
    AVG(delta_ticket_medio)    AS delta_ticket_medio,

    AVG(media_risco_anterior)  AS media_risco_anterior,
    AVG(media_risco_atual)     AS media_risco_atual,
    AVG(delta_media_risco)     AS delta_media_risco,

    AVG(mediana_risco_anterior) AS mediana_risco_anterior,
    AVG(mediana_risco_atual)    AS mediana_risco_atual,
    AVG(delta_mediana_risco)    AS delta_mediana_risco

FROM base
GROUP BY
    mes_anterior,
    mes_atual,
    segmento_anterior,
    segmento_atual,
    novas_filas_adm_anterior,
    novas_filas_adm_atual,
    faixa_atraso_anterior,
    faixa_atraso_atual,
    status_existencia,
    mov_segmento,
    mov_novas_filas_adm

ORDER BY mes_anterior, mes_atual;
```

