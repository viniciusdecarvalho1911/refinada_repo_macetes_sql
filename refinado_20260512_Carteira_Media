## 5. Insert Gold — histórico até 2025-12

```sql
DELETE FROM workspace_db.iceberg_gold_fato_cobranca_carteira_distribuida_dia
WHERE p_anomes <= 202512
  AND origem_modelagem = 'HISTORICO_ACUMULADO_SIMULADO';
```

```sql
INSERT INTO workspace_db.iceberg_gold_fato_cobranca_carteira_distribuida_dia
WITH snapshot_diario AS (
    SELECT
        cast(date_format(dia, '%Y%m%d') AS integer) AS anomesdia,
        cast(date_format(dia, '%Y%m') AS integer) AS anomes,
        dia AS dt_ref,

        contrato,
        produto,
        escritorio,

        vl_saldo,
        dias_atraso_contrato,
        faixa_atraso_contrato,

        true AS fl_distribuido,
        false AS fl_purc,
        true AS fl_simulado_historico,

        CASE
            WHEN dia = dt_entrada_exposicao THEN 'entrada'
            WHEN dia = dt_saida_exposicao THEN 'saida'
            ELSE 'estoque'
        END AS tipo_evento_dia,

        dt_entrada_exposicao,
        dt_saida_exposicao,
        motivo_saida,

        'HISTORICO_ACUMULADO_SIMULADO' AS origem_modelagem
    FROM workspace_db.view_silver_integrado_cobranca_carteira_historica_intervalo_simulado
    CROSS JOIN UNNEST(
        sequence(dt_entrada_exposicao, dt_saida_exposicao, interval '1' day)
    ) AS t(dia)
)

SELECT
    anomesdia,
    anomes,
    dt_ref,
    contrato,
    produto,
    escritorio,
    vl_saldo,
    dias_atraso_contrato,
    faixa_atraso_contrato,
    fl_distribuido,
    fl_purc,
    fl_simulado_historico,
    tipo_evento_dia,
    dt_entrada_exposicao,
    dt_saida_exposicao,
    motivo_saida,
    origem_modelagem,
    'execucao_historico_acumulado_ate_202512' AS id_execucao,
    current_timestamp AS dt_ingestao_modelo,
    anomes AS p_anomes
FROM snapshot_diario;
```

## 6. Insert Gold — PURC observada

```sql
DELETE FROM workspace_db.iceberg_gold_fato_cobranca_carteira_distribuida_dia
WHERE p_anomes >= 202601
  AND origem_modelagem = 'PURC_OBSERVADO';
```

```sql
INSERT INTO workspace_db.iceberg_gold_fato_cobranca_carteira_distribuida_dia
WITH base AS (
    SELECT
        dt_ref_yyyymmdd AS anomesdia,
        mes_ref_yyyymm AS anomes,
        dt_ref_date AS dt_ref,

        contrato,
        produto,
        escritorio,

        vl_saldo,
        dias_atraso_contrato,
        faixa_atraso_contrato,

        fl_distribuido
    FROM workspace_db.view_silver_padronizado_cobranca_purc_carteira_diaria
    WHERE mes_ref_yyyymm >= 202601
),

eventos AS (
    SELECT
        b.*,

        lag(fl_distribuido) OVER (
            PARTITION BY contrato, produto, escritorio
            ORDER BY dt_ref
        ) AS fl_distribuido_anterior,

        lead(fl_distribuido) OVER (
            PARTITION BY contrato, produto, escritorio
            ORDER BY dt_ref
        ) AS fl_distribuido_seguinte,

        min(CASE WHEN fl_distribuido THEN dt_ref END) OVER (
            PARTITION BY contrato, produto, escritorio, anomes
        ) AS dt_entrada_exposicao,

        max(CASE WHEN fl_distribuido THEN dt_ref END) OVER (
            PARTITION BY contrato, produto, escritorio, anomes
        ) AS dt_saida_exposicao
    FROM base b
),

final AS (
    SELECT
        anomesdia,
        anomes,
        dt_ref,

        contrato,
        produto,
        escritorio,

        vl_saldo,
        dias_atraso_contrato,
        faixa_atraso_contrato,

        fl_distribuido,

        CASE
            WHEN fl_distribuido = true
             AND coalesce(fl_distribuido_anterior, false) = false
                THEN 'entrada'
            WHEN fl_distribuido = true
             AND coalesce(fl_distribuido_seguinte, false) = false
                THEN 'saida'
            WHEN fl_distribuido = true
                THEN 'estoque'
            ELSE 'fora'
        END AS tipo_evento_dia,

        dt_entrada_exposicao,
        dt_saida_exposicao
    FROM eventos
    WHERE fl_distribuido = true
)

SELECT
    anomesdia,
    anomes,
    dt_ref,

    contrato,
    produto,
    escritorio,

    vl_saldo,
    dias_atraso_contrato,
    faixa_atraso_contrato,

    true AS fl_distribuido,
    true AS fl_purc,
    false AS fl_simulado_historico,

    tipo_evento_dia,
    dt_entrada_exposicao,
    dt_saida_exposicao,

    CASE
        WHEN tipo_evento_dia = 'saida' THEN 'saida_purc_observada'
        ELSE null
    END AS motivo_saida,

    'PURC_OBSERVADO' AS origem_modelagem,
    'execucao_purc_observado' AS id_execucao,
    current_timestamp AS dt_ingestao_modelo,

    anomes AS p_anomes
FROM final;
```

## 7. Mart — carteira média mensal

```sql
CREATE TABLE IF NOT EXISTS workspace_db.iceberg_gold_mart_cobranca_carteira_media_escritorio_mes (
    anomes                          integer,
    escritorio                      varchar,
    origem_modelagem                varchar,

    qt_dias_observados              integer,
    qt_contratos_expostos           bigint,

    vl_saldo_dia_acumulado          decimal(22,2),
    vl_carteira_media               decimal(18,2),

    vl_entrada_mes                  decimal(18,2),
    vl_saida_mes                    decimal(18,2),
    vl_estoque_medio                decimal(18,2),

    qt_entradas_mes                 bigint,
    qt_saidas_mes                   bigint,

    id_execucao                     varchar,
    dt_ingestao_modelo              timestamp,

    p_anomes                        integer
)
WITH (
    table_type = 'ICEBERG',
    format = 'PARQUET',
    write_compression = 'SNAPPY',
    partitioning = ARRAY['p_anomes'],
    location = 's3://lakehouse/gold/cobranca/iceberg_gold_mart_cobranca_carteira_media_escritorio_mes/'
);
```

```sql
DELETE FROM workspace_db.iceberg_gold_mart_cobranca_carteira_media_escritorio_mes
WHERE p_anomes BETWEEN 202401 AND 202604;
```

```sql
INSERT INTO workspace_db.iceberg_gold_mart_cobranca_carteira_media_escritorio_mes
WITH base AS (
    SELECT *
    FROM workspace_db.iceberg_gold_fato_cobranca_carteira_distribuida_dia
    WHERE p_anomes BETWEEN 202401 AND 202604
      AND fl_distribuido = true
),

agg AS (
    SELECT
        anomes,
        escritorio,
        origem_modelagem,

        count(DISTINCT dt_ref) AS qt_dias_observados,
        count(DISTINCT contrato || '|' || produto) AS qt_contratos_expostos,

        sum(vl_saldo) AS vl_saldo_dia_acumulado,

        cast(
            sum(vl_saldo) / nullif(count(DISTINCT dt_ref), 0)
            AS decimal(18,2)
        ) AS vl_carteira_media,

        cast(sum(CASE WHEN tipo_evento_dia = 'entrada' THEN vl_saldo ELSE 0 END) AS decimal(18,2)) AS vl_entrada_mes,
        cast(sum(CASE WHEN tipo_evento_dia = 'saida' THEN vl_saldo ELSE 0 END) AS decimal(18,2)) AS vl_saida_mes,

        cast(
            sum(CASE WHEN tipo_evento_dia = 'estoque' THEN vl_saldo ELSE 0 END)
            / nullif(count(DISTINCT dt_ref), 0)
            AS decimal(18,2)
        ) AS vl_estoque_medio,

        count(DISTINCT CASE WHEN tipo_evento_dia = 'entrada' THEN contrato || '|' || produto END) AS qt_entradas_mes,
        count(DISTINCT CASE WHEN tipo_evento_dia = 'saida' THEN contrato || '|' || produto END) AS qt_saidas_mes,

        max(id_execucao) AS id_execucao
    FROM base
    GROUP BY 1,2,3
)

SELECT
    anomes,
    escritorio,
    origem_modelagem,

    cast(qt_dias_observados AS integer) AS qt_dias_observados,
    qt_contratos_expostos,

    cast(vl_saldo_dia_acumulado AS decimal(22,2)) AS vl_saldo_dia_acumulado,
    vl_carteira_media,

    vl_entrada_mes,
    vl_saida_mes,
    vl_estoque_medio,

    qt_entradas_mes,
    qt_saidas_mes,

    id_execucao,
    current_timestamp AS dt_ingestao_modelo,

    anomes AS p_anomes
FROM agg;
```

O ponto crítico: a **Gold diária** vira sua verdade auditável; a **Mart mensal** vira consumo para meta, eficiência e QuickSight. Esse padrão de `DELETE + INSERT por partição` é adequado para snapshots mensais/fechamentos no Athena Iceberg. 
