## 2. Silver padronizado

```sql
-- =========================================================
-- 2.1 SILVER PADRONIZADO — CARTEIRA HISTÓRICA
-- =========================================================

CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_cobranca_carteira_distribuida_historica AS
SELECT
    dt_foto AS p_dt_foto,

    cast(substr(cast(dt_foto AS varchar), 1, 6) AS integer) AS mes_ref_yyyymm,
    dt_foto AS dt_ref_yyyymmdd,
    cast(date_parse(cast(dt_foto AS varchar), '%Y%m%d') AS date) AS dt_ref_date,
    cast(date_parse(cast(dt_foto AS varchar), '%Y%m%d') AS timestamp) AS ts_ref,

    cast(contrato AS varchar) AS contrato,
    cast(produto AS varchar) AS produto,
    cast(escritorio AS varchar) AS escritorio,

    cast(vl_saldo AS decimal(18,2)) AS vl_saldo,
    cast(dias_atraso_contrato AS integer) AS dias_atraso_contrato,
    cast(faixa_atraso_contrato AS varchar) AS faixa_atraso_contrato,

    current_timestamp AS dt_ingestao_modelo,
    'silver_padronizado_manual' AS id_execucao,

    md5(
        concat(
            coalesce(cast(contrato AS varchar), ''),
            '|', coalesce(cast(produto AS varchar), ''),
            '|', coalesce(cast(escritorio AS varchar), ''),
            '|', coalesce(cast(dt_foto AS varchar), '')
        )
    ) AS hash_chave_negocio,

    md5(
        concat(
            coalesce(cast(vl_saldo AS varchar), ''),
            '|', coalesce(cast(dias_atraso_contrato AS varchar), ''),
            '|', coalesce(cast(faixa_atraso_contrato AS varchar), '')
        )
    ) AS hash_atributos
FROM workspace_db.tabela_bronze_fonte_cobranca_carteira_distribuida_historica;
