## 3. Silver integrado — histórico acumulado simulado

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_carteira_historica_intervalo_simulado AS
WITH carteira_base AS (
    SELECT
        mes_ref_yyyymm AS anomes,
        dt_ref_yyyymmdd AS dt_foto,
        dt_ref_date AS dt_foto_date,

        contrato,
        produto,
        escritorio,

        vl_saldo,
        dias_atraso_contrato AS dias_atraso_carteira,
        faixa_atraso_contrato
    FROM workspace_db.view_silver_padronizado_cobranca_carteira_distribuida_historica
    WHERE mes_ref_yyyymm <= 202512
),

-- Menor dt_foto do mês por contrato/produto/escritório
carteira_primeira_foto AS (
    SELECT *
    FROM (
        SELECT
            c.*,
            row_number() OVER (
                PARTITION BY anomes, contrato, produto, escritorio
                ORDER BY dt_foto ASC
            ) AS rn
        FROM carteira_base c
    )
    WHERE rn = 1
),

janela_observacao AS (
    SELECT
        c.*,
        dia AS dt_check,
        cast(date_format(dia, '%Y%m%d') AS integer) AS nomegia_check
    FROM carteira_primeira_foto c
    CROSS JOIN UNNEST(
        sequence(
            date_add('day', -3, c.dt_foto_date),
            date_add('day',  4, c.dt_foto_date),
            interval '1' day
        )
    ) AS t(dia)
),

avaliacao_opc AS (
    SELECT
        j.*,
        o.dias_atraso_contrato AS dias_atraso_opc,

        CASE
            WHEN o.contrato IS NULL THEN true
            ELSE false
        END AS fl_nao_existe_opc,

        CASE
            WHEN o.contrato IS NOT NULL
             AND o.dias_atraso_contrato < j.dias_atraso_carteira
                THEN true
            ELSE false
        END AS fl_retroagiu_atraso,

        CASE
            WHEN o.contrato IS NULL THEN 'nao_existe_opc'
            WHEN o.dias_atraso_contrato < j.dias_atraso_carteira THEN 'retroagiu_atraso'
            ELSE null
        END AS motivo_saida_candidato
    FROM janela_observacao j
    LEFT JOIN workspace_db.view_silver_padronizado_cobranca_opc_diaria o
        ON j.contrato = o.contrato
       AND j.produto = o.produto
       AND j.nomegia_check = o.dt_ref_yyyymmdd
),

saida_simulada AS (
    SELECT
        anomes,
        contrato,
        produto,
        escritorio,

        min(dt_check) AS dt_saida_simulada,
        min_by(motivo_saida_candidato, dt_check) AS motivo_saida
    FROM avaliacao_opc
    WHERE fl_nao_existe_opc = true
       OR fl_retroagiu_atraso = true
    GROUP BY 1,2,3,4
)

SELECT
    c.anomes,
    c.contrato,
    c.produto,
    c.escritorio,

    c.vl_saldo,
    c.dias_atraso_carteira AS dias_atraso_contrato,
    c.faixa_atraso_contrato,

    c.dt_foto_date AS dt_entrada_exposicao,

    least(
        last_day_of_month(c.dt_foto_date),
        coalesce(s.dt_saida_simulada, last_day_of_month(c.dt_foto_date))
    ) AS dt_saida_exposicao,

    coalesce(s.motivo_saida, 'fim_mes_sem_saida_simulada') AS motivo_saida
FROM carteira_primeira_foto c
LEFT JOIN saida_simulada s
    ON c.anomes = s.anomes
   AND c.contrato = s.contrato
   AND c.produto = s.produto
   AND c.escritorio = s.escritorio;
```

