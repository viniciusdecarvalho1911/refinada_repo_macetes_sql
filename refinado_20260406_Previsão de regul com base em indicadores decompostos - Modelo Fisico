# 4) SQL da curva histórica de delay

Aqui está a parte mais importante da base histórica.

A mart abaixo calcula:

- `% de conversão no delay`
- `% acumulado até o delay`
- conversão final histórica
- ticket histórico

Vou usar:

- últimos 6 meses
- mais o mesmo mês do ano anterior
- `p25/p50/p75`

Isso está em linha com a sua própria recomendação de combinar recência e sazonalidade anual, em vez de usar média simples.

DELETE FROM gold_db.iceberg_gold_mart_cobranca_curva_delay_historica  
WHERE anomes_referencia = 202603;  
  
INSERT INTO gold_db.iceberg_gold_mart_cobranca_curva_delay_historica  
WITH historico_filtrado AS (  
    SELECT *  
    FROM gold_db.iceberg_gold_fato_cobranca_safra_conversao_delay  
    WHERE anomes IN (202602, 202601, 202512, 202511, 202510, 202509, 202503)  
),  
conv_final_safra AS (  
    SELECT  
        dt_emissao,  
        anomes,  
        escritorio,  
        bucket_modelagem,  
        max(qtd_emitidos_safra)                                         AS qtd_emitidos_safra,  
        sum(qtd_convertidos_delay)                                      AS qtd_convertidos_total,  
        sum(cast(vl_convertido_delay as double))                        AS vl_convertido_total,  
        sum(cast(vl_convertido_delay as double))  
            / nullif(sum(qtd_convertidos_delay), 0)                     AS ticket_pago_final  
    FROM historico_filtrado  
    GROUP BY 1,2,3,4  
),  
delay_pct AS (  
    SELECT  
        h.anomes,  
        h.escritorio,  
        h.bucket_modelagem,  
        h.delay_dias,  
        h.dt_emissao,  
  
        cast(h.qtd_convertidos_delay as double) / nullif(h.qtd_emitidos_safra, 0) AS pct_conv_no_delay  
    FROM historico_filtrado h  
),  
delay_acum AS (  
    SELECT  
        d.anomes,  
        d.escritorio,  
        d.bucket_modelagem,  
        d.delay_dias,  
        d.dt_emissao,  
        d.pct_conv_no_delay,  
  
        sum(d.pct_conv_no_delay) over (  
            partition by d.dt_emissao, d.escritorio, d.bucket_modelagem  
            order by d.delay_dias  
            rows between unbounded preceding and current row  
        ) AS pct_conv_acum_delay  
    FROM delay_pct d  
),  
base_final AS (  
    SELECT  
        a.anomes,  
        a.escritorio,  
        a.bucket_modelagem,  
        a.delay_dias,  
        a.pct_conv_no_delay,  
        a.pct_conv_acum_delay,  
        cast(f.qtd_convertidos_total as double) / nullif(f.qtd_emitidos_safra, 0) AS conv_final_hist,  
        f.ticket_pago_final  
    FROM delay_acum a  
    JOIN conv_final_safra f  
      ON a.dt_emissao = f.dt_emissao  
     AND a.anomes = f.anomes  
     AND a.escritorio = f.escritorio  
     AND a.bucket_modelagem = f.bucket_modelagem  
)  
SELECT  
    202603 AS anomes_referencia,  
    escritorio,  
    bucket_modelagem,  
    delay_dias,  
    count(*) AS qtd_safras,  
  
    approx_percentile(pct_conv_no_delay, 0.25) AS pct_conv_no_delay_p25,  
    approx_percentile(pct_conv_no_delay, 0.50) AS pct_conv_no_delay_p50,  
    approx_percentile(pct_conv_no_delay, 0.75) AS pct_conv_no_delay_p75,  
  
    approx_percentile(pct_conv_acum_delay, 0.25) AS pct_conv_acum_delay_p25,  
    approx_percentile(pct_conv_acum_delay, 0.50) AS pct_conv_acum_delay_p50,  
    approx_percentile(pct_conv_acum_delay, 0.75) AS pct_conv_acum_delay_p75,  
  
    approx_percentile(conv_final_hist, 0.25) AS conv_final_hist_p25,  
    approx_percentile(conv_final_hist, 0.50) AS conv_final_hist_p50,  
    approx_percentile(conv_final_hist, 0.75) AS conv_final_hist_p75,  
  
    approx_percentile(ticket_pago_final, 0.25) AS ticket_pago_hist_p25,  
    approx_percentile(ticket_pago_final, 0.50) AS ticket_pago_hist_p50,  
    approx_percentile(ticket_pago_final, 0.75) AS ticket_pago_hist_p75,  
  
    current_timestamp,  
    'exec_202603_curva_delay'  
FROM base_final  
GROUP BY 1,2,3,4;

