# 5) SQL da projeção por safra com guardrails

Agora vem o coração do modelo.

A lógica é esta:

conv_final_implicita = conv_obs_acum / pct_hist_acum_ate_idade  
conv_final_proj      = blend(histórico, implícita)  
depois aplica clip

E os guardrails são:

- **idade da safra controla o peso do observado**
- **clip superior/inferior relativo ao histórico**
- **ticket também entra suavizado**
- **não deixar D+0/D+1 mandar demais**

Isso bate diretamente com o seu framework anti-estouro: projeção precisa ganhar confiança com o mês, e conversão é a variável que mais precisa ser suavizada no começo.

DELETE FROM gold_db.iceberg_gold_mart_cobranca_projecao_safra_diaria  
WHERE dt_base = current_date;  
  
INSERT INTO gold_db.iceberg_gold_mart_cobranca_projecao_safra_diaria  
WITH safra_emitida AS (  
    SELECT *  
    FROM gold_db.iceberg_gold_fato_cobranca_safra_emissao  
    WHERE anomes = cast(date_format(current_date, '%Y%m') as integer)  
),  
observado_ate_hoje AS (  
    SELECT  
        s.dt_emissao,  
        s.anomes,  
        s.escritorio,  
        s.bucket_modelagem,  
        max(s.qtd_emitidos) AS qtd_emitidos_safra,  
  
        coalesce(sum(d.qtd_convertidos_delay), 0) AS qtd_convertidos_ate_hoje,  
        cast(coalesce(sum(cast(d.vl_convertido_delay as double)), 0) as decimal(18,2)) AS vl_convertido_ate_hoje,  
        avg(cast(d.ticket_pago_medio_delay as double)) AS ticket_pago_obs_ate_hoje_raw  
    FROM safra_emitida s  
    LEFT JOIN gold_db.iceberg_gold_fato_cobranca_safra_conversao_delay d  
      ON s.dt_emissao = d.dt_emissao  
     AND s.anomes = d.anomes  
     AND s.escritorio = d.escritorio  
     AND s.bucket_modelagem = d.bucket_modelagem  
     AND d.delay_dias <= date_diff('day', s.dt_emissao, current_date)  
    GROUP BY 1,2,3,4  
),  
curva AS (  
    SELECT *  
    FROM gold_db.iceberg_gold_mart_cobranca_curva_delay_historica  
    WHERE anomes_referencia = cast(date_format(current_date, '%Y%m') as integer)  
),  
base AS (  
    SELECT  
        current_date AS dt_base,  
        o.anomes,  
        o.escritorio,  
        o.dt_emissao,  
        o.bucket_modelagem,  
        date_diff('day', o.dt_emissao, current_date) AS idade_safra_dias,  
  
        o.qtd_emitidos_safra,  
        o.qtd_convertidos_ate_hoje,  
        o.vl_convertido_ate_hoje,  
  
        cast(o.qtd_convertidos_ate_hoje as double) / nullif(o.qtd_emitidos_safra, 0) AS conv_obs_acum,  
  
        coalesce(c.pct_conv_acum_delay_p50, 1.0) AS pct_hist_acum_ate_idade,  
        c.conv_final_hist_p50 AS conv_final_hist,  
        c.ticket_pago_hist_p50 AS ticket_pago_hist,  
  
        coalesce(o.ticket_pago_obs_ate_hoje_raw, c.ticket_pago_hist_p50) AS ticket_pago_obs_ate_hoje  
    FROM observado_ate_hoje o  
    LEFT JOIN curva c  
      ON o.escritorio = c.escritorio  
     AND o.bucket_modelagem = c.bucket_modelagem  
     AND date_diff('day', o.dt_emissao, current_date) = c.delay_dias  
),  
regras AS (  
    SELECT  
        *,  
        CASE  
            WHEN idade_safra_dias <= 1 THEN 0.90  
            WHEN idade_safra_dias <= 3 THEN 0.75  
            WHEN idade_safra_dias <= 5 THEN 0.55  
            ELSE 0.35  
        END AS peso_hist,  
  
        CASE  
            WHEN idade_safra_dias <= 2 THEN 1.15  
            WHEN idade_safra_dias <= 4 THEN 1.25  
            ELSE 1.40  
        END AS fator_teto,  
  
        CASE  
            WHEN idade_safra_dias <= 2 THEN 0.85  
            WHEN idade_safra_dias <= 4 THEN 0.80  
            ELSE 0.70  
        END AS fator_piso  
    FROM base  
),  
calculado AS (  
    SELECT  
        *,  
        1 - peso_hist AS peso_obs,  
  
        conv_obs_acum / nullif(pct_hist_acum_ate_idade, 0) AS conv_final_implicita_raw,  
  
        (  
            peso_hist * conv_final_hist  
            + (1 - peso_hist) * (conv_obs_acum / nullif(pct_hist_acum_ate_idade, 0))  
        ) AS conv_final_proj_blend,  
  
        (  
            peso_hist * ticket_pago_hist  
            + (1 - peso_hist) * ticket_pago_obs_ate_hoje  
        ) AS ticket_pago_proj_blend  
    FROM regras  
),  
clipado AS (  
    SELECT  
        *,  
        least(  
            conv_final_hist * fator_teto,  
            greatest(conv_final_hist * fator_piso, conv_final_proj_blend)  
        ) AS conv_final_proj,  
  
        least(  
            ticket_pago_hist * 1.20,  
            greatest(ticket_pago_hist * 0.85, ticket_pago_proj_blend)  
        ) AS ticket_pago_proj  
    FROM calculado  
),  
final AS (  
    SELECT  
        dt_base,  
        anomes,  
        escritorio,  
        dt_emissao,  
        bucket_modelagem,  
        idade_safra_dias,  
  
        qtd_emitidos_safra,  
        qtd_convertidos_ate_hoje,  
        vl_convertido_ate_hoje,  
  
        conv_obs_acum,  
        pct_hist_acum_ate_idade,  
        conv_final_implicita_raw AS conv_final_implicita,  
        conv_final_hist,  
        conv_final_proj,  
  
        ticket_pago_hist,  
        ticket_pago_obs_ate_hoje,  
        ticket_pago_proj,  
  
        qtd_emitidos_safra * conv_final_proj AS qtd_convertida_final_proj,  
        (qtd_emitidos_safra * conv_final_proj) - qtd_convertidos_ate_hoje AS qtd_ainda_converter_proj,  
  
        cast(qtd_emitidos_safra * conv_final_proj * ticket_pago_proj as decimal(18,2)) AS regul_final_proj_safra,  
        vl_convertido_ate_hoje AS regul_ja_observado_safra,  
        cast((qtd_emitidos_safra * conv_final_proj * ticket_pago_proj) - cast(vl_convertido_ate_hoje as double) as decimal(18,2))  
            AS regul_ainda_esperado_safra,  
  
        case when conv_final_proj = conv_final_hist * fator_teto then 1 else 0 end AS fl_clip_superior,  
        case when conv_final_proj = conv_final_hist * fator_piso then 1 else 0 end AS fl_clip_inferior,  
        peso_hist,  
        peso_obs,  
        fator_teto,  
        fator_piso,  
  
        current_timestamp AS dt_ingestao_modelo,  
        'exec_proj_safra_' || cast(current_date as varchar) AS id_execucao  
    FROM clipado  
)  
SELECT * FROM final;

