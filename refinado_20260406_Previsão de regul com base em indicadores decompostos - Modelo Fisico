## 6.2 SQL da consolidação final da regul projetada por escritório/mês

A lógica abaixo fecha o mês com 3 componentes:

```text
1. regul já realizado no mês
2. regul projetado das safras já emitidas
3. regul projetado das emissões futuras ainda não feitas
```

### Fórmula executiva

```text
REGUL_PROJ_TOTAL_MES
=
REGUL_JA_REALIZADO_MES
+ REGUL_AINDA_ESPERADO_SAFRAS_EMITIDAS
+ REGUL_ESPERADO_EMISSOES_FUTURAS
```

Isso é exatamente a separação conceitual mais correta para o seu caso: fatos com timings diferentes devem viver separados, em vez de uma tabela única “misturada”. Isso está alinhado com a lógica dimensional de separar processos/fatos por timing e grão.

---

### SQL completo

```sql
DELETE FROM gold_db.iceberg_gold_mart_cobranca_regul_projetada_escritorio_mes
WHERE dt_base = current_date
  AND anomes = cast(date_format(current_date, '%Y%m') as integer);

INSERT INTO gold_db.iceberg_gold_mart_cobranca_regul_projetada_escritorio_mes
WITH params AS (
    SELECT
        current_date AS dt_base,
        cast(date_format(current_date, '%Y%m') as integer) AS anomes_atual
),

-- =========================================================
-- 1) Calendário do mês atual
-- =========================================================
cal_mes AS (
    SELECT
        c.dt_ref_date,
        c.anomes,
        c.dia_util_mes,
        c.qt_dias_uteis_mes,
        c.fl_dia_util
    FROM ctrl_db.dim_calendario c
    JOIN params p
      ON c.anomes = p.anomes_atual
    WHERE c.fl_dia_util = 1
),

du_atual AS (
    SELECT
        p.dt_base,
        p.anomes_atual AS anomes,
        max(c.dia_util_mes) AS dia_util_corrente,
        max(c.qt_dias_uteis_mes) AS qt_dias_uteis_mes
    FROM params p
    JOIN cal_mes c
      ON c.dt_ref_date <= p.dt_base
    GROUP BY 1,2
),

-- =========================================================
-- 2) Realizado do mês até hoje
-- =========================================================
realizado_mes AS (
    SELECT
        p.dt_base,
        p.anomes_atual AS anomes,
        e.escritorio,
        cast(sum(coalesce(pg.vl_pago, 0)) as decimal(18,2)) AS regul_ja_realizado_mes,
        count(distinct e.boleto_id) AS qtd_emitidos_ate_hoje
    FROM params p
    JOIN silver_db.view_silver_integrado_cobranca_boletos_emitidos e
      ON cast(date_format(cast(e.dt_emissao as date), '%Y%m') as integer) = p.anomes_atual
     AND cast(e.dt_emissao as date) <= p.dt_base
    LEFT JOIN silver_db.view_silver_integrado_cobranca_boletos_pagos pg
      ON cast(e.boleto_id as varchar) = cast(pg.boleto_id as varchar)
     AND cast(pg.dt_pagamento as date) <= p.dt_base
     AND cast(date_format(cast(pg.dt_pagamento as date), '%Y%m') as integer) = p.anomes_atual
    GROUP BY 1,2,3
),

-- =========================================================
-- 3) Projeção das safras já emitidas
--    Aqui eu separo:
--    - regul final projetado das safras
--    - regul já observado das safras
--    - regul ainda esperado
-- =========================================================
proj_safras_emitidas AS (
    SELECT
        dt_base,
        anomes,
        escritorio,
        cast(sum(regul_final_proj_safra) as decimal(18,2)) AS regul_proj_safras_emitidas_mes,
        cast(sum(regul_ja_observado_safra) as decimal(18,2)) AS regul_ja_observado_safras_mes,
        cast(sum(regul_ainda_esperado_safra) as decimal(18,2)) AS regul_ainda_esperado_safras_mes,
        sum(qtd_emitidos_safra) AS qtd_emitidos_safras_mes,
        avg(conv_final_proj) AS conv_media_proj_safras,
        avg(ticket_pago_proj) AS ticket_medio_proj_safras
    FROM gold_db.iceberg_gold_mart_cobranca_projecao_safra_diaria
    WHERE dt_base = current_date
      AND anomes = cast(date_format(current_date, '%Y%m') as integer)
    GROUP BY 1,2,3
),

-- =========================================================
-- 4) Curva esperada de emissão por DU
--    Mart assumida previamente construída
-- =========================================================
curva_emissao AS (
    SELECT
        c.escritorio,
        c.dia_util_mes,
        c.pct_emitidos_acum_p50,
        c.emitidos_final_hist_p50
    FROM gold_db.iceberg_gold_mart_cobranca_curva_expectativa_emissao_du c
    JOIN params p
      ON c.anomes_referencia = p.anomes_atual
),

-- =========================================================
-- 5) Emissão acumulada observada até hoje
-- =========================================================
emitido_obs AS (
    SELECT
        p.dt_base,
        p.anomes_atual AS anomes,
        e.escritorio,
        count(*) AS qtd_emitidos_ate_hoje
    FROM params p
    JOIN silver_db.view_silver_integrado_cobranca_boletos_emitidos e
      ON cast(date_format(cast(e.dt_emissao as date), '%Y%m') as integer) = p.anomes_atual
     AND cast(e.dt_emissao as date) <= p.dt_base
    GROUP BY 1,2,3
),

-- =========================================================
-- 6) Projeção da emissão total do mês
--    Com guardrail simples: blend entre histórico e implícita
-- =========================================================
emitidos_proj AS (
    SELECT
        o.dt_base,
        o.anomes,
        o.escritorio,
        d.dia_util_corrente,
        d.qt_dias_uteis_mes,
        o.qtd_emitidos_ate_hoje,
        ce.pct_emitidos_acum_p50,
        ce.emitidos_final_hist_p50,

        cast(o.qtd_emitidos_ate_hoje as double)
            / nullif(ce.pct_emitidos_acum_p50, 0) AS qtd_emitidos_proj_implicita,

        CASE
            WHEN d.dia_util_corrente <= 5 THEN 0.85
            WHEN d.dia_util_corrente <= 8 THEN 0.75
            WHEN d.dia_util_corrente <= 10 THEN 0.65
            WHEN d.dia_util_corrente <= 13 THEN 0.50
            WHEN d.dia_util_corrente <= 16 THEN 0.35
            ELSE 0.20
        END AS peso_hist
    FROM emitido_obs o
    CROSS JOIN du_atual d
    LEFT JOIN curva_emissao ce
      ON o.escritorio = ce.escritorio
     AND d.dia_util_corrente = ce.dia_util_mes
),

emitidos_proj_clip AS (
    SELECT
        dt_base,
        anomes,
        escritorio,
        qtd_emitidos_ate_hoje,
        pct_emitidos_acum_p50,
        emitidos_final_hist_p50,
        qtd_emitidos_proj_implicita,
        peso_hist,
        1 - peso_hist AS peso_obs,

        (
            peso_hist * emitidos_final_hist_p50
            + (1 - peso_hist) * qtd_emitidos_proj_implicita
        ) AS qtd_emitidos_proj_blend
    FROM emitidos_proj
),

emitidos_final AS (
    SELECT
        dt_base,
        anomes,
        escritorio,
        qtd_emitidos_ate_hoje,

        least(
            emitidos_final_hist_p50 * 1.25,
            greatest(emitidos_final_hist_p50 * 0.80, qtd_emitidos_proj_blend)
        ) AS qtd_emitidos_proj_mes
    FROM emitidos_proj_clip
),

-- =========================================================
-- 7) Emissões futuras = total projetado - já emitido
-- =========================================================
emissoes_futuras AS (
    SELECT
        e.dt_base,
        e.anomes,
        e.escritorio,
        e.qtd_emitidos_ate_hoje,
        e.qtd_emitidos_proj_mes,
        greatest(e.qtd_emitidos_proj_mes - e.qtd_emitidos_ate_hoje, 0) AS qtd_emitidos_futuros_proj
    FROM emitidos_final e
),

-- =========================================================
-- 8) Conversão/ticket esperados para emissões futuras
--    Uso da média projetada das safras já emitidas como proxy
--    Se não houver safra suficiente, cai para histórico implícito
-- =========================================================
param_futuro AS (
    SELECT
        ef.dt_base,
        ef.anomes,
        ef.escritorio,
        ef.qtd_emitidos_ate_hoje,
        ef.qtd_emitidos_proj_mes,
        ef.qtd_emitidos_futuros_proj,

        coalesce(ps.conv_media_proj_safras, 0.20) AS conv_media_proj_mes,
        coalesce(ps.ticket_medio_proj_safras, 350.0) AS ticket_medio_proj_mes
    FROM emissoes_futuras ef
    LEFT JOIN proj_safras_emitidas ps
      ON ef.dt_base = ps.dt_base
     AND ef.anomes = ps.anomes
     AND ef.escritorio = ps.escritorio
),

regul_futuro AS (
    SELECT
        dt_base,
        anomes,
        escritorio,
        qtd_emitidos_ate_hoje,
        qtd_emitidos_proj_mes,
        conv_media_proj_mes,
        ticket_medio_proj_mes,
        cast(qtd_emitidos_futuros_proj * conv_media_proj_mes * ticket_medio_proj_mes as decimal(18,2))
            AS regul_proj_emissoes_futuras_mes
    FROM param_futuro
),

-- =========================================================
-- 9) Carteira do mês para eficiência
--    Ajuste a origem conforme sua tabela oficial mensal
-- =========================================================
carteira_mes AS (
    SELECT
        cast(anomes as integer) AS anomes,
        cast(escritorio as varchar) AS escritorio,
        cast(sum(vl_carteira) as double) AS carteira_mes
    FROM gold_db.iceberg_gold_fato_cobranca_escritorio_mes
    WHERE anomes = cast(date_format(current_date, '%Y%m') as integer)
    GROUP BY 1,2
),

-- =========================================================
-- 10) Consolidação
-- =========================================================
final AS (
    SELECT
        p.dt_base,
        p.anomes,
        p.escritorio,

        coalesce(r.regul_ja_realizado_mes, cast(0 as decimal(18,2))) AS regul_ja_realizado_mes,
        coalesce(s.regul_proj_safras_emitidas_mes, cast(0 as decimal(18,2))) AS regul_proj_safras_emitidas_mes,
        coalesce(f.regul_proj_emissoes_futuras_mes, cast(0 as decimal(18,2))) AS regul_proj_emissoes_futuras_mes,

        cast(
            coalesce(s.regul_proj_safras_emitidas_mes, cast(0 as decimal(18,2))) +
            coalesce(f.regul_proj_emissoes_futuras_mes, cast(0 as decimal(18,2)))
            as decimal(18,2)
        ) AS regul_proj_total_mes,

        cast(
            (
                cast(
                    coalesce(s.regul_proj_safras_emitidas_mes, cast(0 as decimal(18,2))) +
                    coalesce(f.regul_proj_emissoes_futuras_mes, cast(0 as decimal(18,2)))
                    as double
                )
            ) / nullif(c.carteira_mes, 0)
            as double
        ) AS eficiencia_proj_total_mes,

        coalesce(f.qtd_emitidos_ate_hoje, 0) AS qtd_emitidos_ate_hoje,
        coalesce(f.qtd_emitidos_proj_mes, 0) AS qtd_emitidos_proj_mes,

        coalesce(f.conv_media_proj_mes, s.conv_media_proj_safras, 0.0) AS conv_media_proj_mes,
        coalesce(f.ticket_medio_proj_mes, s.ticket_medio_proj_safras, 0.0) AS ticket_medio_proj_mes,

        CASE
            WHEN d.dia_util_corrente <= 5 THEN 'baixa'
            WHEN d.dia_util_corrente <= 10 THEN 'media'
            WHEN d.dia_util_corrente <= 15 THEN 'media_alta'
            ELSE 'alta'
        END AS nivel_confianca,

        concat(
            'Projeção de regul de ',
            cast(round(
                cast(
                    coalesce(s.regul_proj_safras_emitidas_mes, cast(0 as decimal(18,2))) +
                    coalesce(f.regul_proj_emissoes_futuras_mes, cast(0 as decimal(18,2)))
                    as double
                ), 0
            ) as varchar),
            '. Eficiência projetada de ',
            cast(round(
                (
                    cast(
                        coalesce(s.regul_proj_safras_emitidas_mes, cast(0 as decimal(18,2))) +
                        coalesce(f.regul_proj_emissoes_futuras_mes, cast(0 as decimal(18,2)))
                        as double
                    ) / nullif(c.carteira_mes, 0)
                ) * 100, 2
            ) as varchar),
            '%. Confiança ',
            CASE
                WHEN d.dia_util_corrente <= 5 THEN 'baixa'
                WHEN d.dia_util_corrente <= 10 THEN 'média'
                WHEN d.dia_util_corrente <= 15 THEN 'média-alta'
                ELSE 'alta'
            END,
            '.'
        ) AS txt_projecao,

        current_timestamp AS dt_ingestao_modelo,
        'exec_regul_proj_' || cast(current_date as varchar) AS id_execucao
    FROM params p
    CROSS JOIN du_atual d
    LEFT JOIN realizado_mes r
      ON p.dt_base = r.dt_base
     AND p.anomes_atual = r.anomes
    LEFT JOIN proj_safras_emitidas s
      ON p.dt_base = s.dt_base
     AND p.anomes_atual = s.anomes
     AND r.escritorio = s.escritorio
    LEFT JOIN regul_futuro f
      ON p.dt_base = f.dt_base
     AND p.anomes_atual = f.anomes
     AND coalesce(r.escritorio, s.escritorio) = f.escritorio
    LEFT JOIN carteira_mes c
      ON p.anomes_atual = c.anomes
     AND coalesce(r.escritorio, s.escritorio, f.escritorio) = c.escritorio
    WHERE coalesce(r.escritorio, s.escritorio, f.escritorio) IS NOT NULL
)

SELECT * FROM final;
```

