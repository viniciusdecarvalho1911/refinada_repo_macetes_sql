# 2) SQL de carga da safra de emissão

Aqui eu parto da sua view integrada de boletos emitidos.

DELETE FROM gold_db.iceberg_gold_fato_cobranca_safra_emissao  
WHERE anomes = 202603;  
  
INSERT INTO gold_db.iceberg_gold_fato_cobranca_safra_emissao  
WITH base AS (  
    SELECT  
        cast(dt_emissao as date)                                AS dt_emissao,  
        cast(date_format(cast(dt_emissao as date), '%Y%m') as integer) AS anomes,  
        cast(escritorio as varchar)                             AS escritorio,  
  
        cast(tp_negociacao as varchar)                          AS tp_negociacao,  
  
        CASE  
            WHEN coalesce(perc_desconto, 0) = 0 THEN '00_0'  
            WHEN perc_desconto <= 0.10 THEN '01_ATE_10'  
            WHEN perc_desconto <= 0.20 THEN '02_ATE_20'  
            WHEN perc_desconto <= 0.30 THEN '03_ATE_30'  
            ELSE '04_ACIMA_30'  
        END AS faixa_desconto,  
  
        CASE  
            WHEN vl_boleto_emitido < 200 THEN '01_ATE_199'  
            WHEN vl_boleto_emitido < 400 THEN '02_200_399'  
            WHEN vl_boleto_emitido < 800 THEN '03_400_799'  
            ELSE '04_800_MAIS'  
        END AS faixa_ticket,  
  
        cast(canal as varchar)                                  AS canal,  
        cast(faixa_atraso as varchar)                           AS faixa_atraso,  
  
        cast(boleto_id as varchar)                              AS boleto_id,  
        cast(vl_boleto_emitido as decimal(18,2))                AS vl_boleto_emitido  
    FROM silver_db.view_silver_integrado_cobranca_boletos_emitidos  
    WHERE cast(date_format(cast(dt_emissao as date), '%Y%m') as integer) = 202603  
),  
bucketizado AS (  
    SELECT  
        dt_emissao,  
        anomes,  
        escritorio,  
        concat(  
            coalesce(tp_negociacao, 'NA'), '|',  
            coalesce(faixa_desconto, 'NA'), '|',  
            coalesce(faixa_ticket, 'NA'), '|',  
            coalesce(canal, 'NA'), '|',  
            coalesce(faixa_atraso, 'NA')  
        ) AS bucket_modelagem,  
  
        tp_negociacao,  
        faixa_desconto,  
        faixa_ticket,  
        canal,  
        faixa_atraso,  
  
        count(*)                                               AS qtd_emitidos,  
        cast(sum(vl_boleto_emitido) as decimal(18,2))          AS vl_emitido_total,  
        cast(avg(vl_boleto_emitido) as decimal(18,2))          AS ticket_emitido_medio  
    FROM base  
    GROUP BY 1,2,3,4,5,6,7,8,9  
)  
SELECT  
    dt_emissao,  
    anomes,  
    escritorio,  
    bucket_modelagem,  
    tp_negociacao,  
    faixa_desconto,  
    faixa_ticket,  
    canal,  
    faixa_atraso,  
    qtd_emitidos,  
    vl_emitido_total,  
    ticket_emitido_medio,  
    current_timestamp,  
    'exec_202603_safra_emissao'  
FROM bucketizado;

