import base64

KEY = ""

def xor_bytes(data, key):
    key_bytes = key.encode("utf-8")
    return bytes([
        b ^ key_bytes[i % len(key_bytes)]
        for i, b in enumerate(data)
    ])

def descriptografar(input_text, key):
    input_text = input_text.strip()

    # Corrige padding do Base64, se necessário
    missing_padding = len(input_text) % 4
    if missing_padding:
        input_text += "=" * (4 - missing_padding)

    decoded = base64.urlsafe_b64decode(input_text.encode("utf-8"))
    decrypted = xor_bytes(decoded, key)

    return decrypted.decode("utf-8", errors="replace")


