# 3. Template único já preparado para formatos mistos

Aqui vai um modelo mais geral.

```sql
WITH parametros AS (
    SELECT
        mes_ref,
        cast(date_trunc('month', mes_ref) as date) AS primeiro_dia,
        cast(date_add('day', -1, date_add('month', 1, date_trunc('month', mes_ref))) as date) AS ultimo_dia,

        cast(year(mes_ref) as bigint) AS ano,
        cast(month(mes_ref) as bigint) AS mes,

        cast(date_format(mes_ref, '%Y%m') as bigint) AS anomes_bigint,
        cast(date_format(mes_ref, '%Y%m') as varchar) AS anomes_varchar,

        cast(date_format(date_trunc('month', mes_ref), '%Y%m%d') as bigint) AS primeiro_dia_yyyymmdd,
        cast(date_format(date_add('day', -1, date_add('month', 1, date_trunc('month', mes_ref))), '%Y%m%d') as bigint) AS ultimo_dia_yyyymmdd,

        cast(date_format(date_trunc('month', mes_ref), '%Y-%m-%d') as varchar) AS primeiro_dia_iso,
        cast(date_format(date_add('day', -1, date_add('month', 1, date_trunc('month', mes_ref))), '%Y-%m-%d') as varchar) AS ultimo_dia_iso
    FROM UNNEST(
        sequence(
            DATE '2025-01-01',
            date_trunc('month', current_date),
            INTERVAL '1' MONTH
        )
    ) AS t(mes_ref)
),

base_date AS (
    SELECT
        p.anomes_bigint,
        a.contrato,
        a.valor
    FROM tabela_date a
    JOIN parametros p
      ON a.dt_referencia BETWEEN p.primeiro_dia AND p.ultimo_dia
),

base_yyyymmdd_bigint AS (
    SELECT
        p.anomes_bigint,
        b.contrato,
        b.status
    FROM tabela_bigint b
    JOIN parametros p
      ON b.dt_referencia BETWEEN p.primeiro_dia_yyyymmdd AND p.ultimo_dia_yyyymmdd
),

base_anomes_varchar AS (
    SELECT
        p.anomes_bigint,
        c.contrato,
        c.flag
    FROM tabela_anomes_varchar c
    JOIN parametros p
      ON c.anomes = p.anomes_varchar
),

final AS (
    SELECT
        a.anomes_bigint AS anomes,
        a.contrato,
        a.valor,
        b.status,
        c.flag
    FROM base_date a
    LEFT JOIN base_yyyymmdd_bigint b
      ON a.anomes_bigint = b.anomes_bigint
     AND a.contrato = b.contrato
    LEFT JOIN base_anomes_varchar c
      ON a.anomes_bigint = c.anomes_bigint
     AND a.contrato = c.contrato
)

SELECT *
FROM final
ORDER BY anomes, contrato;
```

