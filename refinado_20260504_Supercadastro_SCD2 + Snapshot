import sys
import base64

KEY = "juvini"  # troque aqui

def xor_bytes(data, key):
    key_bytes = key.encode()
    return bytes([b ^ key_bytes[i % len(key_bytes)] for i, b in enumerate(data)])

input_text = '''
'''
encrypted = xor_bytes(input_text.encode("utf-8"), KEY)
output = base64.urlsafe_b64encode(encrypted).decode("utf-8")


