# 7. SCD2 com delete lógico

## Uso

Quando uma chave sumiu da origem e você quer fechar a versão ativa sem apagar o histórico.

```sql
UPDATE workspace_db.iceberg_gold_dimensao_contrato_scd2
SET
    dt_fim_vigencia    = date_add('day', -1, current_date),
    fl_ativo           = false,
    fl_excluido_logico = true,
    dt_ingestao_modelo = current_timestamp,
    id_execucao        = 'exec_202604_scd2_delete_logico'
WHERE fl_ativo = true
  AND (contrato, produto) IN (
      WITH origem_atual AS (
          SELECT DISTINCT
              cast(contrato as varchar) AS contrato,
              cast(produto as varchar)  AS produto
          FROM workspace_db.view_silver_integrado_cobranca_contratos
          WHERE mes_ref_yyyymm = 202604
      ),

      ativos_destino AS (
          SELECT
              contrato,
              produto
          FROM workspace_db.iceberg_gold_dimensao_contrato_scd2
          WHERE fl_ativo = true
      ),

      removidos AS (
          SELECT
              t.contrato,
              t.produto
          FROM ativos_destino t
          LEFT JOIN origem_atual s
              ON  t.contrato = s.contrato
              AND t.produto  = s.produto
          WHERE s.contrato IS NULL
      )

      SELECT
          contrato,
          produto
      FROM removidos
  );
```

