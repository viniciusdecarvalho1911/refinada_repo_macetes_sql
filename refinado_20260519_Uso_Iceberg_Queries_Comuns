## 6.2 Inserir novas versões

```sql
INSERT INTO workspace_db.iceberg_gold_dimensao_contrato_scd2 (
    sk_contrato,
    contrato,
    produto,
    cnpj_raiz,
    escritorio,
    faixa_atraso,
    status_contrato,
    hash_atributos,
    dt_inicio_vigencia,
    dt_fim_vigencia,
    fl_ativo,
    fl_excluido_logico,
    dt_ingestao_modelo,
    id_execucao,
    anomes
)
WITH origem AS (
    SELECT
        cast(contrato as varchar)        AS contrato,
        cast(produto as varchar)         AS produto,
        cast(cnpj_raiz as varchar)       AS cnpj_raiz,
        cast(escritorio as varchar)      AS escritorio,
        cast(faixa_atraso as varchar)    AS faixa_atraso,
        cast(status_contrato as varchar) AS status_contrato,
        md5(
            concat(
                coalesce(cast(cnpj_raiz as varchar), ''),
                '|',
                coalesce(cast(escritorio as varchar), ''),
                '|',
                coalesce(cast(faixa_atraso as varchar), ''),
                '|',
                coalesce(cast(status_contrato as varchar), '')
            )
        ) AS hash_atributos
    FROM workspace_db.view_silver_integrado_cobranca_contratos
    WHERE mes_ref_yyyymm = 202604
),

atuais AS (
    SELECT
        contrato,
        produto,
        hash_atributos
    FROM workspace_db.iceberg_gold_dimensao_contrato_scd2
    WHERE fl_ativo = true
),

novos_ou_alterados AS (
    SELECT
        s.*
    FROM origem s
    LEFT JOIN atuais t
        ON  s.contrato = t.contrato
        AND s.produto  = t.produto
    WHERE t.contrato IS NULL
       OR t.hash_atributos <> s.hash_atributos
)

SELECT
    md5(
        concat(
            contrato,
            '|',
            produto,
            '|',
            cast(current_date as varchar)
        )
    ) AS sk_contrato,
    contrato,
    produto,
    cnpj_raiz,
    escritorio,
    faixa_atraso,
    status_contrato,
    hash_atributos,
    current_date AS dt_inicio_vigencia,
    date '9999-12-31' AS dt_fim_vigencia,
    true AS fl_ativo,
    false AS fl_excluido_logico,
    current_timestamp AS dt_ingestao_modelo,
    'exec_202604_scd2_insere' AS id_execucao,
    202604 AS anomes
FROM novos_ou_alterados;
```

