## 10. Rodando Athena com boto3

```python
import boto3
import time

athena = boto3.client("athena", region_name="sa-east-1")

def start_query(sql, database="workspace_db", workgroup="cobranca"):
    resp = athena.start_query_execution(
        QueryString=sql,
        QueryExecutionContext={"Database": database},
        WorkGroup=workgroup
    )
    return resp["QueryExecutionId"]

def wait_query(query_execution_id):
    while True:
        resp = athena.get_query_execution(QueryExecutionId=query_execution_id)
        state = resp["QueryExecution"]["Status"]["State"]

        if state in ["SUCCEEDED", "FAILED", "CANCELLED"]:
            return resp

        time.sleep(2)
```

Uso:

```python
qid = start_query("SELECT count(*) AS qtd FROM workspace_db.minha_tabela")
status = wait_query(qid)

status["QueryExecution"]["Status"]["State"]
```

