# 1. Silver integrada: normalizar a base

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_pool_diario AS
WITH base AS (
    SELECT
        contrato,
        produto,
        cliente_id,

        cast(saldo as decimal(18,2)) AS saldo,

        cast(dias_atraso_contrato as integer) AS dias_atraso_contrato,
        cast(dias_atraso_cliente as integer) AS dias_atraso_cliente,

        lower(trim(flag_incluso_dia)) AS flag_incluso_dia,

        cast(anomesdia as integer) AS anomesdia,
        cast(substr(cast(anomesdia as varchar), 1, 6) as integer) AS anomes,

        cast(date_parse(cast(anomesdia as varchar), '%Y%m%d') as date) AS dt_ref_date

    FROM workspace_db.sua_tabela_base
    WHERE cast(anomesdia as integer) >= 20260101
),

classificada AS (
    SELECT
        *,

        CASE
            WHEN flag_incluso_dia = 'exclusao' THEN 0
            ELSE 1
        END AS fl_ativo_no_dia,

        CASE
            WHEN flag_incluso_dia = 'inclusao' THEN 1
            ELSE 0
        END AS fl_inclusao_dia,

        CASE
            WHEN flag_incluso_dia = 'exclusao' THEN 1
            ELSE 0
        END AS fl_exclusao_dia,

        CASE
            WHEN flag_incluso_dia = 'nunca distribuido' THEN 1
            WHEN flag_incluso_dia = 'nunca_distribuido' THEN 1
            ELSE 0
        END AS fl_nunca_distribuido,

        CASE
            WHEN dias_atraso_contrato BETWEEN 0 AND 30 THEN '000_030'
            WHEN dias_atraso_contrato BETWEEN 31 AND 60 THEN '031_060'
            WHEN dias_atraso_contrato BETWEEN 61 AND 90 THEN '061_090'
            WHEN dias_atraso_contrato BETWEEN 91 AND 180 THEN '091_180'
            WHEN dias_atraso_contrato BETWEEN 181 AND 360 THEN '181_360'
            WHEN dias_atraso_contrato > 360 THEN '361_plus'
            ELSE 'sem_faixa'
        END AS faixa_atraso_contrato,

        CASE
            WHEN dias_atraso_cliente BETWEEN 0 AND 30 THEN '000_030'
            WHEN dias_atraso_cliente BETWEEN 31 AND 60 THEN '031_060'
            WHEN dias_atraso_cliente BETWEEN 61 AND 90 THEN '061_090'
            WHEN dias_atraso_cliente BETWEEN 91 AND 180 THEN '091_180'
            WHEN dias_atraso_cliente BETWEEN 181 AND 360 THEN '181_360'
            WHEN dias_atraso_cliente > 360 THEN '361_plus'
            ELSE 'sem_faixa'
        END AS faixa_atraso_cliente,

        concat(
            cast(contrato as varchar),
            '|',
            cast(produto as varchar)
        ) AS chave_contrato_produto

    FROM base
)

SELECT *
FROM classificada;
```

