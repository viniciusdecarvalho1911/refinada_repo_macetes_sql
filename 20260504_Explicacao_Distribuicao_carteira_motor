# 2. Fato de eventos: detectar mudança dia a dia

```sql
CREATE TABLE IF NOT EXISTS workspace_db.iceberg_gold_fato_cobranca_evento_pool
WITH (
    table_type = 'ICEBERG',
    format = 'PARQUET',
    partitioning = ARRAY['anomes']
) AS
WITH base AS (
    SELECT
        *,
        lag(anomesdia) OVER (
            PARTITION BY contrato, produto
            ORDER BY anomesdia
        ) AS anomesdia_anterior,

        lag(saldo) OVER (
            PARTITION BY contrato, produto
            ORDER BY anomesdia
        ) AS saldo_anterior,

        lag(faixa_atraso_contrato) OVER (
            PARTITION BY contrato, produto
            ORDER BY anomesdia
        ) AS faixa_atraso_contrato_anterior,

        lag(faixa_atraso_cliente) OVER (
            PARTITION BY contrato, produto
            ORDER BY anomesdia
        ) AS faixa_atraso_cliente_anterior,

        lag(fl_ativo_no_dia) OVER (
            PARTITION BY contrato, produto
            ORDER BY anomesdia
        ) AS fl_ativo_anterior

    FROM workspace_db.view_silver_integrado_cobranca_pool_diario
)

SELECT
    contrato,
    produto,
    cliente_id,
    chave_contrato_produto,

    anomesdia,
    anomes,
    dt_ref_date,

    saldo_anterior,
    saldo AS saldo_atual,

    dias_atraso_contrato,
    dias_atraso_cliente,

    faixa_atraso_contrato_anterior,
    faixa_atraso_contrato AS faixa_atraso_contrato_atual,

    faixa_atraso_cliente_anterior,
    faixa_atraso_cliente AS faixa_atraso_cliente_atual,

    flag_incluso_dia,
    fl_ativo_no_dia,
    fl_inclusao_dia,
    fl_exclusao_dia,
    fl_nunca_distribuido,

    CASE
        WHEN anomesdia_anterior IS NULL THEN 'primeira_observacao'
        WHEN flag_incluso_dia = 'inclusao' THEN 'inclusao'
        WHEN flag_incluso_dia = 'exclusao' THEN 'exclusao'
        WHEN flag_incluso_dia IN ('nunca distribuido', 'nunca_distribuido') THEN 'nunca_distribuido'
        WHEN faixa_atraso_contrato_anterior <> faixa_atraso_contrato THEN 'mudanca_faixa_contrato'
        WHEN faixa_atraso_cliente_anterior <> faixa_atraso_cliente THEN 'mudanca_faixa_cliente'
        WHEN saldo_anterior <> saldo THEN 'mudanca_saldo'
        ELSE 'permanencia'
    END AS tipo_evento,

    saldo - coalesce(saldo_anterior, 0) AS delta_saldo

FROM base;
```

