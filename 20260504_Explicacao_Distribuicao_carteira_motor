# 5. Mart de variação mês contra mês

```sql
CREATE OR REPLACE VIEW workspace_db.view_gold_mart_cobranca_variacao_pool_mensal AS
WITH mensal AS (
    SELECT
        *
    FROM workspace_db.view_gold_mart_cobranca_pool_mensal
),

comparado AS (
    SELECT
        *,

        lag(saldo_medio_disponivel_mes) OVER (
            PARTITION BY faixa_atraso_contrato, faixa_atraso_cliente
            ORDER BY anomes
        ) AS saldo_medio_disponivel_mes_ant,

        lag(qtd_contrato_produto) OVER (
            PARTITION BY faixa_atraso_contrato, faixa_atraso_cliente
            ORDER BY anomes
        ) AS qtd_contrato_produto_ant,

        lag(media_dias_ativo_por_contrato) OVER (
            PARTITION BY faixa_atraso_contrato, faixa_atraso_cliente
            ORDER BY anomes
        ) AS media_dias_ativo_ant

    FROM mensal
)

SELECT
    *,

    saldo_medio_disponivel_mes - saldo_medio_disponivel_mes_ant AS delta_saldo_medio_disponivel,

    qtd_contrato_produto - qtd_contrato_produto_ant AS delta_qtd_contrato_produto,

    media_dias_ativo_por_contrato - media_dias_ativo_ant AS delta_media_dias_ativo

FROM comparado;
```

