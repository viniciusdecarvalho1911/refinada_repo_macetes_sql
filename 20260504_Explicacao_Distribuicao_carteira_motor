# 3. Mart diária do pool

```sql
CREATE OR REPLACE VIEW workspace_db.view_gold_mart_cobranca_pool_diario AS
SELECT
    anomesdia,
    anomes,
    dt_ref_date,
    faixa_atraso_contrato,
    faixa_atraso_cliente,

    count(DISTINCT chave_contrato_produto) AS qtd_contrato_produto,
    count(DISTINCT contrato) AS qtd_contratos,
    count(DISTINCT cliente_id) AS qtd_clientes,

    sum(saldo) AS saldo_total,

    sum(CASE WHEN fl_ativo_no_dia = 1 THEN saldo ELSE 0 END) AS saldo_ativo,
    sum(CASE WHEN fl_inclusao_dia = 1 THEN saldo ELSE 0 END) AS saldo_inclusao,
    sum(CASE WHEN fl_exclusao_dia = 1 THEN saldo ELSE 0 END) AS saldo_exclusao,
    sum(CASE WHEN fl_nunca_distribuido = 1 THEN saldo ELSE 0 END) AS saldo_nunca_distribuido,

    count(DISTINCT CASE WHEN fl_ativo_no_dia = 1 THEN chave_contrato_produto END) AS qtd_ativo,
    count(DISTINCT CASE WHEN fl_inclusao_dia = 1 THEN chave_contrato_produto END) AS qtd_inclusao,
    count(DISTINCT CASE WHEN fl_exclusao_dia = 1 THEN chave_contrato_produto END) AS qtd_exclusao,
    count(DISTINCT CASE WHEN fl_nunca_distribuido = 1 THEN chave_contrato_produto END) AS qtd_nunca_distribuido

FROM workspace_db.view_silver_integrado_cobranca_pool_diario
GROUP BY 1,2,3,4,5;
```

