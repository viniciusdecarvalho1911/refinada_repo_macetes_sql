# 4. Mart mensal: saldo médio disponível e dias médios

Essa responde bem sua pergunta de “quantos dias em média o saldo ficou disponível”.

```sql
CREATE OR REPLACE VIEW workspace_db.view_gold_mart_cobranca_pool_mensal AS
WITH contrato_mes AS (
    SELECT
        anomes,
        contrato,
        produto,
        cliente_id,
        faixa_atraso_contrato,
        faixa_atraso_cliente,

        count(DISTINCT anomesdia) AS qtd_dias_observado,

        count(DISTINCT CASE
            WHEN fl_ativo_no_dia = 1 THEN anomesdia
        END) AS qtd_dias_ativo,

        avg(CASE
            WHEN fl_ativo_no_dia = 1 THEN saldo
        END) AS saldo_medio_ativo,

        max(saldo) AS saldo_maximo_mes,
        min(saldo) AS saldo_minimo_mes,

        max(fl_inclusao_dia) AS fl_teve_inclusao_mes,
        max(fl_exclusao_dia) AS fl_teve_exclusao_mes,
        max(fl_nunca_distribuido) AS fl_nunca_distribuido_mes

    FROM workspace_db.view_silver_integrado_cobranca_pool_diario
    GROUP BY 1,2,3,4,5,6
)

SELECT
    anomes,
    faixa_atraso_contrato,
    faixa_atraso_cliente,

    count(DISTINCT concat(cast(contrato as varchar), '|', cast(produto as varchar))) AS qtd_contrato_produto,
    count(DISTINCT contrato) AS qtd_contratos,
    count(DISTINCT cliente_id) AS qtd_clientes,

    sum(saldo_medio_ativo) AS saldo_medio_disponivel_mes,

    avg(qtd_dias_ativo) AS media_dias_ativo_por_contrato,
    approx_percentile(qtd_dias_ativo, 0.5) AS mediana_dias_ativo_por_contrato,

    sum(CASE WHEN fl_teve_inclusao_mes = 1 THEN saldo_medio_ativo ELSE 0 END) AS saldo_incluido_mes,
    sum(CASE WHEN fl_teve_exclusao_mes = 1 THEN saldo_medio_ativo ELSE 0 END) AS saldo_excluido_mes,
    sum(CASE WHEN fl_nunca_distribuido_mes = 1 THEN saldo_medio_ativo ELSE 0 END) AS saldo_nunca_distribuido_mes,

    count(DISTINCT CASE
        WHEN fl_teve_inclusao_mes = 1
        THEN concat(cast(contrato as varchar), '|', cast(produto as varchar))
    END) AS qtd_incluidos_mes,

    count(DISTINCT CASE
        WHEN fl_teve_exclusao_mes = 1
        THEN concat(cast(contrato as varchar), '|', cast(produto as varchar))
    END) AS qtd_excluidos_mes,

    count(DISTINCT CASE
        WHEN fl_nunca_distribuido_mes = 1
        THEN concat(cast(contrato as varchar), '|', cast(produto as varchar))
    END) AS qtd_nunca_distribuidos_mes

FROM contrato_mes
GROUP BY 1,2,3;
```

