# 🧪 Pseudológica SQL do motor

```sql
WITH base_atual AS (...),
curva AS (...),
historico AS (...),

parametros AS (
    SELECT
        CASE
            WHEN dia_util_mes <= 5 THEN 0.85
            WHEN dia_util_mes <= 8 THEN 0.75
            WHEN dia_util_mes <= 10 THEN 0.65
            WHEN dia_util_mes <= 13 THEN 0.50
            WHEN dia_util_mes <= 16 THEN 0.35
            ELSE 0.20
        END AS peso_hist
),

calc AS (
    SELECT
        ...,
        1 - peso_hist AS peso_atual,

        emitidos_acum / NULLIF(pct_emitidos_acum_exp, 0) AS proj_emitidos_realizado,

        (peso_hist * emitidos_final_hist)
        + ((1 - peso_hist) * (emitidos_acum / NULLIF(pct_emitidos_acum_exp, 0)))
            AS proj_emitidos_blend,

        (pagos_acum + (1500 * conv_final_hist))
        / NULLIF(emitidos_acum + 1500, 0)
            AS conv_suavizada
    FROM ...
),

final AS (
    SELECT
        ...,
        least(emitidos_final_hist * 1.20,
              greatest(emitidos_final_hist * 0.80, proj_emitidos_blend)
        ) AS proj_emitidos_final,

        least(conv_final_hist * 1.12,
              greatest(conv_final_hist * 0.90,
                       (0.80 * conv_final_hist) + (0.20 * conv_suavizada))
        ) AS conv_final_proj
    FROM calc
)

SELECT
    ...,
    proj_emitidos_final * conv_final_proj * ticket_final_proj AS regul_final_proj,
    (proj_emitidos_final * conv_final_proj * ticket_final_proj) / NULLIF(carteira_mes, 0) AS eficiencia_final_proj
FROM final;
```

