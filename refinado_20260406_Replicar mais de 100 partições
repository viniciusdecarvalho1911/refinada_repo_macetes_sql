SRC_DATABASE = "workspace_db"
SRC_TABLE = "minha_tabela_origem"

DST_DATABASE = "workspace_db"
DST_TABLE = "tabela_bronze_fonte_cobranca_minha_entidade"

DST_S3_PATH = "s3://meu-bucket/bronze/cobranca/minha_entidade/"

PARTITION_KEYS = ["anomes", "dt_ref"]

# =========================================================
# 3) LEITURA DA ORIGEM
# =========================================================
dyf_src = glueContext.create_dynamic_frame.from_catalog(
    database=SRC_DATABASE,
    table_name=SRC_TABLE
)

df_src = dyf_src.toDF()

# =========================================================
# 4) ESCRITA FÍSICA NO S3
