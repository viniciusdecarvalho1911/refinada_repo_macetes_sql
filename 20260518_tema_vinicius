  font-size: 11px !important;
  line-height: 1 !important;
  margin: 0 0 1px 0 !important;
}

.box-mini strong {
  font-size: 11px !important;
  line-height: 1 !important;
}


/* =========================================================
   8) Sucesso
   Use para risco crítico, erro grave ou decisão perigosa
   ========================================================= */

.success {
  border: 2px solid var(--cor-ok);
  border-radius: 14px;
  padding: 18px 22px;
  margin-top: 18px;
  background: #0ff71b;
}
