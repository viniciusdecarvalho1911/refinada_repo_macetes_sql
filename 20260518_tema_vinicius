   #########################################################

   Use para:
   - tabelas pequenas
   - comparações
   - rankings
   - resumo executivo

######################################################### */

.tabela_posicionada_exemplo {
  position: absolute;

  top: 160px;
  right: 60px;

  width: 700px;

  background: white;

  padding: 20px;

  border-radius: 18px;

  box-shadow:
    0 10px 25px rgba(0,0,0,0.08);
