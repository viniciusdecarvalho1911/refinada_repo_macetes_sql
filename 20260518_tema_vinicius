   - imagens decorativas
   - screenshots pequenas
   - selos
   - watermark

   Controle:
   top
   left
   right
   bottom
   width
   height

######################################################### */

.imagem_posicionada_exemplo {
  position: absolute;

  top: 120px;
  right: 80px;

  width: 320px;

  border-radius: 18px;

  box-shadow:
    0 10px 25px rgba(0,0,0,0.15);
}

