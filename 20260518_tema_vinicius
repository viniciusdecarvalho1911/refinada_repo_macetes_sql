/* @theme tema_vinicius */

@import 'default';
/* =========================================================
   1) VARIÁVEIS GLOBAIS
   Altere aqui para mudar o visual do deck inteiro
   ========================================================= */

:root {
  --cor-primaria: #D4AF37;
  --cor-secundaria: #4CAF50;
  --cor-texto: #222222;
  --cor-fundo: #FFFFFF;
  --cor-card: #F4F4F4;
  --cor-borda: #CCCCCC;

  --cor-danger: #ef4444;
  --cor-warning: #f59e0b;
  --cor-muted: #64748b;
  --cor-ok: #166534;

  --fonte-titulo-slide: 46px;
  --fonte-subtitulo: 28px;
  --fonte-card-titulo: 30px;
  --fonte-card-valor: 42px;
  --fonte-texto: 19px;

  --padding-card: 25px;
  --gap-cards: 20px;
  --radius-card: 12px;
}

/* =========================================================
   2) CONFIGURAÇÃO GERAL DOS SLIDES
   Mude aqui fundo, fonte, padding e cor padrão
   ========================================================= */

section {
  background: var(--cor-fundo);
  color: var(--cor-texto);
  font-size: var(--fonte-texto);
  font-family: Arial, Helvetica, sans-serif;
  padding: 56px 72px;
}

section.sql-card pre {
  background: white !important;
  border: 1px solid #e2e8f0;
  border-radius: 18px;
  padding: 24px !important;
  box-shadow: 0 10px 25px rgba(0,0,0,0.06);
}

section.sql-card pre code {
  color: #0f172a !important;
  font-size: 18px;
  line-height: 1.5;
}

section.dark .code-light pre {
  background: white !important;

  border-radius: 18px;

  border: 1px solid #334155;

  box-shadow:
    0 10px 25px rgba(0,0,0,0.18);
}

section.dark .code-light pre code {
  color: #0f172a !important;
}

/* =========================================================
   3) TÍTULOS PADRÃO
   Afeta #, ## e ### do Markdown
   ========================================================= */

h1 {
  font-size: var(--fonte-titulo-slide);
  color: #0f172a;
  margin-bottom: 18px;
}

h2 {
  font-size: var(--fonte-subtitulo);
  color: #334155;
}

h3 {
  font-size: 22px;
  color: #475569;
}

p, li {
  font-size: var(--fonte-texto);
  line-height: 1.35;
}

/* =========================================================
   4) TABELAS
   Use quando quiser tabela formatada
   ========================================================= */

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 18px;
}

th {
  background: #e2e8f0;
  color: #0f172a;
  font-weight: 700;
}

th, td {
  border: 1px solid #cbd5e1;
  padding: 10px 12px;
  vertical-align: top;
}

/* =========================================================
   5) CLASSES UTILITÁRIAS
   Pequenas classes reutilizáveis para texto
   ========================================================= */

.center {
  text-align: center;
}

.muted {
  color: var(--cor-muted);
}

.small {
  font-size: 18px;
}

.ok {
  color: var(--cor-ok);
  font-weight: 700;
}

.risk {
  color: #b91c1c;
  font-weight: 700;
}

/* =========================================================
   6) BOX PADRÃO
   Use para destacar uma ideia neutra
   ========================================================= */

.box {
  border: 2px solid #cbd5e1;
  border-radius: 14px;
  padding: 18px 22px;
  margin-top: 18px;
  background: #f8fafc;
}

/* =========================================================
   7) WARNING
   Use para alertas moderados
   ========================================================= */

.warning {
  border: 2px solid var(--cor-warning);
  border-radius: 14px;
  padding: 18px 22px;
  margin-top: 18px;
  background: #fffbeb;
}

/* =========================================================
   8) DANGER
   Use para risco crítico, erro grave ou decisão perigosa
   ========================================================= */

.danger {
  border: 2px solid var(--cor-danger);
  border-radius: 14px;
  padding: 18px 22px;
  margin-top: 18px;
  background: #fef2f2;
}

/* =========================================================
   9) FLOW
   Use para mostrar sequência de processo
   ========================================================= */

.flow {
  font-size: 26px;
  line-height: 1.55;
  text-align: center;
  font-weight: 700;
}

/* =========================================================
   10) TWO COLUMNS COM GRID
   Melhor para layout fixo em duas colunas
   ========================================================= */

.two-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  align-items: start;
}

/* =========================================================
   11) FLEX ROW
   Melhor para cards lado a lado
   ========================================================= */

.flex-row {
  display: flex;
  gap: var(--gap-cards);
  align-items: stretch;
}

/* =========================================================
   12) CARD DE MÉTRICA
   Use dentro de flex-row
   ========================================================= */

.metric-card {
  border: 1px solid var(--cor-borda);
  padding: var(--padding-card);
  border-radius: var(--radius-card);
  flex: 1;
  background: white;
}

.metric-title {
  font-size: var(--fonte-card-titulo);
  font-weight: bold;
  margin-bottom: 20px;
   text-align: center;
}

.metric-value {
  font-size: var(--fonte-card-valor);
  text-align: center;
  font-weight: bold;
  text-align: center;
}

/* =========================================================
   13) CLASSES ESPECÍFICAS DE MÉTRICAS
   Mude aqui se quiser alterar só Caixa ou só Eficiência
   ========================================================= */

.caixa-title {
  color: #D4AF37 !important;
  font-size: 30px !important;
  text-align: center !important;
}

.caixa-value {
  color: #222222 !important;
  font-size: 40px !important;
  text-align: center !important;
}

.eficiencia-title {
  color: #4CAF50 !important;
  font-size: 30px !important;
  text-align: center !important;
}

.eficiencia-value {
  color: #222222 !important;
  font-size: 40px !important;
  text-align: center !important;
}

/* =========================================================
   14) SECTION CLASSES
   Use <!-- _class: nome_da_classe --> no slide
   ========================================================= */

section.lead h1 {
  font-size: 54px;
}

section.lead p {
  font-size: 28px;
}

section.dark {
  background: #0f172a;
  color: white;
}

section.dark h1,
section.dark h2,
section.dark h3 {
  color: white;
}

section.executivo {
  background: #f8fafc;
}

section.tecnico {
  background: #ffffff;
}

/* =========================================================
   15) POSICIONAMENTO LIVRE
   Use para logo, fonte, legenda ou selo
   ========================================================= */

.fonte-rodape {
  position: absolute;
  bottom: 25px;
  right: 40px;
  font-size: 16px;
  color: #777777;
}

.logo-canto {
  position: absolute;
  top: 25px;
  right: 40px;
  font-size: 18px;
  font-weight: bold;
  color: #999999;
}

/* =========================================================
   16) DIVISORES HORIZONTAIS
   Use para separar blocos visualmente
   ========================================================= */

.divider {
  height: 2px;
  background: #e2e8f0;
  margin: 28px 0;
  border-radius: 999px;
}

/* =========================================================
   17) HERO / CAPA PRINCIPAL
   Use para slides de abertura
   ========================================================= */

.hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 70%;
}

.hero-title {
  font-size: 64px;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.1;
  margin-bottom: 20px;
}

.hero-subtitle {
  font-size: 28px;
  color: #475569;
  max-width: 900px;
  line-height: 1.4;
}

/* =========================================================
   18) BADGES / TAGS
   Use para status, labels e categorias
   ========================================================= */

.badge {
  display: inline-block;
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 16px;
  font-weight: 700;
  margin-right: 8px;
  margin-bottom: 8px;
}

.badge-ok {
  background: #dcfce7;
  color: #166534;
}

.badge-warning {
  background: #fef3c7;
  color: #92400e;
}

.badge-danger {
  background: #fee2e2;
  color: #991b1b;
}

.badge-info {
  background: #dbeafe;
  color: #1d4ed8;
}

/* =========================================================
   19) KPI GRID
   Grid automática para vários KPIs
   ========================================================= */

.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.kpi-card {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  padding: 24px;
}

.kpi-label {
  font-size: 18px;
  color: #64748b;
  margin-bottom: 14px;
}

.kpi-number {
  font-size: 42px;
  font-weight: 800;
  color: #0f172a;
}

.kpi-delta {
  margin-top: 10px;
  font-size: 18px;
  font-weight: 700;
}

/* =========================================================
   20) CÓDIGO / SQL
   Melhor visual para blocos técnicos
   ========================================================= */

pre {
  background: #0f172a !important;
  border-radius: 16px;
  padding: 22px !important;
  overflow: hidden;
}

code {
  font-size: 18px;
  line-height: 1.45;
}

/* =========================================================
   21) QUOTE EXECUTIVO
   Use para tese principal ou insight forte
   ========================================================= */

.quote {
  border-left: 10px solid var(--cor-primaria);
  padding: 18px 28px;
  background: #fffaf0;
  border-radius: 12px;
  font-size: 32px;
  font-weight: 700;
  line-height: 1.4;
  color: #0f172a;
}

/* =========================================================
   22) TIMELINE VERTICAL
   Use para evolução temporal ou roadmap
   ========================================================= */

.timeline {
  border-left: 4px solid #cbd5e1;
  margin-left: 14px;
  padding-left: 28px;
}

.timeline-item {
  margin-bottom: 30px;
  position: relative;
}

.timeline-item::before {
  content: "";
  width: 18px;
  height: 18px;
  background: var(--cor-primaria);
  border-radius: 999px;
  position: absolute;
  left: -39px;
  top: 8px;
}

.timeline-title {
  font-size: 24px;
  font-weight: 700;
  color: #0f172a;
}

.timeline-text {
  font-size: 20px;
  color: #475569;
  margin-top: 8px;
}

/* =========================================================
   23) SIDE PANEL
   Painel lateral fixo para destaque
   ========================================================= */

.side-panel {
  background: #f8fafc;
  border-left: 8px solid var(--cor-primaria);
  padding: 24px;
  border-radius: 14px;
}

/* =========================================================
   24) IMAGEM RESPONSIVA
   Use para screenshots, dashboards e diagramas
   ========================================================= */

.image-card {
  border: 1px solid #cbd5e1;
  border-radius: 18px;
  padding: 18px;
  background: white;
}

.image-fit {
  width: 100%;
  height: auto;
  border-radius: 12px;
}

.image-cover {
  width: 100%;
  height: 420px;
  object-fit: cover;
  border-radius: 12px;
}

.image-cover-small {
  width: 100%;
  height: 300px;          /* diminua aqui */
  object-fit: cover;
  border-radius: 12px;
}

.image-cover-fit-slide {
  width: 100%;
  max-height: 45vh;       /* ocupa no máximo 45% da altura do slide */
  object-fit: cover;
  border-radius: 12px;
}

.image-slide-stack {
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 18px;
  height: 100%;
}

.image-slide-stack .image-card {
  overflow: hidden;
}

.image-slide-stack img {
  width: 100%;
  max-height: 42vh;
  object-fit: cover;
  border-radius: 12px;
}

/* =========================================================
   25) OVERLAY ESCURO PARA IMAGEM
   Use em slides com background image
   ========================================================= */

.overlay-dark {
  background: rgba(15, 23, 42, 0.72);
  padding: 30px;
  border-radius: 20px;
  color: white;
}

/* =========================================================
   26) GRID 3 COLUNAS
   Use para comparações múltiplas
   ========================================================= */

.three-cols {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
}

/* =========================================================
   27) PILLS DE MÉTRICA
   Pequenas métricas inline
   ========================================================= */

.metric-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;

  padding: 12px 18px;

  border-radius: 999px;

  background: #f1f5f9;

  font-size: 18px;
  font-weight: 700;
}

/* =========================================================
   28) CENTRALIZAÇÃO ABSOLUTA
   Use para slides minimalistas
   ========================================================= */

.absolute-center {
  position: absolute;

  top: 50%;
  left: 50%;

  transform: translate(-50%, -50%);

  text-align: center;
}

/* =========================================================
   29) MINI CARDS
   Cards compactos para grids densos
   ========================================================= */

.mini-card {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 16px;
}

.mini-card-title {
  font-size: 16px;
  color: #64748b;
  margin-bottom: 10px;
}

.mini-card-value {
  font-size: 28px;
  font-weight: 800;
}

/* =========================================================
   30) TABLE STRIPES
   Zebra em tabelas
   ========================================================= */

table tr:nth-child(even) {
  background: #f8fafc;
}

/* =========================================================
   31) CALLOUT INFO
   Use para observações importantes
   ========================================================= */

.info {
  border-left: 8px solid #3b82f6;
  background: #eff6ff;
  padding: 18px 22px;
  border-radius: 12px;
}

/* =========================================================
   32) STACK VERTICAL
   Melhor para empilhar blocos com espaçamento
   ========================================================= */

.stack {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* =========================================================
   33) SPACE BETWEEN
   Empurra elementos para extremos do slide
   ========================================================= */

.space-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* =========================================================
   34) WIDTH HELPERS
   Controle rápido de largura
   ========================================================= */

.w-25 { width: 25%; }
.w-50 { width: 50%; }
.w-75 { width: 75%; }
.w-100 { width: 100%; }

/* =========================================================
   35) HEIGHT HELPERS
   Controle rápido de altura
   ========================================================= */

.h-100 {
  height: 100%;
}

/* =========================================================
   36) GLASS EFFECT
   Use para slides modernos sobre imagem
   ========================================================= */

.glass {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(12px);

  border: 1px solid rgba(255,255,255,0.2);

  border-radius: 20px;

  padding: 24px;
}

/* =========================================================
   37) SOMBRA SUAVE
   Adicione class="shadow"
   ========================================================= */

.shadow {
  box-shadow:
    0 10px 25px rgba(0,0,0,0.08);
}

/* =========================================================
   38) BORDER TOP HIGHLIGHT
   Destaque elegante em cards
   ========================================================= */

.border-top-gold {
  border-top: 8px solid var(--cor-primaria);
}

/* =========================================================
   39) CARD ESCURO
   Use em slides dark
   ========================================================= */

.dark-card {
  background: #1e293b;
  border-radius: 16px;
  padding: 24px;
  color: white;
}

/* =========================================================
   40) FOOTNOTE TÉCNICA
   Observações pequenas no rodapé
   ========================================================= */

.footnote {
  font-size: 14px;
  color: #94a3b8;
  margin-top: 18px;
}

/* =========================================================
   41) TEXTO SQL
   Usar para textos sql
   ========================================================= */

.sql-card pre {
  background: white !important;

  border: 1px solid #e2e8f0;

  border-radius: 18px;

  box-shadow:
    0 10px 25px rgba(0,0,0,0.06);
}

/* =========================================================
   42. MODO DENSO
   Para slides com muito conteúdo
   ========================================================= */

section.dense {
  padding: 38px 52px;
}

section.dense h1 {
  font-size: 36px;
  margin-bottom: 10px;
}

section.dense h2 {
  font-size: 22px;
  margin-bottom: 8px;
}

section.dense h3 {
  font-size: 18px;
  margin-bottom: 6px;
}

section.dense p,
section.dense li {
  font-size: 18px;
  line-height: 1.2;
}

section.dense .box,
section.dense .warning,
section.dense .danger,
section.dense .success {
  padding: 12px 16px;
  margin-top: 10px;
}

section.dense .divider {
  margin: 14px 0;
}

section.dense table {
  font-size: 15px;
}

section.dense pre code {
  font-size: 14px;
}

section.ultra-dense {
  padding: 22px 34px !important;
}

section.ultra-dense h1 {
  font-size: 28px !important;
  margin: 0 0 6px 0 !important;
}

section.ultra-dense h2 {
  font-size: 17px !important;
  margin: 0 0 4px 0 !important;
}

section.ultra-dense h3 {
  font-size: 14px !important;
  margin: 0 0 2px 0 !important;
}

section.ultra-dense p,
section.ultra-dense li {
  font-size: 14px !important;
  line-height: 1.05 !important;
}

section.ultra-dense .box {
  padding: 8px 10px !important;
  margin-top: 4px !important;
}

section.ultra-dense .two-cols {
  gap: 12px !important;
}

section.ultra-dense .divider {
  margin: 6px 0 !important;
}

.dense-slide h1 {
  font-size: 36px !important;
  margin: 0 0 10px 0 !important;
}

.dense-slide h2 {
  font-size: 24px !important;
  margin: 0 0 8px 0 !important;
}

.dense-slide h3 {
  font-size: 18px !important;
  margin: 0 0 6px 0 !important;
}

.dense-slide p,
.dense-slide li {
  font-size: 18px !important;
  line-height: 1.2 !important;
}

.dense-slide .box {
  padding: 12px 16px !important;
  margin-top: 8px !important;
}

.dense-slide .two-cols {
  gap: 18px !important;
}

.dense-slide .divider {
  margin: 12px 0 !important;
}

.ultra-dense-slide h1 {
  font-size: 28px !important;
  margin: 0 0 6px 0 !important;
}

.ultra-dense-slide h2 {
  font-size: 17px !important;
  margin: 0 0 4px 0 !important;
}

.ultra-dense-slide h3 {
  font-size: 14px !important;
  margin: 0 0 2px 0 !important;
}

.ultra-dense-slide p,
.ultra-dense-slide li {
  font-size: 14px !important;
  line-height: 1.05 !important;
}

.ultra-dense-slide .box {
  padding: 8px 10px !important;
  margin-top: 4px !important;
}

.ultra-dense-slide .two-cols {
  gap: 12px !important;
}

.ultra-dense-slide .divider {
  margin: 6px 0 !important;
}

.two-cols-ultra {
  gap: 10px !important;
}

.box-ultra {
  padding: 6px 8px !important;
  margin-top: 3px !important;
  font-size: 13px !important;
  line-height: 1.05 !important;
}

.box-ultra h3 {
  font-size: 14px !important;
  margin: 0 0 2px 0 !important;
}

.box-ultra p,
.box-ultra li {
