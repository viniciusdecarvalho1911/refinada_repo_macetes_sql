7. Versão melhor: usando atalho para executar linha atual

Em vez de criar um hotstring para cada comando, uma versão mais poderosa é:

1. digitar o comando na nota


2. selecionar a linha


3. apertar um atalho


4. AutoHotkey interpreta



Exemplo:

/sql scd2

Seleciona a linha e aperta:

Ctrl + Alt + Enter


---

8. AutoHotkey com parser simples

#Requires AutoHotkey v2.0

#HotIf WinActive("ahk_exe StikyNot.exe")

^!Enter::
{
    Send "^c"
    Sleep 100

    cmd := Trim(A_Clipboard)

    if (cmd = "") {
        return
    }

    vault := "MeuVault"

    if InStr(cmd, "/pag ") {
        termo := StrReplace(cmd, "/pag ", "")
        Run "obsidian://search?vault=" vault "&query=pag%20" UriEncode(termo)
    }
    else if InStr(cmd, "/req ") {
        termo := StrReplace(cmd, "/req ", "")
        Run "obsidian://search?vault=" vault "&query=req%20" UriEncode(termo)
    }
    else if InStr(cmd, "/sql ") {
        termo := StrReplace(cmd, "/sql ", "")
        Run "obsidian://search?vault=" vault "&query=sql%20" UriEncode(termo)
    }
    else if InStr(cmd, "/com ") {
        termo := StrReplace(cmd, "/com ", "")
        Run "obsidian://search?vault=" vault "&query=com%20" UriEncode(termo)
    }
    else {
        Run "obsidian://search?vault=" vault "&query=" UriEncode(cmd)
    }
}

UriEncode(str) {
    encoded := ""
    Loop Parse str {
        ch := A_LoopField
        if ch ~= "^[A-Za-z0-9_.~-]$"
            encoded .= ch
        else if ch = " "
            encoded .= "%20"
        else
            encoded .= "%" Format("{:02X}", Ord(ch))
    }
    return encoded
}

#HotIf


