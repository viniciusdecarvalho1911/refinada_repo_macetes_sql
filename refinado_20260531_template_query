# SQL

```sql
MERGE INTO workspace_db.iceberg_gold_fato_pagadoria tgt
USING (
    SELECT *
    FROM workspace_db.view_silver_integrado_cobranca_pagamentos_consolidados
) src
ON (
    tgt.contrato = src.contrato
    AND tgt.produto = src.produto
)
WHEN MATCHED THEN UPDATE SET
    vl_regul = src.vl_regul
WHEN NOT MATCHED THEN INSERT (
    contrato,
    produto,
    vl_regul
)
VALUES (
    src.contrato,
    src.produto,
    src.vl_regul
);
```

