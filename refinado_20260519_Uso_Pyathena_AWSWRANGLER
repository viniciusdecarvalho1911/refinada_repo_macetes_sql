    id_execucao = f"exec_{anomes}_python"

    try:
        registrar_execucao(
            id_execucao=id_execucao,
            anomes=anomes,
            status="INICIADO",
            detalhe="Pipeline iniciado"
        )

        reprocessar_mes_pagadoria(
