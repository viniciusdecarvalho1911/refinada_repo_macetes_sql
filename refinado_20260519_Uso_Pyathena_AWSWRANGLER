        WHERE mes_ref_yyyymm = {anomes}
        GROUP BY 1, 2, 3, 4
    ),

    final AS (
        SELECT
            md5(
                concat(
                    contrato,
                    '|',
                    produto,
                    '|',
                    cast(anomes as varchar),
