# 17. Passo 4 — criar a staging delta

Agora a staging usa os valores finais resolvidos.

## SQL

```sql
CREATE OR REPLACE VIEW workspace_db.view_gold_staging_cobranca_pagamentos_consolidados_delta AS
WITH ajuste AS (
    SELECT
        acao_ajuste,
        motivo_ajuste,
        pasta,
        contrato,
        produto,
        tipo_carteira_final,
        esteira_final,
        escritorio,
        vl_pagamento,
        vl_caixa,
        vl_regul,
        dt_pagamento,
        anomes_ref,
        fl_elegivel_meta_regul,
        fl_elegivel_comissao_caixa,
        observacao,
        usuario_solicitante,
        fl_tipo_carteira_nao_resolvida,
        fl_esteira_nao_resolvida,
        md5(
            concat(
                coalesce(tipo_carteira_final, ''),
                '|', coalesce(esteira_final, ''),
                '|', coalesce(escritorio, ''),
                '|', coalesce(cast(vl_pagamento as varchar), ''),
                '|', coalesce(cast(vl_caixa as varchar), ''),
                '|', coalesce(cast(vl_regul as varchar), ''),
                '|', coalesce(cast(dt_pagamento as varchar), ''),
                '|', coalesce(cast(fl_elegivel_meta_regul as varchar), ''),
                '|', coalesce(cast(fl_elegivel_comissao_caixa as varchar), '')
            )
        ) AS hash_payload
    FROM workspace_db.view_silver_integrado_cobranca_pagamentos_ajuste_enriquecido
),
atual AS (
    SELECT
        pasta,
        contrato,
        produto
    FROM workspace_db.iceberg_gold_fato_pagadoria
)
SELECT
    CASE
        WHEN a.acao_ajuste IN ('INSERT','UPDATE','DELETE') THEN a.acao_ajuste
        ELSE 'NOOP'
    END AS acao_merge,

    a.motivo_ajuste AS motivo_acao,
    a.pasta,
    a.contrato,
    a.produto,
    a.tipo_carteira_final AS tipo_carteira,
    a.esteira_final       AS esteira,
    a.escritorio,
    a.vl_pagamento,
    a.vl_caixa,
    a.vl_regul,
    a.dt_pagamento,
    a.anomes_ref,
    a.fl_elegivel_meta_regul,
    a.fl_elegivel_comissao_caixa,
    a.observacao,
    a.usuario_solicitante,
    a.hash_payload,
    current_timestamp AS dt_processamento,
    'exec_manual_csv_001' AS id_execucao,

    CASE
        WHEN a.fl_tipo_carteira_nao_resolvida THEN 'ERRO_TIPO_CARTEIRA_NAO_DEFINIDA'
        WHEN a.fl_esteira_nao_resolvida THEN 'ERRO_ESTEIRA_NAO_DEFINIDA'
        WHEN a.acao_ajuste = 'INSERT' AND t.pasta IS NOT NULL THEN 'ERRO_INSERT_JA_EXISTE'
        WHEN a.acao_ajuste IN ('UPDATE','DELETE') AND t.pasta IS NULL THEN 'ERRO_ALVO_NAO_EXISTE'
        ELSE 'OK'
    END AS status_validacao
FROM ajuste a
LEFT JOIN atual t
  ON  a.pasta    = t.pasta
  AND a.contrato = t.contrato
  AND a.produto  = t.produto;
```

---

# 18. Passo 5 — criar a staging pronta para uso

Essa view filtra só o que pode ser aplicado.

## SQL

```sql
CREATE OR REPLACE VIEW workspace_db.view_gold_staging_cobranca_pagamentos_consolidados_delta_pronto AS
SELECT *
FROM workspace_db.view_gold_staging_cobranca_pagamentos_consolidados_delta
WHERE status_validacao = 'OK'
  AND acao_merge <> 'NOOP';
```

