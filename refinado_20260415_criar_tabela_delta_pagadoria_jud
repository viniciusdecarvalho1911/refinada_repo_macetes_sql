# 14. Passo 2 — criar a view silver padronizada

Essa camada limpa e tipa o CSV.

Além disso, ela marca se `tipo_carteira` ou `esteira` vieram ausentes.

## SQL

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_cobranca_pagamentos_ajuste_manual AS
SELECT
    upper(trim(acao_ajuste)) AS acao_ajuste,
    trim(motivo_ajuste)      AS motivo_ajuste,

    trim(pasta)              AS pasta,
    trim(contrato)           AS contrato,
    trim(produto)            AS produto,

    nullif(trim(tipo_carteira), '') AS tipo_carteira_informada,
    nullif(trim(esteira), '')       AS esteira_informada,
    trim(escritorio)                AS escritorio,

    try_cast(replace(vl_pagamento, ',', '.') as decimal(18,2)) AS vl_pagamento,
    try_cast(replace(vl_caixa, ',', '.') as decimal(18,2))     AS vl_caixa,
    try_cast(replace(vl_regul, ',', '.') as decimal(18,2))     AS vl_regul,

    cast(dt_pagamento as date) AS dt_pagamento,
    cast(date_format(cast(dt_pagamento as date), '%Y%m') as integer) AS anomes_ref,

    case
        when trim(fl_elegivel_meta_regul) in ('1','true','TRUE','S','SIM') then true
        else false
    end AS fl_elegivel_meta_regul,

    case
        when trim(fl_elegivel_comissao_caixa) in ('1','true','TRUE','S','SIM') then true
        else false
    end AS fl_elegivel_comissao_caixa,

    case
        when nullif(trim(tipo_carteira), '') is null then true
        else false
    end AS fl_tipo_carteira_pendente,

    case
        when nullif(trim(esteira), '') is null then true
        else false
    end AS fl_esteira_pendente,

    trim(observacao)          AS observacao,
    trim(usuario_solicitante) AS usuario_solicitante,

    current_timestamp         AS dt_ingestao_modelo
FROM workspace_db.tabela_bronze_fonte_manual_cobranca_pagamentos_ajuste
WHERE pasta IS NOT NULL
  AND contrato IS NOT NULL
  AND produto IS NOT NULL;
```

---

# 15. Passo 3 — criar a view silver integrada enriquecida

Aqui o processo tenta descobrir `tipo_carteira` e `esteira`.

## 15.1 Ideia da query

Ela precisa ter 4 blocos:

### Bloco A — manual

O que veio no CSV

### Bloco B — VIJUD do mês

Busca por `contrato + produto` na partição do mês informado

### Bloco C — OPC

Busca por `cod_idef_pessoa`, encontra o maior atraso e o risco

### Bloco D — coalesce final

Escolhe manual → vijud → opc

---

## 15.2 Janela de partição da OPC

A OPC precisa ser consultada da seguinte forma:

* pegar o `anomes_ref` preenchido na linha manual
* calcular:

  * `primeiro_anomesdia_do_mes`
  * `ultimo_anomesdia_disponivel_do_mes`

Depois consultar **todas as partições** entre esses dois limites.

---

## 15.3 SQL conceitual

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_pagamentos_ajuste_enriquecido AS
WITH manual AS (
    SELECT *
    FROM workspace_db.view_silver_padronizado_cobranca_pagamentos_ajuste_manual
),

vijud_mes AS (
    SELECT
        contrato,
        produto,
        p_anomes,
        tipo_carteira AS tipo_carteira_vijud,
        esteira       AS esteira_vijud
    FROM workspace_db.view_silver_padronizado_juridico_vijud_inicio_mes
),

contrato_pessoa AS (
    SELECT
        contrato,
        produto,
        cod_idef_pessoa
    FROM workspace_db.alguma_base_contrato_produto_pessoa
),

opc_base AS (
    SELECT
        o.p_anomesdia,
        o.cod_idef_pessoa,
        o.ind_atr_ctr,
        o.risco_ser
    FROM workspace_db.tabela_bronze_fonte_opc o
),

opc_resumo AS (
    SELECT
        m.contrato,
        m.produto,
        cp.cod_idef_pessoa,
        max(o.ind_atr_ctr) AS max_ind_atr_ctr,
        max_by(o.risco_ser, o.p_anomesdia) AS risco_ser_ref
    FROM manual m
    LEFT JOIN contrato_pessoa cp
      ON  m.contrato = cp.contrato
      AND m.produto  = cp.produto
    LEFT JOIN opc_base o
      ON  cp.cod_idef_pessoa = o.cod_idef_pessoa
      AND o.p_anomesdia BETWEEN cast(cast(m.anomes_ref as varchar) || '01' as bigint)
                            AND cast(date_format(last_day_of_month(cast(cast(m.anomes_ref as varchar) || '01' as date)), '%Y%m%d') as bigint)
    GROUP BY 1,2,3
),

enriquecido AS (
    SELECT
        m.acao_ajuste,
        m.motivo_ajuste,
        m.pasta,
        m.contrato,
        m.produto,

        coalesce(
            m.tipo_carteira_informada,
            v.tipo_carteira_vijud,
            case
                when o.max_ind_atr_ctr between 0 and 30 then 'CARTEIRA_RECENTE'
                when o.max_ind_atr_ctr between 31 and 90 then 'CARTEIRA_INTERMEDIARIA'
                when o.max_ind_atr_ctr > 90 then 'CARTEIRA_AVANCADA'
                else null
            end
        ) AS tipo_carteira_final,

        coalesce(
            m.esteira_informada,
            v.esteira_vijud,
            case
                when o.risco_ser_ref in ('AA','A') then 'ESTEIRA_BAIXO_RISCO'
                when o.risco_ser_ref in ('B','C') then 'ESTEIRA_MEDIO_RISCO'
                when o.risco_ser_ref in ('D','E','F') then 'ESTEIRA_ALTO_RISCO'
                else null
            end
        ) AS esteira_final,

        m.escritorio,
        m.vl_pagamento,
        m.vl_caixa,
        m.vl_regul,
        m.dt_pagamento,
        m.anomes_ref,
        m.fl_elegivel_meta_regul,
        m.fl_elegivel_comissao_caixa,
        m.observacao,
        m.usuario_solicitante,

        case
            when coalesce(
                m.tipo_carteira_informada,
                v.tipo_carteira_vijud,
                case
                    when o.max_ind_atr_ctr between 0 and 30 then 'CARTEIRA_RECENTE'
                    when o.max_ind_atr_ctr between 31 and 90 then 'CARTEIRA_INTERMEDIARIA'
                    when o.max_ind_atr_ctr > 90 then 'CARTEIRA_AVANCADA'
                    else null
                end
            ) is null then true
            else false
        end AS fl_tipo_carteira_nao_resolvida,

        case
            when coalesce(
                m.esteira_informada,
                v.esteira_vijud,
                case
                    when o.risco_ser_ref in ('AA','A') then 'ESTEIRA_BAIXO_RISCO'
                    when o.risco_ser_ref in ('B','C') then 'ESTEIRA_MEDIO_RISCO'
                    when o.risco_ser_ref in ('D','E','F') then 'ESTEIRA_ALTO_RISCO'
                    else null
                end
            ) is null then true
            else false
        end AS fl_esteira_nao_resolvida

    FROM manual m
    LEFT JOIN vijud_mes v
      ON  m.contrato = v.contrato
      AND m.produto  = v.produto
      AND m.anomes_ref = v.p_anomes
    LEFT JOIN opc_resumo o
      ON  m.contrato = o.contrato
      AND m.produto  = o.produto
)
SELECT *
FROM enriquecido;
```

