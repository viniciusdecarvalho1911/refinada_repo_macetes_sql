# 6. 🟢 Silver integrado — pagamentos consolidados

> Esta view consolida pagamentos a partir das fontes padronizadas, resolve precedência entre origens e filtra a carteira elegível.

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_pagamentos_consolidados AS
WITH carteira_vigor AS (
    SELECT
        anomes,
        contrato,
        produto,
        cnpj_raiz,
        escritorio
    FROM workspace_db.view_silver_padronizado_cobranca_carteira_vigor
),

colchao AS (
    SELECT
        anomes,
        contrato,
        produto
    FROM workspace_db.view_silver_padronizado_cobranca_colchao
),

vijud AS (
    SELECT
        anomes,
        contrato,
        produto
    FROM workspace_db.view_silver_padronizado_juridico_vijud_inicio_mes
),

carteira_elegivel AS (
    SELECT
        v.anomes,
        v.contrato,
        v.produto,
        v.cnpj_raiz,
        v.escritorio
    FROM carteira_vigor v
    LEFT JOIN colchao c
        ON v.anomes = c.anomes
       AND v.contrato = c.contrato
       AND v.produto = c.produto
    LEFT JOIN vijud j
        ON v.anomes = j.anomes
       AND v.contrato = j.contrato
       AND v.produto = j.produto
    WHERE c.contrato IS NULL
      AND j.contrato IS NULL
),

pagamentos_union AS (
    SELECT
        b.mes_ref_yyyymm,
        b.dt_ref_yyyymmdd,
        b.dt_ref_date,
        b.ts_ref,
        b.contrato,
        b.produto,
        b.cnpj_raiz,
        b.escritorio,
        b.boleto,
        b.vl_pago,
        b.vl_desconto_boleto,
        b.origem_pagamento,
        b.tp_acordo,
        1 AS prioridade_origem
    FROM workspace_db.view_silver_padronizado_cobranca_boletos b
    WHERE coalesce(b.flag_cancelado, 0) = 0

    UNION ALL

    SELECT
        d.mes_ref_yyyymm,
        d.dt_ref_yyyymmdd,
        d.dt_ref_date,
        d.ts_ref,
        d.contrato,
        d.produto,
        d.cnpj_raiz,
        d.escritorio,
        d.boleto,
        d.vl_pago,
        d.vl_desconto_boleto,
        d.origem_pagamento,
        d.tp_acordo,
        2 AS prioridade_origem
    FROM workspace_db.view_silver_padronizado_cobranca_debito_conta d

    UNION ALL

    SELECT
        f.mes_ref_yyyymm,
        f.dt_ref_yyyymmdd,
        f.dt_ref_date,
        f.ts_ref,
        f.contrato,
        f.produto,
        f.cnpj_raiz,
        f.escritorio,
        f.boleto,
        f.vl_pago,
        f.vl_desconto_boleto,
        f.origem_pagamento,
        f.tp_acordo,
        3 AS prioridade_origem
    FROM workspace_db.view_silver_padronizado_cobranca_fluxo_apartado f
),

pagamentos_dedup AS (
    SELECT *
    FROM (
        SELECT
            p.*,
            row_number() over (
                partition by contrato, produto, dt_ref_yyyymmdd, vl_pago
                order by prioridade_origem
            ) AS rn
        FROM pagamentos_union p
    ) x
    WHERE rn = 1
),

pn AS (
    SELECT
        contrato,
        produto,
        dt_ref_yyyymmdd,
        tp_acordo,
        perc_desconto_final
    FROM workspace_db.view_silver_padronizado_cobranca_proposta_negocio
)

SELECT
    p.mes_ref_yyyymm,
    p.dt_ref_yyyymmdd,
    p.dt_ref_date,
    p.ts_ref,

    p.contrato,
    p.produto,
    p.cnpj_raiz,
    coalesce(e.escritorio, p.escritorio) AS escritorio,
    p.boleto,

    p.origem_pagamento,
    coalesce(p.tp_acordo, pn.tp_acordo) AS tp_acordo,
    p.vl_pago,
    p.vl_desconto_boleto,
    pn.perc_desconto_final,

    md5(
        concat(
            coalesce(cast(p.contrato as varchar), ''),
            '|', coalesce(cast(p.produto as varchar), ''),
            '|', coalesce(cast(p.dt_ref_yyyymmdd as varchar), ''),
            '|', coalesce(cast(p.origem_pagamento as varchar), '')
        )
    ) AS hash_chave_pagadoria
FROM pagamentos_dedup p
INNER JOIN carteira_elegivel e
    ON p.mes_ref_yyyymm = e.anomes
   AND p.contrato = e.contrato
   AND p.produto = e.produto
LEFT JOIN pn
    ON p.contrato = pn.contrato
   AND p.produto = pn.produto
   AND p.dt_ref_yyyymmdd = pn.dt_ref_yyyymmdd;
```

