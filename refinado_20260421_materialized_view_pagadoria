# 5. 🔵 Views silver padronizado lendo a MV falsa válida

## 5.1 Boletos

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_cobranca_boletos AS
SELECT
    particao_tabela_origem AS p_particao_tabela_origem,
    mes_ref_yyyymm,
    dt_ref_yyyymmdd,
    cast(date_parse(cast(dt_ref_yyyymmdd as varchar), '%Y%m%d') as date) AS dt_ref_date,
    cast(date_parse(cast(dt_ref_yyyymmdd as varchar), '%Y%m%d') as timestamp) AS ts_ref,

    contrato,
    produto,
    cnpj_raiz,
    escritorio,

    boleto,
    vl_pago,
    vl_desconto_boleto,
    coalesce(flag_cancelado, 0) AS flag_cancelado,

    'BOLETO' AS origem_pagamento,
    cast(null as varchar) AS tp_acordo,

    current_timestamp AS dt_ingestao_modelo,
    id_execucao,

    md5(
        concat(
            coalesce(cast(contrato as varchar), ''),
            '|', coalesce(cast(produto as varchar), ''),
            '|', coalesce(cast(dt_ref_yyyymmdd as varchar), '')
        )
    ) AS hash_chave_negocio,

    md5(
        concat(
            coalesce(cast(boleto as varchar), ''),
            '|', coalesce(cast(vl_pago as varchar), ''),
            '|', coalesce(cast(vl_desconto_boleto as varchar), ''),
            '|', coalesce(cast(flag_cancelado as varchar), '')
        )
    ) AS hash_atributos
FROM workspace_db.iceberg_bronze_fonte_cobranca_boletos_mv
WHERE fl_valido = true;
```

