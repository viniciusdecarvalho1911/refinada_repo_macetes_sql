# 4. 🔄 SQL de invalidar + inserir

## Estratégia recomendada

Em vez de depender de um único `MERGE` “mágico”, a estratégia desta nota é:

1. descobrir partições candidatas
2. invalidar a versão antiga
3. inserir a nova versão válida

Isso é mais simples de entender, mais previsível para operação e mais aderente ao comportamento SCD2.

## 4.1 Invalidar partições antigas — boletos

```sql
UPDATE workspace_db.iceberg_bronze_fonte_cobranca_boletos_mv
SET
    fl_valido = false,
    data_particao_execucao = current_timestamp
WHERE fl_valido = true
  AND particao_tabela_origem IN (

    WITH particoes_origem AS (
        SELECT
            cast(dt_ref as varchar) AS particao_tabela_origem,
            max("$file_modified_time") AS data_max_atualizacao
        FROM workspace_db.tabela_bronze_fonte_sap_boletos
        GROUP BY 1
    ),
    particoes_mv AS (
        SELECT
            particao_tabela_origem,
            max(data_particao_execucao) AS data_ultima_execucao
        FROM workspace_db.iceberg_bronze_fonte_cobranca_boletos_mv
        WHERE fl_valido = true
        GROUP BY 1
    )
    SELECT o.particao_tabela_origem
    FROM particoes_origem o
    LEFT JOIN particoes_mv m
        ON o.particao_tabela_origem = m.particao_tabela_origem
    WHERE m.particao_tabela_origem IS NULL
       OR o.data_max_atualizacao > m.data_ultima_execucao
);
```

## 4.2 Inserir a nova versão válida — boletos

```sql
INSERT INTO workspace_db.iceberg_bronze_fonte_cobranca_boletos_mv (
    contrato,
    produto,
    cnpj_raiz,
    escritorio,
    boleto,
    dt_ref_yyyymmdd,
    mes_ref_yyyymm,
    vl_pago,
    vl_desconto_boleto,
    flag_cancelado,
    particao_tabela_origem,
    data_particao_execucao,
    fl_valido,
    dt_ingestao_modelo,
    id_execucao
)
WITH particoes_origem AS (
    SELECT
        cast(dt_ref as varchar) AS particao_tabela_origem,
        max("$file_modified_time") AS data_max_atualizacao
    FROM workspace_db.tabela_bronze_fonte_sap_boletos
    GROUP BY 1
),

particoes_mv AS (
    SELECT
        particao_tabela_origem,
        max(data_particao_execucao) AS data_ultima_execucao
    FROM workspace_db.iceberg_bronze_fonte_cobranca_boletos_mv
    WHERE fl_valido = true
    GROUP BY 1
),

particoes_candidatas AS (
    SELECT o.particao_tabela_origem
    FROM particoes_origem o
    LEFT JOIN particoes_mv m
        ON o.particao_tabela_origem = m.particao_tabela_origem
    WHERE m.particao_tabela_origem IS NULL
       OR o.data_max_atualizacao > m.data_ultima_execucao
),

base_deduplicada AS (
    SELECT
        cast(dt_ref as varchar) AS particao_tabela_origem,
        contrato,
        produto,
        cnpj_raiz,
        escritorio,
        boleto,
        dt_ref AS dt_ref_yyyymmdd,
        cast(substr(cast(dt_ref as varchar), 1, 6) as integer) AS mes_ref_yyyymm,
        try_cast(vl_pago as decimal(18,2)) AS vl_pago,
        try_cast(vl_desconto_boleto as decimal(18,2)) AS vl_desconto_boleto,
        coalesce(flag_cancelado, 0) AS flag_cancelado,
        row_number() over (
            partition by contrato, produto, boleto, dt_ref
            order by "$file_modified_time" desc
        ) AS rn
    FROM workspace_db.tabela_bronze_fonte_sap_boletos
)
SELECT
    contrato,
    produto,
    cnpj_raiz,
    escritorio,
    boleto,
    dt_ref_yyyymmdd,
    mes_ref_yyyymm,
    vl_pago,
    vl_desconto_boleto,
    flag_cancelado,
    particao_tabela_origem,
    current_timestamp AS data_particao_execucao,
    true AS fl_valido,
    current_timestamp AS dt_ingestao_modelo,
    '{{ID_EXECUCAO}}' AS id_execucao
FROM base_deduplicada b
INNER JOIN particoes_candidatas p
    ON b.particao_tabela_origem = p.particao_tabela_origem
WHERE rn = 1;
```

