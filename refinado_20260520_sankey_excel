5️⃣ Cole o código completo

Código principal

Option Explicit

Sub SankeyDaSelecao()

    Dim matriz As Variant
    Dim wsDestino As Worksheet

    If TypeName(Selection) <> "Range" Then
        MsgBox "Selecione uma matriz com 4 colunas.", vbExclamation
        Exit Sub
    End If

    matriz = Selection.Value

    Set wsDestino = Worksheets("dashboard")

    Call DesenharSankeyMatriz( _
        matriz:=matriz, _
        wsDestino:=wsDestino, _
        nomePrefixo:="sankey_", _
        transparencia:=0.5, _
        fatorPeso:=1, _
        pesoMinimo:=2, _
        limparAntes:=True _
    )

End Sub


---

6️⃣ Motor de renderização

Sub DesenharSankeyMatriz( _
    ByVal matriz As Variant, _
    ByVal wsDestino As Worksheet, _
    Optional ByVal nomePrefixo As String = "sankey_", _
    Optional ByVal transparencia As Double = 0.5, _
    Optional ByVal fatorPeso As Double = 1, _
    Optional ByVal pesoMinimo As Double = 1, _
    Optional ByVal limparAntes As Boolean = True _
)

    Dim i As Long
    Dim src As Range
    Dim tgt As Range
    Dim shp As Shape

    If limparAntes Then
        Call LimparSankey(wsDestino, nomePrefixo)
    End If

    For i = 1 To UBound(matriz, 1)

        Set src = wsDestino.Range(CStr(matriz(i, 1)))
        Set tgt = wsDestino.Range(CStr(matriz(i, 2)))

        Set shp = wsDestino.Shapes.AddConnector( _
            msoConnectorCurve, _
            src.Left + src.Width, _
            src.Top + src.Height / 2, _
            tgt.Left, _
            tgt.Top + tgt.Height / 2 _
        )

        shp.Name = nomePrefixo & Format(i, "0000")

        With shp.Line

            .Visible = msoTrue

            .ForeColor.RGB = CorSankey(CStr(matriz(i, 4)))

            .Weight = Application.Max( _
                pesoMinimo, _
                CDbl(matriz(i, 3)) * fatorPeso _
            )

            .Transparency = transparencia

            .BeginArrowheadStyle = msoArrowheadNone
            .EndArrowheadStyle = msoArrowheadTriangle

        End With

    Next i

End Sub


---

7️⃣ Função de limpeza

Sub LimparSankey( _
    ByVal ws As Worksheet, _
    Optional ByVal nomePrefixo As String = "sankey_" _
)

    Dim shp As Shape

    For Each shp In ws.Shapes

        If Left(shp.Name, Len(nomePrefixo)) = nomePrefixo Then
            shp.Delete
        End If

    Next shp

End Sub


---

8️⃣ Função de cores

Function CorSankey(ByVal nomeCor As String) As Long

    Select Case LCase(Trim(nomeCor))

        Case "blue"
            CorSankey = RGB(0, 112, 192)

        Case "green"
            CorSankey = RGB(0, 176, 80)

        Case "red"
            CorSankey = RGB(255, 0, 0)

        Case "orange"
            CorSankey = RGB(255, 192, 0)

        Case "purple"
            CorSankey = RGB(112, 48, 160)

        Case "gray"
            CorSankey = RGB(128, 128, 128)

        Case Else
            CorSankey = RGB(91, 155, 213)

    End Select

End Function


