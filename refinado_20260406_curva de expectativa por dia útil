# 8. SQL da curva esperada ponderada

Suponha que você quer gerar a curva para `202603`.  
Você usa meses anteriores e atribui pesos.

## Exemplo conceitual

WITH historico AS (  
    SELECT  
        anomes,  
        escritorio,  
        dia_util_mes,  
        pct_acum_caixa,  
        pct_acum_emitidos,  
        pct_acum_pagos  
    FROM mart.cobranca_escritorio_curva_mes  
    WHERE anomes IN (202602, 202601, 202512, 202511, 202510, 202509, 202503)  
),  
  
pesos AS (  
    SELECT  
        anomes,  
        CASE  
            WHEN anomes = 202602 THEN 6  
            WHEN anomes = 202601 THEN 5  
            WHEN anomes = 202512 THEN 4  
            WHEN anomes = 202511 THEN 3  
            WHEN anomes = 202510 THEN 2  
            WHEN anomes = 202509 THEN 1  
            WHEN anomes = 202503 THEN 3  
            ELSE 1  
        END AS peso  
    FROM historico  
    GROUP BY 1  
),  
  
base_pesada AS (  
    SELECT  
        h.escritorio,  
        h.dia_util_mes,  
        h.pct_acum_caixa,  
        h.pct_acum_emitidos,  
        h.pct_acum_pagos,  
        p.peso  
    FROM historico h  
    JOIN pesos p  
      ON h.anomes = p.anomes  
)  
  
SELECT  
    escritorio,  
    dia_util_mes,  
  
    SUM(pct_acum_caixa * peso) / NULLIF(SUM(peso), 0) AS pct_acum_caixa_exp,  
    SUM(pct_acum_emitidos * peso) / NULLIF(SUM(peso), 0) AS pct_acum_emitidos_exp,  
    SUM(pct_acum_pagos * peso) / NULLIF(SUM(peso), 0) AS pct_acum_pagos_exp  
  
FROM base_pesada  
GROUP BY 1,2;

