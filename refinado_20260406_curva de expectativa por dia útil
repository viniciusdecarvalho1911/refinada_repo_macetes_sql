# 6. Como montar a curva histórica mensal

Agora, para cada mês histórico, você quer o acumulado por dia útil.

## Exemplo SQL

WITH base AS (  
    SELECT *  
    FROM mart.cobranca_escritorio_dia  
),  
  
acumulado AS (  
    SELECT  
        anomes,  
        escritorio,  
        dia_util_mes,  
        qt_dias_uteis_mes,  
  
        caixa_dia,  
        emitidos_dia,  
        pagos_dia,  
  
        SUM(caixa_dia) OVER (  
            PARTITION BY anomes, escritorio  
            ORDER BY dia_util_mes  
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW  
        ) AS caixa_acum,  
  
        SUM(emitidos_dia) OVER (  
            PARTITION BY anomes, escritorio  
            ORDER BY dia_util_mes  
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW  
        ) AS emitidos_acum,  
  
        SUM(pagos_dia) OVER (  
            PARTITION BY anomes, escritorio  
            ORDER BY dia_util_mes  
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW  
        ) AS pagos_acum,  
  
        SUM(caixa_dia) OVER (PARTITION BY anomes, escritorio) AS caixa_mes_total,  
        SUM(emitidos_dia) OVER (PARTITION BY anomes, escritorio) AS emitidos_mes_total,  
        SUM(pagos_dia) OVER (PARTITION BY anomes, escritorio) AS pagos_mes_total  
    FROM base  
)  
  
SELECT  
    anomes,  
    escritorio,  
    dia_util_mes,  
    qt_dias_uteis_mes,  
  
    caixa_acum,  
    emitidos_acum,  
    pagos_acum,  
  
    caixa_acum / NULLIF(caixa_mes_total, 0) AS pct_acum_caixa,  
    emitidos_acum / NULLIF(emitidos_mes_total, 0) AS pct_acum_emitidos,  
    pagos_acum / NULLIF(pagos_mes_total, 0) AS pct_acum_pagos  
FROM acumulado;

