# 2. Template — `view_silver_integrado`

## Quando usar

Use quando você já tem fontes padronizadas e quer construir **informação reutilizável**, com:

- joins
    
- deduplicação
    
- enriquecimento
    
- regra intermediária
    
- consolidação entre fontes
    

## Naming esperado

```text
view_silver_integrado_<dominio>_<entidade_ou_regra>
```

## Regra crítica

> `silver_integrado` deve depender sempre de `silver_padronizado`.

## Template

```sql
CREATE OR REPLACE VIEW <database>.view_silver_integrado_<dominio>_<entidade> AS
WITH base_principal AS (
    SELECT
        p_<particao>,
        mes_ref_yyyymm,
        dt_ref_yyyymmdd,
        dt_ref_date,
        ts_ref,
        <chaves>,
        <atributos>
    FROM <database>.view_silver_padronizado_<dominio>_<base_1>
),

base_auxiliar_1 AS (
    SELECT
        <chaves_join>,
        <atributos_auxiliares>
    FROM <database>.view_silver_padronizado_<dominio>_<base_2>
),

base_auxiliar_2 AS (
    SELECT
        <chaves_join>,
        <atributos_auxiliares>
    FROM <database>.view_silver_padronizado_<dominio>_<base_3>
),

joined AS (
    SELECT
        b.*,
        a1.<atributo_aux_1>,
        a2.<atributo_aux_2>
    FROM base_principal b
    LEFT JOIN base_auxiliar_1 a1
      ON <condicao_join_1>
    LEFT JOIN base_auxiliar_2 a2
      ON <condicao_join_2>
),

regras AS (
    SELECT
        *,
        <regra_1> AS <saida_regra_1>,
        <regra_2> AS <saida_regra_2>
    FROM joined
)

SELECT *
FROM regras;
```

## Exemplo realista — pagamentos conciliados

```sql
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_pagamentos_conciliados AS
WITH boletos AS (
    SELECT
        p_dt_ref,
        mes_ref_yyyymm,
        dt_ref_yyyymmdd,
        dt_ref_date,
        contrato,
        produto,
        boleto,
        vl_pago,
        vl_desconto_boleto,
        'BOLETO' AS origem_pagamento
    FROM workspace_db.view_silver_padronizado_cobranca_boletos
    WHERE flag_cancelado = 0
),

debito AS (
    SELECT
        p_dt_ref,
        mes_ref_yyyymm,
        dt_ref_yyyymmdd,
        dt_ref_date,
        contrato,
        produto,
        cast(null as varchar) AS boleto,
        vl_pago,
        cast(null as decimal(18,2)) AS vl_desconto_boleto,
        'DEBITO_CONTA' AS origem_pagamento
    FROM workspace_db.view_silver_padronizado_cobranca_debito_conta
),

unionado AS (
    SELECT * FROM boletos
    UNION ALL
    SELECT * FROM debito
),

dedup AS (
    SELECT *
    FROM (
        SELECT
            u.*,
            row_number() over (
                partition by contrato, produto, dt_ref_yyyymmdd, vl_pago
                order by
                    case origem_pagamento
                        when 'BOLETO' then 1
                        when 'DEBITO_CONTA' then 2
                        else 99
                    end
            ) as rn
        FROM unionado u
    ) x
    WHERE rn = 1
)

SELECT *
FROM dedup;
```

