06) Silver integrado — caixa recebido deduplicado com prioridade

A regra implementada aqui é:

BOLETO ganha de BD em ±3 dias
BOLETO e BD ganham de DEBITO em ±3 dias

Depois eu enriqueço com cdpasta e cnpj pela âncora judicial.

CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_caixa_recebido_juridico AS
WITH boletos AS (
    SELECT
        id_pagamento,
        dt_pagamento_date,
        contrato,
        produto,
        vl_pago,
        origem_pagamento
    FROM workspace_db.view_silver_padronizado_cobranca_boletos
    WHERE flag_cancelado = 0
      AND vl_pago > 0
),
bd AS (
    SELECT
        b.*
    FROM workspace_db.view_silver_padronizado_cobranca_bd b
    WHERE b.vl_pago > 0
      AND NOT EXISTS (
          SELECT 1
          FROM boletos x
          WHERE x.contrato = b.contrato
            AND x.produto  = b.produto
            AND abs(date_diff('day', x.dt_pagamento_date, b.dt_pagamento_date)) <= 3
      )
),
debito AS (
    SELECT
        d.*
    FROM workspace_db.view_silver_padronizado_cobranca_debito_conta d
    WHERE d.vl_pago > 0
      AND NOT EXISTS (
          SELECT 1
          FROM boletos x
          WHERE x.contrato = d.contrato
            AND x.produto  = d.produto
            AND abs(date_diff('day', x.dt_pagamento_date, d.dt_pagamento_date)) <= 3
      )
      AND NOT EXISTS (
          SELECT 1
          FROM bd x
          WHERE x.contrato = d.contrato
            AND x.produto  = d.produto
            AND abs(date_diff('day', x.dt_pagamento_date, d.dt_pagamento_date)) <= 3
      )
),
unionizada AS (
    SELECT * FROM boletos
    UNION ALL
    SELECT * FROM bd
    UNION ALL
    SELECT * FROM debito
),
enriquecida AS (
    SELECT
        u.id_pagamento,
        u.dt_pagamento_date,
        u.contrato,
        u.produto,
        u.vl_pago AS vl_caixa_recebido_evento,
        u.origem_pagamento,

        a.cdpasta,
        a.cnpj,
        a.safra_ajuizamento_yyyymm,
        a.dt_ajuizamento_date,
        a.hash_chave_caso,

        row_number() OVER (
            PARTITION BY u.id_pagamento, u.contrato, u.produto, u.dt_pagamento_date
            ORDER BY a.dt_ajuizamento_date DESC
        ) AS rn_ancora
    FROM unionizada u
    JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
      ON a.contrato = u.contrato
     AND a.produto  = u.produto
     AND u.dt_pagamento_date >= a.dt_ajuizamento_date
)
SELECT
    coalesce(id_pagamento, md5(concat(contrato,'|',produto,'|',cast(dt_pagamento_date as varchar),'|',cast(vl_caixa_recebido_evento as varchar)))) AS id_evento_caixa,
    cdpasta,
    cnpj,
    contrato,
    produto,
    safra_ajuizamento_yyyymm,
    dt_ajuizamento_date,
    dt_pagamento_date,
    date_diff(
        'month',
        date_trunc('month', dt_ajuizamento_date),
        date_trunc('month', dt_pagamento_date)
    ) AS mob_evento,
    origem_pagamento,
    cast(vl_caixa_recebido_evento as decimal(18,2)) AS vl_caixa_recebido_evento,
    hash_chave_caso
FROM enriquecida
WHERE rn_ancora = 1;


