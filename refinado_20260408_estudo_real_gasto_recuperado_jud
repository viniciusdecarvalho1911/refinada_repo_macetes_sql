            PARTITION BY c.cdpasta, c.cnpj, c.contrato_origem, c.produto_origem, c.dt_composicao_date
            ORDER BY s.dt_ref_date
        ) AS rn
    FROM workspace_db.view_silver_padronizado_juridico_composicao c
    JOIN workspace_db.view_silver_padronizado_juridico_carteira_snapshot s
      ON s.cdpasta   = c.cdpasta
     AND s.cnpj      = c.cnpj
     AND s.contrato  = c.contrato_destino
     AND s.produto   = c.produto_destino
     AND s.dt_ref_date >= c.dt_composicao_date
),
escolhido AS (
    SELECT
        *
    FROM novo_contrato_snapshot
    WHERE rn = 1
)
SELECT
    md5(
        concat(
            c.cdpasta,'|',c.cnpj,'|',c.contrato_origem,'|',c.produto_origem,'|',
            cast(c.dt_composicao_date as varchar),'|COMPOSICAO'
        )
    ) AS id_evento_risco,
    a.cdpasta,
    a.cnpj,
    a.contrato,
    a.produto,
    a.safra_ajuizamento_yyyymm,
    a.dt_ajuizamento_date,
    c.dt_composicao_date AS dt_evento_date,
    date_diff(
        'month',
        date_trunc('month', a.dt_ajuizamento_date),
        date_trunc('month', c.dt_composicao_date)
    ) AS mob_evento,

    cast(coalesce(e.vl_saldo_atual, e.vl_risco_atual, 0) as decimal(18,2)) AS vl_risco_abatido_evento,
    cast(0 as decimal(18,2)) AS vl_risco_ganho_evento,
    'COMPOSICAO' AS tp_evento_risco,
    a.hash_chave_caso
FROM workspace_db.view_silver_padronizado_juridico_composicao c
JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
  ON a.cdpasta  = c.cdpasta
 AND a.cnpj     = c.cnpj
 AND a.contrato = c.contrato_origem
 AND a.produto  = c.produto_origem
LEFT JOIN escolhido e
  ON e.cdpasta          = c.cdpasta
 AND e.cnpj             = c.cnpj
 AND e.contrato_origem  = c.contrato_origem
 AND e.produto_origem   = c.produto_origem
 AND e.dt_composicao_date = c.dt_composicao_date
WHERE c.dt_composicao_date >= a.dt_ajuizamento_date;


