13) Mart detalhada por caso e MOB

Essa é a mart mais importante do processo.

Grão

1 linha = 1 cdpasta + cnpj + contrato + produto + MOB

Ela te entrega:

risco inicial

risco atual no mês

risco ganho

risco abatido

caixa recebido

custo

acumulados

comparativos custo x risco abatido

comparativos custo x caixa


CREATE TABLE IF NOT EXISTS workspace_db.iceberg_gold_mart_juridico_caso_mob (
    safra_ajuizamento_yyyymm             integer,
    mob                                  integer,

    cdpasta                              varchar,
    cnpj                                 varchar,
    contrato                             varchar,
    produto                              varchar,

    dt_ajuizamento_date                  date,
    dt_fim_mes_referencia                date,

    vl_risco_inicial                     decimal(18,2),
    vl_risco_atual_mes                   decimal(18,2),
    vl_delta_risco_mes                   decimal(18,2),
    vl_risco_ganho_mes                   decimal(18,2),

    vl_risco_abatido_mes                 decimal(18,2),
    vl_risco_abatido_acumulado           decimal(18,2),

    vl_caixa_recebido_mes                decimal(18,2),
    vl_caixa_recebido_acumulado          decimal(18,2),

    vl_custo_mes                         decimal(18,2),
    vl_custo_acumulado                   decimal(18,2),

    idx_risco_abatido_por_custo_acum     decimal(18,6),
    idx_caixa_por_custo_acum             decimal(18,6),

    dt_ingestao_modelo                   timestamp,
    id_execucao                          varchar
)
WITH (
    table_type='ICEBERG',
    format='PARQUET',
    write_compression='SNAPPY',
    partitioning = ARRAY['safra_ajuizamento_yyyymm']
);

Carga

INSERT INTO workspace_db.iceberg_gold_mart_juridico_caso_mob
WITH casos AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        safra_ajuizamento_yyyymm,
        dt_ajuizamento_date,
        vl_risco_inicial
    FROM workspace_db.iceberg_gold_fato_juridico_safra_entrada
),

mobs AS (
    SELECT mob
    FROM UNNEST(sequence(0, 60)) AS t(mob)
),

grade AS (
    SELECT
        c.safra_ajuizamento_yyyymm,
        m.mob,
        c.cdpasta,
        c.cnpj,
        c.contrato,
        c.produto,
        c.dt_ajuizamento_date,
        date_add(
            'day',
            -1,
            date_add('month', m.mob + 1, date_trunc('month', c.dt_ajuizamento_date))
        ) AS dt_fim_mes_referencia,
        c.vl_risco_inicial
    FROM casos c
    CROSS JOIN mobs m
),

risco_mes AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        mob_mes AS mob,
        max_by(vl_risco_atual_mes, dt_fechamento_mes) AS vl_risco_atual_mes
    FROM workspace_db.iceberg_gold_fato_juridico_risco_snapshot_mes
    GROUP BY
        cdpasta, cnpj, contrato, produto, mob_mes
),

risco_abatido_mes AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        mob_evento AS mob,
        cast(sum(vl_risco_abatido_evento) as decimal(18,2)) AS vl_risco_abatido_mes,
        cast(sum(vl_risco_ganho_evento) as decimal(18,2))   AS vl_risco_ganho_mes
    FROM workspace_db.iceberg_gold_fato_juridico_risco_regularizacao_evento
    GROUP BY
        cdpasta, cnpj, contrato, produto, mob_evento
),

caixa_mes AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        mob_evento AS mob,
        cast(sum(vl_caixa_recebido_evento) as decimal(18,2)) AS vl_caixa_recebido_mes
    FROM workspace_db.iceberg_gold_fato_juridico_caixa_evento
    GROUP BY
        cdpasta, cnpj, contrato, produto, mob_evento
),

custo_mes AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        mob_evento AS mob,
        cast(sum(vl_custo) as decimal(18,2)) AS vl_custo_mes
    FROM workspace_db.iceberg_gold_fato_juridico_custo_evento
    GROUP BY
        cdpasta, cnpj, contrato, produto, mob_evento
),

base AS (
    SELECT
        g.safra_ajuizamento_yyyymm,
        g.mob,
        g.cdpasta,
        g.cnpj,
        g.contrato,
        g.produto,
        g.dt_ajuizamento_date,
        g.dt_fim_mes_referencia,
        cast(g.vl_risco_inicial as decimal(18,2)) AS vl_risco_inicial,

        cast(coalesce(r.vl_risco_atual_mes, 0) as decimal(18,2)) AS vl_risco_atual_mes,
        cast(coalesce(a.vl_risco_ganho_mes, 0) as decimal(18,2)) AS vl_risco_ganho_mes,
        cast(coalesce(a.vl_risco_abatido_mes, 0) as decimal(18,2)) AS vl_risco_abatido_mes,
        cast(coalesce(x.vl_caixa_recebido_mes, 0) as decimal(18,2)) AS vl_caixa_recebido_mes,
        cast(coalesce(c.vl_custo_mes, 0) as decimal(18,2)) AS vl_custo_mes
    FROM grade g
    LEFT JOIN risco_mes r
      ON g.cdpasta  = r.cdpasta
     AND g.cnpj     = r.cnpj
     AND g.contrato = r.contrato
     AND g.produto  = r.produto
     AND g.mob      = r.mob
    LEFT JOIN risco_abatido_mes a
      ON g.cdpasta  = a.cdpasta
     AND g.cnpj     = a.cnpj
     AND g.contrato = a.contrato
     AND g.produto  = a.produto
     AND g.mob      = a.mob
    LEFT JOIN caixa_mes x
      ON g.cdpasta  = x.cdpasta
     AND g.cnpj     = x.cnpj
     AND g.contrato = x.contrato
     AND g.produto  = x.produto
     AND g.mob      = x.mob
    LEFT JOIN custo_mes c
      ON g.cdpasta  = c.cdpasta
     AND g.cnpj     = c.cnpj
     AND g.contrato = c.contrato
     AND g.produto  = c.produto
     AND g.mob      = c.mob
),

com_delta AS (
    SELECT
        *,
        cast(
            vl_risco_atual_mes
            - lag(vl_risco_atual_mes) OVER (
                PARTITION BY cdpasta, cnpj, contrato, produto
                ORDER BY mob
            )
        as decimal(18,2)) AS vl_delta_risco_mes
    FROM base
),

acumulada AS (
    SELECT
        *,
        cast(
            sum(vl_risco_abatido_mes) OVER (
                PARTITION BY cdpasta, cnpj, contrato, produto
                ORDER BY mob
                ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
            )
        as decimal(18,2)) AS vl_risco_abatido_acumulado,

        cast(
            sum(vl_caixa_recebido_mes) OVER (
                PARTITION BY cdpasta, cnpj, contrato, produto
                ORDER BY mob
                ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
            )
        as decimal(18,2)) AS vl_caixa_recebido_acumulado,

        cast(
            sum(vl_custo_mes) OVER (
                PARTITION BY cdpasta, cnpj, contrato, produto
                ORDER BY mob
                ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
            )
        as decimal(18,2)) AS vl_custo_acumulado
    FROM com_delta
)

SELECT
    safra_ajuizamento_yyyymm,
    mob,
    cdpasta,
    cnpj,
    contrato,
    produto,
    dt_ajuizamento_date,
    dt_fim_mes_referencia,
    vl_risco_inicial,
    vl_risco_atual_mes,
    cast(coalesce(vl_delta_risco_mes, 0) as decimal(18,2)) AS vl_delta_risco_mes,
    vl_risco_ganho_mes,
    vl_risco_abatido_mes,
    vl_risco_abatido_acumulado,
    vl_caixa_recebido_mes,
    vl_caixa_recebido_acumulado,
    vl_custo_mes,
    vl_custo_acumulado,

    cast(
        vl_risco_abatido_acumulado / nullif(vl_custo_acumulado, 0)
    as decimal(18,6)) AS idx_risco_abatido_por_custo_acum,

    cast(
        vl_caixa_recebido_acumulado / nullif(vl_custo_acumulado, 0)
    as decimal(18,6)) AS idx_caixa_por_custo_acum,

    current_timestamp AS dt_ingestao_modelo,
    'execucao_manual' AS id_execucao
FROM acumulada;


