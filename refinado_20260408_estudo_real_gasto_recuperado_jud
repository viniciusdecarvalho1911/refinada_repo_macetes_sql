01) Silver padronizado — carteira/risco snapshot

CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_juridico_carteira_snapshot AS
SELECT
    cast(date_format(cast(dt_ref as date), '%Y%m') as integer)            AS p_anomes_ref,
    cast(date_format(cast(dt_ref as date), '%Y%m%d') as integer)          AS dt_ref_yyyymmdd,
    cast(dt_ref as date)                                                  AS dt_ref_date,
    cast(dt_ref as timestamp)                                             AS ts_ref,

    trim(cast(cdpasta as varchar))                                        AS cdpasta,
    trim(cast(cnpj as varchar))                                           AS cnpj,
    trim(cast(contrato as varchar))                                       AS contrato,
    trim(cast(produto as varchar))                                        AS produto,

    cast(coalesce(dt_ajuizamento, dt_ref) as date)                        AS dt_ajuizamento_date,
    cast(coalesce(atraso_dias, 0) as integer)                             AS atraso_dias,
    cast(coalesce(vl_risco_atual, 0) as decimal(18,2))                    AS vl_risco_atual,
    cast(coalesce(vl_saldo_atual, 0) as decimal(18,2))                    AS vl_saldo_atual,
    cast(coalesce(fl_ajuizado, true) as boolean)                          AS fl_ajuizado,

    current_timestamp                                                     AS dt_ingestao_modelo,
    'execucao_manual'                                                     AS id_execucao,

    md5(
        concat(
            coalesce(trim(cast(cdpasta as varchar)), ''),
            '|', coalesce(trim(cast(cnpj as varchar)), ''),
            '|', coalesce(trim(cast(contrato as varchar)), ''),
            '|', coalesce(trim(cast(produto as varchar)), '')
        )
    ) AS hash_chave_caso
FROM workspace_db.tabela_bronze_fonte_juridico_carteira_snapshot
WHERE cdpasta  IS NOT NULL
