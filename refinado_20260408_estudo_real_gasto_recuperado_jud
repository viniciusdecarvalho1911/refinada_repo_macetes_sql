08) Silver integrado — evento de regularização do risco no mesmo contrato

Aqui entra sua regra de negócio principal.

CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_risco_regularizacao_mesmo_contrato AS
WITH base AS (
    SELECT
        s.cdpasta,
        s.cnpj,
        s.contrato,
        s.produto,
        a.safra_ajuizamento_yyyymm,
        a.dt_ajuizamento_date,
        s.dt_ref_date,
        s.atraso_dias,
        s.vl_risco_atual,
        s.vl_saldo_atual,
        a.hash_chave_caso,

        lag(s.dt_ref_date) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS dt_ref_anterior,

        lag(s.atraso_dias) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS atraso_dias_anterior,

        lag(s.vl_risco_atual) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS vl_risco_anterior,

        lag(s.vl_saldo_atual) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS vl_saldo_anterior
    FROM workspace_db.view_silver_padronizado_juridico_carteira_snapshot s
    JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
      ON a.cdpasta  = s.cdpasta
     AND a.cnpj     = s.cnpj
     AND a.contrato = s.contrato
     AND a.produto  = s.produto
    WHERE s.dt_ref_date >= a.dt_ajuizamento_date
),
eventos AS (
    SELECT
        md5(
            concat(
                cdpasta,'|',cnpj,'|',contrato,'|',produto,'|',
                cast(dt_ref_date as varchar),'|REGRA_MESMO_CONTRATO'
            )
        ) AS id_evento_risco,
        cdpasta,
        cnpj,
        contrato,
        produto,
        safra_ajuizamento_yyyymm,
        dt_ajuizamento_date,
        dt_ref_date AS dt_evento_date,

        date_diff(
            'month',
            date_trunc('month', dt_ajuizamento_date),
            date_trunc('month', dt_ref_date)
        ) AS mob_evento,

        cast(
            CASE
                WHEN dt_ref_anterior IS NULL THEN 0

                -- atraso foi para zero no mesmo contrato:
                -- risco abatido = saldo remanescente do novo estado
                WHEN coalesce(atraso_dias_anterior, 0) > 0
                 AND coalesce(atraso_dias, 0) = 0
                THEN coalesce(vl_saldo_atual, 0)

                -- atraso caiu, continua > 0, saldo caiu:
                -- risco abatido = diferença positiva de saldo
                WHEN coalesce(atraso_dias_anterior, 0) > coalesce(atraso_dias, 0)
                 AND coalesce(atraso_dias, 0) > 0
                 AND coalesce(vl_saldo_anterior, 0) > coalesce(vl_saldo_atual, 0)
                THEN coalesce(vl_saldo_anterior, 0) - coalesce(vl_saldo_atual, 0)

                ELSE 0
            END
        as decimal(18,2)) AS vl_risco_abatido_evento,

        cast(
            CASE
                WHEN dt_ref_anterior IS NULL THEN 0
                WHEN coalesce(vl_risco_atual, 0) > coalesce(vl_risco_anterior, 0)
                THEN coalesce(vl_risco_atual, 0) - coalesce(vl_risco_anterior, 0)
                ELSE 0
            END
        as decimal(18,2)) AS vl_risco_ganho_evento,

        'MESMO_CONTRATO' AS tp_evento_risco,
        hash_chave_caso
    FROM base
)
SELECT
    *
FROM eventos
WHERE vl_risco_abatido_evento > 0
   OR vl_risco_ganho_evento > 0;


