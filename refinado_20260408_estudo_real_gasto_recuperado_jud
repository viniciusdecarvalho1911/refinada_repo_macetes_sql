    cast(sum(vl_caixa_recebido_mes) as decimal(18,2))      AS vl_caixa_recebido_total_mes,
    cast(sum(vl_caixa_recebido_acumulado) as decimal(18,2)) AS vl_caixa_recebido_total_acumulado,

    cast(sum(vl_custo_mes) as decimal(18,2))               AS vl_custo_total_mes,
    cast(sum(vl_custo_acumulado) as decimal(18,2))         AS vl_custo_total_acumulado,

    cast(
        sum(vl_risco_abatido_acumulado) / nullif(sum(vl_custo_acumulado), 0)
    as decimal(18,6)) AS idx_risco_abatido_por_custo_acum,

    cast(
        sum(vl_caixa_recebido_acumulado) / nullif(sum(vl_custo_acumulado), 0)
    as decimal(18,6)) AS idx_caixa_por_custo_acum,

    current_timestamp AS dt_ingestao_modelo,
    'execucao_manual' AS id_execucao
FROM workspace_db.iceberg_gold_mart_juridico_caso_mob
GROUP BY
    safra_ajuizamento_yyyymm,
    mob;


