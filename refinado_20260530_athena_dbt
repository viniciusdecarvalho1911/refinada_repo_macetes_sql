write("scripts/catalog_explorer.py", """
import sys
from common import run_sql

def usage():
print('''
Uso:
python scripts/catalog_explorer.py databases
python scripts/catalog_explorer.py tables <database>
python scripts/catalog_explorer.py describe <database> <table>
python scripts/catalog_explorer.py show-create <database> <table>
''')

if len(sys.argv) < 2:
usage()
raise SystemExit(1)

cmd = sys.argv[1]

if cmd == "databases":
print(run_sql("SHOW DATABASES").to_string(index=False))

elif cmd == "tables":
db = sys.argv[2]
print(run_sql(f"SHOW TABLES IN {db}").to_string(index=False))

elif cmd == "describe":
db, table = sys.argv[2], sys.argv[3]
print(run_sql(f"DESCRIBE {db}.{table}").to_string(index=False))

elif cmd == "show-create":
db, table = sys.argv[2], sys.argv[3]
df = run_sql(f"SHOW CREATE TABLE {db}.{table}")
print(df.iloc[0, 0])

else:
usage()
raise SystemExit(1)
""")

