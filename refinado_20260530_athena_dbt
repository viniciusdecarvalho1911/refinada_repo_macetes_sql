write("scripts/common.py", r"""
from pathlib import Path
import yaml
from pyathena import connect
import pandas as pd
from datetime import datetime

ROOT = Path(**file**).resolve().parents[1]

def load_yaml(path: str):
with open(ROOT / path, "r", encoding="utf-8") as f:
return yaml.safe_load(f)

def load_profile():
profile_path = ROOT / "config" / "profiles.yml"
if not profile_path.exists():
profile_path = ROOT / "config" / "profiles.example.yml"
return load_yaml(str(profile_path.relative_to(ROOT)))

def get_conn():
cfg = load_profile()["athena"]
return connect(
s3_staging_dir=cfg["s3_staging_dir"],
region_name=cfg.get("region_name", "sa-east-1"),
work_group=cfg.get("work_group", "primary"),
)

def run_sql(sql: str):
conn = get_conn()
return pd.read_sql(sql, conn)

def load_models():
data = load_yaml("metadata/models.yml")
return sorted(data["models"], key=lambda x: x.get("order", 999))

def find_model(name: str):
for model in load_models():
if model["name"] == name:
return model
raise ValueError(f"Modelo não encontrado: {name}")

def read_sql_file(path: str):
return (ROOT / path).read_text(encoding="utf-8")

def split_statements(sql: str):
parts = [p.strip() for p in sql.split(";") if p.strip()]
return [p + ";" for p in parts]

def log(message: str):
ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
print(f"[{ts}] {message}")
""")

