-- model: view_silver_padronizado_cobranca_boletos
-- materialization: view
-- database: silver_db
-- grain: 1 linha = 1 boleto + 1 contrato + 1 produto + 1 data_ref

CREATE OR REPLACE VIEW silver_db.view_silver_padronizado_cobranca_boletos AS
SELECT
dt_ref AS p_dt_ref,

```
cast(substr(cast(dt_ref as varchar), 1, 6) as integer) AS mes_ref_yyyymm,
dt_ref AS dt_ref_yyyymmdd,
cast(date_parse(cast(dt_ref as varchar), '%Y%m%d') as date) AS dt_ref_date,
cast(date_parse(cast(dt_ref as varchar), '%Y%m%d') as timestamp) AS ts_ref,

cast(contrato as varchar) AS contrato,
cast(produto as varchar) AS produto,
right(regexp_replace(cast(cnpj_raiz as varchar), '[^0-9]', ''), 14) AS cnpj_canonico,
upper(trim(cast(escritorio as varchar))) AS escritorio,

cast(boleto as varchar) AS boleto,
try_cast(vl_pago as decimal(18,2)) AS vl_pago,
try_cast(vl_desconto_boleto as decimal(18,2)) AS vl_desconto_boleto,
coalesce(try_cast(flag_cancelado as integer), 0) AS flag_cancelado,

'BOLETO' AS origem_pagamento,
cast(null as varchar) AS tp_acordo,

current_timestamp AS dt_ingestao_modelo,
'manual_local' AS id_execucao,

md5(
    concat(
        coalesce(cast(contrato as varchar), ''),
        '|', coalesce(cast(produto as varchar), ''),
        '|', coalesce(cast(boleto as varchar), ''),
        '|', coalesce(cast(dt_ref as varchar), '')
    )
) AS hash_chave_negocio,

md5(
    concat(
        coalesce(cast(vl_pago as varchar), ''),
        '|', coalesce(cast(vl_desconto_boleto as varchar), ''),
        '|', coalesce(cast(flag_cancelado as varchar), '')
    )
) AS hash_atributos
```

