# Template Universal

```dataviewjs
const obrigatorios = [
  "MERGE INTO"
];

const opcionais = [
  "iceberg_gold",
  "gold_db"
];

const proibidos = [
  "old/"
];

let pages = dv.pages();
let rows = [];

for (let p of pages) {

  let content =
    await dv.io.load(p.file.path);

  let texto =
    ((content || "") + " " + p.file.path)
      .toUpperCase();

  const temObrigatorios =
    obrigatorios.every(t =>
      texto.includes(t.toUpperCase())
    );

  const temAlgumOpcional =
    opcionais.length === 0 ||
    opcionais.some(t =>
      texto.includes(t.toUpperCase())
    );

  const naoTemProibidos =
    proibidos.every(t =>
      !texto.includes(t.toUpperCase())
    );

  if (
    temObrigatorios &&
    temAlgumOpcional &&
    naoTemProibidos
  ) {
    rows.push([
      p.file.link,
      p.file.path
    ]);
  }
}

dv.table(
  ["Arquivo", "Caminho"],
  rows
);
```

