# DataviewJS — Pesquisas Compostas

## AND

Encontrar notas que contenham:

```text
MERGE INTO
e
iceberg_gold
```

```dataviewjs
const termos = ["MERGE INTO", "iceberg_gold"];

let rows = [];

for (let p of dv.pages()) {
  let content = await dv.io.load(p.file.path);
  let upper = (content || "").toUpperCase();

  if (termos.every(t => upper.includes(t.toUpperCase()))) {
    rows.push([
      p.file.link,
      p.file.path
    ]);
  }
}

dv.table(["Arquivo", "Caminho"], rows);
```

---

## OR

```dataviewjs
const termos = [
  "MERGE INTO",
  "INSERT INTO",
  "CREATE TABLE"
];

let rows = [];

for (let p of dv.pages()) {
  let content = await dv.io.load(p.file.path);
  let upper = (content || "").toUpperCase();

  if (termos.some(t => upper.includes(t.toUpperCase()))) {
    rows.push([
      p.file.link,
      p.file.path
    ]);
  }
}

dv.table(["Arquivo", "Caminho"], rows);
```

---

## AND + NOT

```dataviewjs
const obrigatorios = ["MERGE INTO"];
const proibidos = ["old/"];

let rows = [];

for (let p of dv.pages()) {
  let content = await dv.io.load(p.file.path);

  let texto =
    ((content || "") + " " + p.file.path)
      .toUpperCase();

  const okObrigatorios =
    obrigatorios.every(t =>
      texto.includes(t.toUpperCase())
    );

  const okProibidos =
    proibidos.every(t =>
      !texto.includes(t.toUpperCase())
    );

  if (okObrigatorios && okProibidos) {
    rows.push([
      p.file.link,
      p.file.path
    ]);
  }
}

dv.table(["Arquivo", "Caminho"], rows);
```

