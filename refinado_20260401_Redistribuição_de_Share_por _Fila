resultado_final AS (
    SELECT
        r.ciclo,
        r.fila,
        f.pontos_movimentar_desejado,
        r.escritorio,
        r.share_inicial,
        r.meta,
        r.realizado,
        r.mediana_fila,
        r.grupo,
        r.atingimento_meta,
        r.indice_vs_mediana,
        COALESCE(p.pontos_perdidos, 0) AS pontos_perdidos,
        COALESCE(g.pontos_ganhos, 0) AS pontos_ganhos,
        COALESCE(g.pontos_ganhos, 0) - COALESCE(p.pontos_perdidos, 0) AS delta_share,
        r.share_inicial - COALESCE(p.pontos_perdidos, 0) + COALESCE(g.pontos_ganhos, 0) AS share_final
    FROM rankings r
    JOIN parametros_fila f
      ON r.ciclo = f.ciclo
     AND r.fila = f.fila
    LEFT JOIN consolidado_perdas p
      ON r.ciclo = p.ciclo
     AND r.fila = p.fila
     AND f.pontos_movimentar_desejado = p.pontos_movimentar_desejado
     AND r.escritorio = p.escritorio
    LEFT JOIN consolidado_ganhos g
      ON r.ciclo = g.ciclo
     AND r.fila = g.fila
     AND f.pontos_movimentar_desejado = g.pontos_movimentar_desejado
     AND r.escritorio = g.escritorio
)

SELECT *
FROM resultado_final
ORDER BY ciclo, fila, pontos_movimentar_desejado, share_final DESC, escritorio;
