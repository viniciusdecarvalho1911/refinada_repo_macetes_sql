        f.pontos_movimentar_desejado,
        g.escritorio,
        1 AS ponto_ganho
    FROM slots_ganho_ordenados g
    JOIN parametros_fila f
      ON g.ciclo = f.ciclo
     AND g.fila  = f.fila
    WHERE g.rodada_ganho <= f.pontos_movimentar
),

