    SELECT
        ciclo,
        fila,
        pontos_movimentar_desejado,
        escritorio,
        COUNT(*) AS pontos_perdidos
    FROM perdas_aplicadas
    GROUP BY 1,2,3,4
),

consolidado_ganhos AS (
    SELECT
        ciclo,
        fila,
        pontos_movimentar_desejado,
        escritorio,
        COUNT(*) AS pontos_ganhos
    FROM ganhos_aplicados
    GROUP BY 1,2,3,4
