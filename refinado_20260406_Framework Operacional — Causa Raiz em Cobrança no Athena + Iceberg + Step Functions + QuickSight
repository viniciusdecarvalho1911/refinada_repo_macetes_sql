    fl_aprovado      boolean,
    dt_execucao      timestamp
)
```

## Exemplo de teste de duplicidade

```sql
SELECT count(*) AS qtd_erros
FROM (
    SELECT
        anomes_atual,
        nivel_analise,
        escritorio,
        fila,
        faixa_atraso,
        cluster,
        segmento,
        produto,
        tipo_carteira
    FROM mart_db.cobranca_causa_raiz_drill_mes_v2
    GROUP BY 1,2,3,4,5,6,7,8,9
