# ETAPA F — Criar a mart principal com decomposição e texto

A ideia aqui é ter **número + narrativa** no mesmo SQL.

## Estrutura conceitual da query

```sql
WITH parametros AS (
    SELECT
        202603 AS anomes_atual,
        202602 AS anomes_anterior
),

base AS (
    SELECT
        anomes,
        coalesce(cast(escritorio as varchar), 'TODOS')      AS escritorio,
        coalesce(cast(fila as varchar), 'TODAS')            AS fila,
        coalesce(cast(faixa_atraso as varchar), 'TODAS')    AS faixa_atraso,
        coalesce(cast(cluster as varchar), 'TODOS')         AS cluster,
        coalesce(cast(segmento as varchar), 'TODOS')        AS segmento,
        coalesce(cast(produto as varchar), 'TODOS')         AS produto,
        coalesce(cast(tipo_carteira as varchar), 'TODAS')   AS tipo_carteira,
        sum(vl_carteira) AS carteira,
        sum(vl_pagamento) AS caixa,
        count(*) AS volume,
        sum(vl_pagamento) / nullif(count(*),0) AS ticket_medio,
        max(qt_dias_uteis) AS du
    FROM workspace_db.view_gold_base_analise_mes
    WHERE anomes IN (202602, 202603)
    GROUP BY 1,2,3,4,5,6,7,8
),

nivel_escritorio AS (
    SELECT
        anomes,
        'ESCRITORIO' AS nivel_analise,
        escritorio,
        'TODAS' AS fila,
        'TODAS' AS faixa_atraso,
        'TODOS' AS cluster,
        'TODOS' AS segmento,
        'TODOS' AS produto,
        'TODAS' AS tipo_carteira,
        sum(carteira) AS carteira,
        sum(caixa) AS caixa,
        sum(volume) AS volume,
        sum(caixa) / nullif(sum(volume),0) AS ticket_medio,
        max(du) AS du
    FROM base
    GROUP BY 1,2,3,4,5,6,7,8,9
),

nivel_escritorio_fila_faixa AS (
    SELECT
        anomes,
        'ESCRITORIO_FILA_FAIXA' AS nivel_analise,
        escritorio,
        fila,
        faixa_atraso,
        'TODOS' AS cluster,
        'TODOS' AS segmento,
        'TODOS' AS produto,
        'TODAS' AS tipo_carteira,
        sum(carteira) AS carteira,
        sum(caixa) AS caixa,
        sum(volume) AS volume,
        sum(caixa) / nullif(sum(volume),0) AS ticket_medio,
        max(du) AS du
    FROM base
    GROUP BY 1,2,3,4,5,6,7,8,9
),

empilhado AS (
    SELECT * FROM nivel_escritorio
    UNION ALL
    SELECT * FROM nivel_escritorio_fila_faixa
),

comparacao AS (
    SELECT
        a.nivel_analise,
        a.escritorio,
        a.fila,
        a.faixa_atraso,
        a.cluster,
        a.segmento,
        a.produto,
        a.tipo_carteira,
        a.anomes AS anomes_atual,
        b.anomes AS anomes_anterior,
        a.carteira AS carteira_atual,
        b.carteira AS carteira_anterior,
        a.caixa AS caixa_atual,
        b.caixa AS caixa_anterior,
        a.volume AS volume_atual,
        b.volume AS volume_anterior,
        a.ticket_medio AS ticket_atual,
        b.ticket_medio AS ticket_anterior,
        a.du AS du_atual,
        b.du AS du_anterior
    FROM empilhado a
    LEFT JOIN empilhado b
      ON a.nivel_analise = b.nivel_analise
     AND a.escritorio = b.escritorio
     AND a.fila = b.fila
     AND a.faixa_atraso = b.faixa_atraso
     AND a.cluster = b.cluster
     AND a.segmento = b.segmento
     AND a.produto = b.produto
     AND a.tipo_carteira = b.tipo_carteira
     AND b.anomes = 202602
    WHERE a.anomes = 202603
),

metricas AS (
    SELECT
        *,
        caixa_atual / nullif(carteira_atual,0) AS eficiencia_real_atual,
        caixa_anterior / nullif(carteira_anterior,0) AS eficiencia_real_anterior,
        (caixa_atual * (cast(du_anterior as double) / nullif(cast(du_atual as double),0)))
            / nullif(carteira_atual,0) AS eficiencia_ajustada_du_atual
    FROM comparacao
),

decomposicao AS (
    SELECT
        *,
        (eficiencia_real_atual - eficiencia_real_anterior) * 100 AS delta_eficiencia_real_pp,
        (eficiencia_ajustada_du_atual - eficiencia_real_anterior) * 100 AS delta_eficiencia_ajustada_du_pp,
        ((eficiencia_real_atual - eficiencia_real_anterior)
          - (eficiencia_ajustada_du_atual - eficiencia_real_anterior)) * 100 AS impacto_du_pp,
        caixa_atual - caixa_anterior AS delta_caixa,
        (volume_atual - volume_anterior) * ticket_anterior AS impacto_volume,
        (ticket_atual - ticket_anterior) * volume_atual AS impacto_ticket
    FROM metricas
),

classificado AS (
    SELECT
        *,
        CASE
            WHEN abs(impacto_volume) >= abs(impacto_ticket) THEN 'volume'
            ELSE 'ticket'
        END AS principal_driver_caixa,
        CASE
            WHEN abs(impacto_du_pp) >= 0.5 THEN 'relevante'
            ELSE 'nao_relevante'
        END AS relevancia_du
    FROM decomposicao
),

final AS (
    SELECT
        *,
        concat(
            'Eficiência ',
            CASE
                WHEN delta_eficiencia_real_pp < 0 THEN 'caiu '
                WHEN delta_eficiencia_real_pp > 0 THEN 'subiu '
                ELSE 'ficou estável '
            END,
            cast(round(abs(delta_eficiencia_real_pp),1) AS varchar),
            ' pp. Ajustando por dias úteis, a variação seria de ',
            cast(round(delta_eficiencia_ajustada_du_pp,1) AS varchar),
            ' pp. ',
            CASE
                WHEN relevancia_du = 'relevante'
                    THEN concat('Parte relevante da variação é explicada por DUs (',
                                cast(round(abs(impacto_du_pp),1) AS varchar),
                                ' pp). ')
                ELSE 'O efeito de DUs não é relevante. '
            END,
            'Principal driver do caixa: ',
            CASE
                WHEN principal_driver_caixa = 'volume' AND impacto_volume < 0 THEN 'queda de volume'
                WHEN principal_driver_caixa = 'volume' AND impacto_volume > 0 THEN 'alta de volume'
                WHEN principal_driver_caixa = 'ticket' AND impacto_ticket < 0 THEN 'queda de ticket médio'
                WHEN principal_driver_caixa = 'ticket' AND impacto_ticket > 0 THEN 'alta de ticket médio'
                ELSE 'variação mista'
            END,
            '.'
        ) AS txt_insight_exec
    FROM classificado
)

SELECT * FROM final;
```

## O que esse SQL já resolve

Ele já entrega:

- comparação atual vs anterior
    
- eficiência real
    
- eficiência ajustada por DU
    
- impacto de DU
    
- impacto volume
    
- impacto ticket
    
- driver principal
    
- narrativa textual pronta
    

Esse é o coração do seu objetivo: **ter no mesmo SQL o texto descritivo parametrizado de explicação**.

