# 7. Script local — espelha S3 para máquina

Esse script faz exatamente sua regra:

```text
se arquivo AWS novo → baixa
se arquivo AWS mudou tamanho → baixa
se arquivo local existe e AWS não existe → move para old/
se old > 30 dias → apaga
```

## `sync_s3_athena_md.py`

```python
from pathlib import Path
from datetime import datetime, timedelta
import boto3
import shutil

AWS_PROFILE = "SEU_PROFILE"
REGION = "sa-east-1"

BUCKET = "SEU-BUCKET"
PREFIX = "athena-query-catalog/current/"

LOCAL_ROOT = Path(r"C:\Users\SEU_USUARIO\Documents\athena-vault")
LOCAL_CURRENT = LOCAL_ROOT / "athena-query-catalog" / "current"
LOCAL_OLD = LOCAL_ROOT / "athena-query-catalog" / "old"

RETENCAO_OLD_DIAS = 30


def get_s3_client():
    session = boto3.Session(profile_name=AWS_PROFILE, region_name=REGION)
    return session.client("s3")


def list_s3_files(s3):
    files = {}

    paginator = s3.get_paginator("list_objects_v2")

    for page in paginator.paginate(Bucket=BUCKET, Prefix=PREFIX):
        for obj in page.get("Contents", []):
            key = obj["Key"]

            if key.endswith("/"):
                continue

            files[key] = {
                "size": obj["Size"],
                "etag": obj["ETag"].replace('"', ""),
                "last_modified": obj["LastModified"],
            }

    return files


def local_path_from_s3_key(key: str) -> Path:
    relative = key.replace("athena-query-catalog/current/", "")
    return LOCAL_CURRENT / relative


def s3_key_from_local_path(local_path: Path) -> str:
    relative = local_path.relative_to(LOCAL_CURRENT).as_posix()
    return f"athena-query-catalog/current/{relative}"


def old_path_from_current_path(local_path: Path) -> Path:
    relative = local_path.relative_to(LOCAL_CURRENT)
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    return LOCAL_OLD / timestamp / relative


def should_download(local_path: Path, s3_meta: dict) -> bool:
    if not local_path.exists():
        return True

    if local_path.stat().st_size != s3_meta["size"]:
        return True

    return False


def download_new_or_changed(s3, s3_files):
    for key, meta in s3_files.items():
        local_path = local_path_from_s3_key(key)

        if should_download(local_path, meta):
            local_path.parent.mkdir(parents=True, exist_ok=True)
            s3.download_file(BUCKET, key, str(local_path))
            print(f"baixado/atualizado: {key}")
        else:
            print(f"igual, ignorado: {key}")


def move_missing_local_to_old(s3_files):
    if not LOCAL_CURRENT.exists():
        return

    s3_keys = set(s3_files.keys())

    for local_file in LOCAL_CURRENT.rglob("*.md"):
        local_key = s3_key_from_local_path(local_file)

        if local_key not in s3_keys:
            dest = old_path_from_current_path(local_file)
            dest.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(local_file), str(dest))
            print(f"movido para old: {local_file}")


def cleanup_old():
    if not LOCAL_OLD.exists():
        return

    limite = datetime.now() - timedelta(days=RETENCAO_OLD_DIAS)

    for file in LOCAL_OLD.rglob("*"):
        if file.is_file():
            modified = datetime.fromtimestamp(file.stat().st_mtime)

            if modified < limite:
                file.unlink()
                print(f"apagado old > 30 dias: {file}")

    for folder in sorted(LOCAL_OLD.rglob("*"), reverse=True):
        if folder.is_dir() and not any(folder.iterdir()):
            folder.rmdir()


def main():
    s3 = get_s3_client()

    s3_files = list_s3_files(s3)

    download_new_or_changed(s3, s3_files)
    move_missing_local_to_old(s3_files)
    cleanup_old()

    print("sync finalizado")


if __name__ == "__main__":
    main()
```

