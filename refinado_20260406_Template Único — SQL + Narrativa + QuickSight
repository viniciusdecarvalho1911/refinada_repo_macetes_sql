# 🧪 Template único de SQL

> A ideia aqui é:
> 
> 1. pegar a base mensal
>     
> 2. comparar atual vs anterior
>     
> 3. calcular eficiência, DU, volume, ticket
>     
> 4. calcular mediana por nível
>     
> 5. gerar textos em blocos
>     
> 6. devolver uma linha pronta para QuickSight
>     

```sql
WITH parametros AS (

    -- =========================================================
    -- 1) PARÂMETROS DO PERÍODO
    --    ajuste aqui o mês atual e o anterior
    -- =========================================================
    SELECT
        202603 AS anomes_atual,
        202602 AS anomes_anterior
),

base AS (

    -- =========================================================
    -- 2) BASE ANALÍTICA
    --    1 linha = 1 mês + 1 escritório
    --
    --    Troque esta origem pela sua view/tabela oficial.
    -- =========================================================
    SELECT
        b.anomes,
        COALESCE(CAST(b.escritorio AS varchar), 'N/A') AS escritorio,

        SUM(b.vl_carteira) AS carteira,
        SUM(b.vl_pagamento) AS caixa,
        COUNT(*) AS volume,
        SUM(b.vl_pagamento) / NULLIF(COUNT(*), 0) AS ticket_medio,
        MAX(b.qt_dias_uteis) AS du

    FROM gold.cobranca_base_analise_mes b
    JOIN parametros p
      ON b.anomes IN (p.anomes_atual, p.anomes_anterior)

    GROUP BY 1,2
),

comparacao AS (

    -- =========================================================
    -- 3) JUNTA MÊS ATUAL COM MÊS ANTERIOR
    -- =========================================================
    SELECT
        a.escritorio,
        a.anomes AS anomes_atual,
        b.anomes AS anomes_anterior,

        a.carteira AS carteira_atual,
        b.carteira AS carteira_anterior,

        a.caixa AS caixa_atual,
        b.caixa AS caixa_anterior,

        a.volume AS volume_atual,
        b.volume AS volume_anterior,

        a.ticket_medio AS ticket_atual,
        b.ticket_medio AS ticket_anterior,

        a.du AS du_atual,
        b.du AS du_anterior

    FROM base a
    JOIN parametros p
      ON a.anomes = p.anomes_atual

    LEFT JOIN base b
      ON a.escritorio = b.escritorio
     AND b.anomes = p.anomes_anterior
),

metricas AS (

    -- =========================================================
    -- 4) CÁLCULOS PRINCIPAIS
    -- =========================================================
    SELECT
        *,

        caixa_atual / NULLIF(carteira_atual, 0) AS eficiencia_real_atual,
        caixa_anterior / NULLIF(carteira_anterior, 0) AS eficiencia_real_anterior,

        (caixa_atual * (CAST(du_anterior AS double) / NULLIF(CAST(du_atual AS double),0)))
            / NULLIF(carteira_atual, 0) AS eficiencia_ajustada_du_atual,

        (caixa_atual - caixa_anterior) AS delta_caixa,

        (volume_atual - volume_anterior) * ticket_anterior AS impacto_volume,
        (ticket_atual - ticket_anterior) * volume_atual AS impacto_ticket

    FROM comparacao
),

decomposicao AS (

    -- =========================================================
    -- 5) DELTAS EM PP
    -- =========================================================
    SELECT
        *,

        (eficiencia_real_atual - eficiencia_real_anterior) * 100 AS delta_eficiencia_real_pp,

        (eficiencia_ajustada_du_atual - eficiencia_real_anterior) * 100 AS delta_eficiencia_ajustada_du_pp,

        (
            (eficiencia_real_atual - eficiencia_real_anterior)
            - (eficiencia_ajustada_du_atual - eficiencia_real_anterior)
        ) * 100 AS impacto_du_pp

    FROM metricas
),

classificado AS (

    -- =========================================================
    -- 6) CLASSIFICA O DRIVER PRINCIPAL
    -- =========================================================
    SELECT
        *,

        CASE
            WHEN ABS(impacto_volume) >= ABS(impacto_ticket) THEN 'volume'
            ELSE 'ticket'
        END AS principal_driver_caixa

    FROM decomposicao
),

com_mediana AS (

    -- =========================================================
    -- 7) COMPARAÇÃO RELATIVA VS MERCADO
    --    mediana do nível escritório no período
    -- =========================================================
    SELECT
        *,
        approx_percentile(eficiencia_real_atual, 0.5) OVER () AS mediana_eficiencia_atual,
        approx_percentile(eficiencia_real_anterior, 0.5) OVER () AS mediana_eficiencia_anterior
    FROM classificado
),

relativo AS (

    -- =========================================================
    -- 8) GAP PARA MEDIANA
    -- =========================================================
    SELECT
        *,

        (eficiencia_real_atual - mediana_eficiencia_atual) * 100 AS gap_mediana_atual,
        (eficiencia_real_anterior - mediana_eficiencia_anterior) * 100 AS gap_mediana_anterior,

        (
            (eficiencia_real_atual - mediana_eficiencia_atual)
            - (eficiencia_real_anterior - mediana_eficiencia_anterior)
        ) * 100 AS delta_gap_mediana

    FROM com_mediana
),

textos AS (

    -- =========================================================
    -- 9) BLOCOS DE TEXTO
    --    Não monte tudo em um concat gigante logo de cara.
    --    Primeiro monte os blocos.
    -- =========================================================
    SELECT
        *,

        -- ---------------------------------------------
        -- 9.1 Headline
        -- ---------------------------------------------
        CONCAT(
            'A eficiência do escritório ',
            COALESCE(escritorio, 'N/A'),
            ' ',
            CASE
                WHEN delta_eficiencia_real_pp < 0 THEN 'caiu '
                WHEN delta_eficiencia_real_pp > 0 THEN 'subiu '
                ELSE 'ficou estável '
            END,
            CAST(ROUND(ABS(delta_eficiencia_real_pp), 1) AS varchar),
            ' pp no mês, de ',
            CAST(ROUND(eficiencia_real_anterior * 100, 1) AS varchar),
            '% para ',
            CAST(ROUND(eficiencia_real_atual * 100, 1) AS varchar),
            '%.'
        ) AS txt_headline,

        -- ---------------------------------------------
        -- 9.2 Dias úteis
        -- ---------------------------------------------
        CASE
            WHEN ABS(impacto_du_pp) >= ABS(delta_eficiencia_real_pp) * 0.6 THEN
                CONCAT(
                    'A maior parte da variação é explicada por calendário. Ajustando por dias úteis, a variação seria de ',
                    CAST(ROUND(delta_eficiencia_ajustada_du_pp, 1) AS varchar),
                    ' pp.'
                )

            WHEN ABS(impacto_du_pp) >= ABS(delta_eficiencia_real_pp) * 0.3 THEN
                CONCAT(
                    'Mesmo após ajuste por dias úteis, a variação permanece em ',
                    CAST(ROUND(ABS(delta_eficiencia_ajustada_du_pp), 1) AS varchar),
                    ' pp, indicando que o efeito de calendário explica apenas parte da variação.'
                )

            ELSE
                'O efeito de dias úteis não é relevante.'
        END AS txt_du,

        -- ---------------------------------------------
        -- 9.3 Driver
        -- ---------------------------------------------
        CASE
            WHEN principal_driver_caixa = 'volume' THEN
                CONCAT(
                    'A principal pressão veio da redução de volume, que variou de ',
                    CAST(ROUND(volume_anterior, 0) AS varchar),
                    ' para ',
                    CAST(ROUND(volume_atual, 0) AS varchar),
                    '.'
                )

            WHEN principal_driver_caixa = 'ticket' THEN
                CONCAT(
                    'A principal pressão veio do ticket médio, que variou de ',
                    CAST(ROUND(ticket_anterior, 2) AS varchar),
                    ' para ',
                    CAST(ROUND(ticket_atual, 2) AS varchar),
                    '.'
                )

            ELSE
                'A variação foi explicada por múltiplos fatores.'
        END AS txt_driver,

        -- ---------------------------------------------
        -- 9.4 Relativo à mediana
        -- ---------------------------------------------
        CASE

            WHEN eficiencia_real_atual < eficiencia_real_anterior
             AND delta_gap_mediana < 0
             AND gap_mediana_atual < 0 THEN
                CONCAT(
                    'Além da queda absoluta, o escritório também piorou em relação ao mercado, passando de ',
                    CAST(ROUND(gap_mediana_anterior, 1) AS varchar),
                    ' pp para ',
                    CAST(ROUND(gap_mediana_atual, 1) AS varchar),
                    ' pp em relação à mediana, ficando abaixo dela.'
                )

            WHEN eficiencia_real_atual < eficiencia_real_anterior
             AND gap_mediana_atual >= 0 THEN
                CONCAT(
                    'Apesar da queda, o escritório permanece acima da mediana do mercado, com gap de ',
                    CAST(ROUND(gap_mediana_atual, 1) AS varchar),
                    ' pp.'
                )

            WHEN eficiencia_real_atual > eficiencia_real_anterior
             AND delta_gap_mediana > 0
             AND gap_mediana_atual > 0 THEN
                CONCAT(
                    'O escritório também melhorou sua posição relativa, passando de ',
                    CAST(ROUND(gap_mediana_anterior, 1) AS varchar),
                    ' pp para ',
                    CAST(ROUND(gap_mediana_atual, 1) AS varchar),
                    ' pp acima da mediana.'
                )

            WHEN eficiencia_real_atual > eficiencia_real_anterior
             AND gap_mediana_atual < 0 THEN
                CONCAT(
                    'Apesar da melhora, o escritório ainda permanece abaixo da mediana, com gap de ',
                    CAST(ROUND(gap_mediana_atual, 1) AS varchar),
                    ' pp.'
                )

            ELSE
                'O escritório manteve posição relativamente estável em relação à mediana.'
        END AS txt_relativo_mediana,

        -- ---------------------------------------------
        -- 9.5 Diagnóstico
        -- ---------------------------------------------
        CASE

            WHEN delta_eficiencia_real_pp < 0
             AND ABS(impacto_du_pp) >= ABS(delta_eficiencia_real_pp) * 0.6 THEN
                'A leitura é de piora predominantemente explicada por calendário.'

            WHEN delta_eficiencia_real_pp < 0
             AND principal_driver_caixa = 'volume' THEN
                'A leitura é de deterioração de execução operacional.'

            WHEN delta_eficiencia_real_pp < 0
             AND principal_driver_caixa = 'ticket' THEN
                'A leitura é de deterioração de qualidade de arrecadação.'

            WHEN delta_eficiencia_real_pp > 0
             AND ABS(impacto_du_pp) >= ABS(delta_eficiencia_real_pp) * 0.6 THEN
                'A leitura é de melhora predominantemente explicada por calendário.'

            WHEN delta_eficiencia_real_pp > 0
             AND principal_driver_caixa = 'volume' THEN
                'A leitura é de ganho de tração operacional.'

            WHEN delta_eficiencia_real_pp > 0
             AND principal_driver_caixa = 'ticket' THEN
                'A leitura é de melhora de qualidade de arrecadação.'

            ELSE
                'A leitura é de estabilidade relativa, sem variação material.'
        END AS txt_diagnostico

    FROM relativo
),

final AS (

    -- =========================================================
    -- 10) TEXTO FINAL
    -- =========================================================
    SELECT
        *,

        CONCAT(
            txt_headline,
            ' ',
            txt_driver
        ) AS txt_insight_simples,

        CONCAT(
            txt_headline,
            ' ',
            txt_du,
            ' ',
            txt_driver,
            ' ',
            txt_relativo_mediana,
            ' ',
            txt_diagnostico
        ) AS txt_insight_completo

    FROM textos
)

SELECT *
FROM final;
```

