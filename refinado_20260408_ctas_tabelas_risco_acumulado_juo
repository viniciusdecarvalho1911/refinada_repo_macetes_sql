-- =========================================================
-- 01_silver_padronizado.sql
-- Camada: silver_padronizado
-- Objetivo:
--   1) Padronizar snapshots de carteira/risco judicial
--   2) Padronizar composição (novo contrato invalida o anterior)
--   3) Padronizar custos judiciais
--   4) Padronizar pagamentos de BOLETO, DEBITO e BD
-- Observação:
--   Ajuste nomes de tabelas e colunas conforme seu ambiente real.
-- =========================================================

-- =========================================================
-- 1) CARTEIRA / RISCO SNAPSHOT
-- Grão:
--   1 linha = 1 dt_ref + 1 cdpasta + 1 cnpj + 1 contrato + 1 produto
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_juridico_carteira_snapshot AS
SELECT
    cast(date_format(cast(dt_ref as date), '%Y%m') as integer)            AS p_anomes_ref,
    cast(date_format(cast(dt_ref as date), '%Y%m%d') as integer)          AS dt_ref_yyyymmdd,
    cast(dt_ref as date)                                                  AS dt_ref_date,
    cast(dt_ref as timestamp)                                             AS ts_ref,

    trim(cast(cdpasta as varchar))                                        AS cdpasta,
    trim(cast(cnpj as varchar))                                           AS cnpj,
    trim(cast(contrato as varchar))                                       AS contrato,
    trim(cast(produto as varchar))                                        AS produto,

    cast(coalesce(dt_ajuizamento, dt_ref) as date)                        AS dt_ajuizamento_date,
    cast(coalesce(atraso_dias, 0) as integer)                             AS atraso_dias,
    cast(coalesce(vl_risco_atual, 0) as decimal(18,2))                    AS vl_risco_atual,
    cast(coalesce(vl_saldo_atual, 0) as decimal(18,2))                    AS vl_saldo_atual,
    cast(coalesce(fl_ajuizado, true) as boolean)                          AS fl_ajuizado,

    current_timestamp                                                     AS dt_ingestao_modelo,
    'execucao_manual'                                                     AS id_execucao,

    md5(
        concat(
            coalesce(trim(cast(cdpasta as varchar)), ''),
            '|', coalesce(trim(cast(cnpj as varchar)), ''),
            '|', coalesce(trim(cast(contrato as varchar)), ''),
            '|', coalesce(trim(cast(produto as varchar)), '')
        )
    ) AS hash_chave_caso
FROM workspace_db.tabela_bronze_fonte_juridico_carteira_snapshot
WHERE cdpasta  IS NOT NULL
  AND cnpj     IS NOT NULL
  AND contrato IS NOT NULL
  AND produto  IS NOT NULL;

-- =========================================================
-- 2) COMPOSICAO
-- Grão:
--   1 linha = 1 evento de composição
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_juridico_composicao AS
SELECT
    cast(date_format(cast(dt_composicao as date), '%Y%m') as integer)     AS p_anomes_composicao,
    cast(date_format(cast(dt_composicao as date), '%Y%m%d') as integer)   AS dt_composicao_yyyymmdd,
    cast(dt_composicao as date)                                            AS dt_composicao_date,

    trim(cast(cdpasta as varchar))                                         AS cdpasta,
    trim(cast(cnpj as varchar))                                            AS cnpj,
    trim(cast(contrato_origem as varchar))                                 AS contrato_origem,
    trim(cast(produto_origem as varchar))                                  AS produto_origem,
    trim(cast(contrato_destino as varchar))                                AS contrato_destino,
    trim(cast(produto_destino as varchar))                                 AS produto_destino,

    current_timestamp                                                      AS dt_ingestao_modelo,
    'execucao_manual'                                                      AS id_execucao
FROM workspace_db.tabela_bronze_fonte_juridico_composicao
WHERE dt_composicao IS NOT NULL
  AND contrato_origem IS NOT NULL
  AND produto_origem IS NOT NULL
  AND contrato_destino IS NOT NULL
  AND produto_destino IS NOT NULL;

-- =========================================================
-- 3) CUSTOS
-- Grão:
--   1 linha = 1 evento de custo
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_juridico_custos AS
SELECT
    cast(date_format(cast(dt_custo as date), '%Y%m') as integer)          AS p_anomes_custo,
    cast(date_format(cast(dt_custo as date), '%Y%m%d') as integer)        AS dt_custo_yyyymmdd,
    cast(dt_custo as date)                                                AS dt_custo_date,

    trim(cast(id_custo as varchar))                                       AS id_custo,
    trim(cast(cdpasta as varchar))                                        AS cdpasta,
    trim(cast(cnpj as varchar))                                           AS cnpj,
    trim(cast(contrato as varchar))                                       AS contrato,
    trim(cast(produto as varchar))                                        AS produto,
    upper(trim(cast(tp_custo as varchar)))                                AS tp_custo,

    cast(coalesce(vl_custo, 0) as decimal(18,2))                          AS vl_custo,

    current_timestamp                                                     AS dt_ingestao_modelo,
    'execucao_manual'                                                     AS id_execucao
FROM workspace_db.tabela_bronze_fonte_juridico_custos
WHERE dt_custo IS NOT NULL
  AND cdpasta  IS NOT NULL
  AND cnpj     IS NOT NULL
  AND contrato IS NOT NULL
  AND produto  IS NOT NULL;

-- =========================================================
-- 4) PAGAMENTOS - BOLETO
