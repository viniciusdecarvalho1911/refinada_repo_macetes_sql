-- =========================================================
-- 02_silver_integrado.sql
-- Camada: silver_integrado
-- Objetivo:
--   1) Criar âncora oficial do caso judicial
--   2) Consolidar caixa recebido com prioridade BOLETO > BD > DEBITO
--      usando janela de conflito de +/- 3 dias
--   3) Construir snapshots mensais de risco
--   4) Construir eventos de regularização/ganho de risco
-- =========================================================

-- =========================================================
-- 1) ANCORA OFICIAL DO CASO
-- Grão:
--   1 linha = 1 cdpasta + cnpj + contrato + produto
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_caso_ancora AS
WITH base AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        dt_ajuizamento_date,
        dt_ref_date,
        vl_risco_atual,
        vl_saldo_atual,
        hash_chave_caso,
        row_number() OVER (
            PARTITION BY cdpasta, cnpj, contrato, produto
            ORDER BY dt_ajuizamento_date, dt_ref_date
        ) AS rn
    FROM workspace_db.view_silver_padronizado_juridico_carteira_snapshot
    WHERE fl_ajuizado = true
),
inicial AS (
    SELECT
        cdpasta,
        cnpj,
        contrato,
        produto,
        cast(date_format(dt_ajuizamento_date, '%Y%m') as integer) AS safra_ajuizamento_yyyymm,
        dt_ajuizamento_date,
        vl_risco_atual AS vl_risco_inicial,
        vl_saldo_atual AS vl_saldo_inicial,
        hash_chave_caso
    FROM base
    WHERE rn = 1
)
SELECT
    *
FROM inicial;

-- =========================================================
-- 2) CAIXA RECEBIDO JURIDICO
-- Regra:
--   BOLETO > BD > DEBITO
--   conflito por contrato + produto em +/- 3 dias
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_cobranca_caixa_recebido_juridico AS
WITH boletos AS (
    SELECT
        id_pagamento,
        dt_pagamento_date,
        contrato,
        produto,
        vl_pago,
        origem_pagamento
    FROM workspace_db.view_silver_padronizado_cobranca_boletos
    WHERE flag_cancelado = 0
      AND vl_pago > 0
),
bd AS (
    SELECT
        b.*
    FROM workspace_db.view_silver_padronizado_cobranca_bd b
    WHERE b.vl_pago > 0
      AND NOT EXISTS (
          SELECT 1
          FROM boletos x
          WHERE x.contrato = b.contrato
            AND x.produto  = b.produto
            AND abs(date_diff('day', x.dt_pagamento_date, b.dt_pagamento_date)) <= 3
      )
),
debito AS (
    SELECT
        d.*
    FROM workspace_db.view_silver_padronizado_cobranca_debito_conta d
    WHERE d.vl_pago > 0
      AND NOT EXISTS (
          SELECT 1
          FROM boletos x
          WHERE x.contrato = d.contrato
            AND x.produto  = d.produto
            AND abs(date_diff('day', x.dt_pagamento_date, d.dt_pagamento_date)) <= 3
      )
      AND NOT EXISTS (
          SELECT 1
          FROM bd x
          WHERE x.contrato = d.contrato
            AND x.produto  = d.produto
            AND abs(date_diff('day', x.dt_pagamento_date, d.dt_pagamento_date)) <= 3
      )
),
unionizada AS (
    SELECT * FROM boletos
    UNION ALL
    SELECT * FROM bd
    UNION ALL
    SELECT * FROM debito
),
enriquecida AS (
    SELECT
        u.id_pagamento,
        u.dt_pagamento_date,
        u.contrato,
        u.produto,
        u.vl_pago AS vl_caixa_recebido_evento,
        u.origem_pagamento,

        a.cdpasta,
        a.cnpj,
        a.safra_ajuizamento_yyyymm,
        a.dt_ajuizamento_date,
        a.hash_chave_caso,

        row_number() OVER (
            PARTITION BY u.id_pagamento, u.contrato, u.produto, u.dt_pagamento_date
            ORDER BY a.dt_ajuizamento_date DESC
        ) AS rn_ancora
    FROM unionizada u
    JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
      ON a.contrato = u.contrato
     AND a.produto  = u.produto
     AND u.dt_pagamento_date >= a.dt_ajuizamento_date
)
SELECT
    coalesce(
        id_pagamento,
        md5(
            concat(
                contrato,'|',produto,'|',
                cast(dt_pagamento_date as varchar),'|',
                cast(vl_caixa_recebido_evento as varchar)
            )
        )
    ) AS id_evento_caixa,
    cdpasta,
    cnpj,
    contrato,
    produto,
    safra_ajuizamento_yyyymm,
    dt_ajuizamento_date,
    dt_pagamento_date,
    date_diff(
        'month',
        date_trunc('month', dt_ajuizamento_date),
        date_trunc('month', dt_pagamento_date)
    ) AS mob_evento,
    origem_pagamento,
    cast(vl_caixa_recebido_evento as decimal(18,2)) AS vl_caixa_recebido_evento,
    hash_chave_caso
FROM enriquecida
WHERE rn_ancora = 1;

-- =========================================================
-- 3) SNAPSHOT MENSAL DE RISCO
-- Grão:
--   1 linha = 1 caso + 1 mês de referência (última foto do mês)
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_risco_snapshot_mes AS
WITH base AS (
    SELECT
        s.cdpasta,
        s.cnpj,
        s.contrato,
        s.produto,
        a.safra_ajuizamento_yyyymm,
        a.dt_ajuizamento_date,

        cast(date_format(s.dt_ref_date, '%Y%m') as integer) AS anomes_ref,
        s.dt_ref_date,
        s.atraso_dias,
        s.vl_risco_atual,
        s.vl_saldo_atual,
        s.hash_chave_caso,

        row_number() OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto, cast(date_format(s.dt_ref_date, '%Y%m') as integer)
            ORDER BY s.dt_ref_date DESC
        ) AS rn_mes
    FROM workspace_db.view_silver_padronizado_juridico_carteira_snapshot s
    JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
      ON a.cdpasta  = s.cdpasta
     AND a.cnpj     = s.cnpj
     AND a.contrato = s.contrato
     AND a.produto  = s.produto
    WHERE s.dt_ref_date >= a.dt_ajuizamento_date
)
SELECT
    cdpasta,
    cnpj,
    contrato,
    produto,
    safra_ajuizamento_yyyymm,
    dt_ajuizamento_date,
    anomes_ref,
    dt_ref_date AS dt_fechamento_mes,
    atraso_dias,
    cast(vl_risco_atual as decimal(18,2)) AS vl_risco_atual_mes,
    cast(vl_saldo_atual as decimal(18,2)) AS vl_saldo_atual_mes,
    date_diff(
        'month',
        date_trunc('month', dt_ajuizamento_date),
        date_trunc('month', dt_ref_date)
    ) AS mob_mes,
    hash_chave_caso
FROM base
WHERE rn_mes = 1;

-- =========================================================
-- 4) EVENTOS DE REGULARIZACAO NO MESMO CONTRATO
-- Regra:
--   a) atraso > 0 e vira 0 -> risco abatido = saldo atual
--   b) atraso cai, continua > 0, e saldo cai -> abatimento = saldo anterior - saldo atual
--   c) risco pode ganhar ao longo do tempo -> ganho positivo de risco
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_risco_regularizacao_mesmo_contrato AS
WITH base AS (
    SELECT
        s.cdpasta,
        s.cnpj,
        s.contrato,
        s.produto,
        a.safra_ajuizamento_yyyymm,
        a.dt_ajuizamento_date,
        s.dt_ref_date,
        s.atraso_dias,
        s.vl_risco_atual,
        s.vl_saldo_atual,
        a.hash_chave_caso,

        lag(s.dt_ref_date) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS dt_ref_anterior,

        lag(s.atraso_dias) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS atraso_dias_anterior,

        lag(s.vl_risco_atual) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS vl_risco_anterior,

        lag(s.vl_saldo_atual) OVER (
            PARTITION BY s.cdpasta, s.cnpj, s.contrato, s.produto
            ORDER BY s.dt_ref_date
        ) AS vl_saldo_anterior
    FROM workspace_db.view_silver_padronizado_juridico_carteira_snapshot s
    JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
      ON a.cdpasta  = s.cdpasta
     AND a.cnpj     = s.cnpj
     AND a.contrato = s.contrato
     AND a.produto  = s.produto
    WHERE s.dt_ref_date >= a.dt_ajuizamento_date
),
eventos AS (
    SELECT
        md5(
            concat(
                cdpasta,'|',cnpj,'|',contrato,'|',produto,'|',
                cast(dt_ref_date as varchar),'|REGRA_MESMO_CONTRATO'
            )
        ) AS id_evento_risco,
        cdpasta,
        cnpj,
        contrato,
        produto,
        safra_ajuizamento_yyyymm,
        dt_ajuizamento_date,
        dt_ref_date AS dt_evento_date,

        date_diff(
            'month',
            date_trunc('month', dt_ajuizamento_date),
            date_trunc('month', dt_ref_date)
        ) AS mob_evento,

        cast(
            CASE
                WHEN dt_ref_anterior IS NULL THEN 0
                WHEN coalesce(atraso_dias_anterior, 0) > 0
                 AND coalesce(atraso_dias, 0) = 0
                THEN coalesce(vl_saldo_atual, 0)
                WHEN coalesce(atraso_dias_anterior, 0) > coalesce(atraso_dias, 0)
                 AND coalesce(atraso_dias, 0) > 0
                 AND coalesce(vl_saldo_anterior, 0) > coalesce(vl_saldo_atual, 0)
                THEN coalesce(vl_saldo_anterior, 0) - coalesce(vl_saldo_atual, 0)
                ELSE 0
            END
        as decimal(18,2)) AS vl_risco_abatido_evento,

        cast(
            CASE
                WHEN dt_ref_anterior IS NULL THEN 0
                WHEN coalesce(vl_risco_atual, 0) > coalesce(vl_risco_anterior, 0)
                THEN coalesce(vl_risco_atual, 0) - coalesce(vl_risco_anterior, 0)
                ELSE 0
            END
        as decimal(18,2)) AS vl_risco_ganho_evento,

        'MESMO_CONTRATO' AS tp_evento_risco,
        hash_chave_caso
    FROM base
)
SELECT
    *
FROM eventos
WHERE vl_risco_abatido_evento > 0
   OR vl_risco_ganho_evento > 0;

-- =========================================================
-- 5) EVENTOS DE REGULARIZACAO POR COMPOSICAO
-- Regra:
--   regularização do contrato anterior = valor de risco/saldo do novo contrato
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_risco_regularizacao_composicao AS
WITH novo_contrato_snapshot AS (
    SELECT
        c.dt_composicao_date,
        c.cdpasta,
        c.cnpj,
        c.contrato_origem,
        c.produto_origem,
        c.contrato_destino,
        c.produto_destino,

        s.dt_ref_date,
        s.vl_risco_atual,
        s.vl_saldo_atual,

        row_number() OVER (
            PARTITION BY c.cdpasta, c.cnpj, c.contrato_origem, c.produto_origem, c.dt_composicao_date
            ORDER BY s.dt_ref_date
        ) AS rn
    FROM workspace_db.view_silver_padronizado_juridico_composicao c
    JOIN workspace_db.view_silver_padronizado_juridico_carteira_snapshot s
      ON s.cdpasta   = c.cdpasta
     AND s.cnpj      = c.cnpj
     AND s.contrato  = c.contrato_destino
     AND s.produto   = c.produto_destino
     AND s.dt_ref_date >= c.dt_composicao_date
),
escolhido AS (
    SELECT
        *
    FROM novo_contrato_snapshot
    WHERE rn = 1
)
SELECT
    md5(
        concat(
            c.cdpasta,'|',c.cnpj,'|',c.contrato_origem,'|',c.produto_origem,'|',
            cast(c.dt_composicao_date as varchar),'|COMPOSICAO'
        )
    ) AS id_evento_risco,
    a.cdpasta,
    a.cnpj,
    a.contrato,
    a.produto,
    a.safra_ajuizamento_yyyymm,
    a.dt_ajuizamento_date,
    c.dt_composicao_date AS dt_evento_date,
    date_diff(
        'month',
        date_trunc('month', a.dt_ajuizamento_date),
        date_trunc('month', c.dt_composicao_date)
    ) AS mob_evento,

    cast(coalesce(e.vl_saldo_atual, e.vl_risco_atual, 0) as decimal(18,2)) AS vl_risco_abatido_evento,
    cast(0 as decimal(18,2)) AS vl_risco_ganho_evento,
    'COMPOSICAO' AS tp_evento_risco,
    a.hash_chave_caso
FROM workspace_db.view_silver_padronizado_juridico_composicao c
JOIN workspace_db.view_silver_integrado_juridico_caso_ancora a
  ON a.cdpasta  = c.cdpasta
 AND a.cnpj     = c.cnpj
 AND a.contrato = c.contrato_origem
 AND a.produto  = c.produto_origem
LEFT JOIN escolhido e
  ON e.cdpasta            = c.cdpasta
 AND e.cnpj               = c.cnpj
 AND e.contrato_origem    = c.contrato_origem
 AND e.produto_origem     = c.produto_origem
 AND e.dt_composicao_date = c.dt_composicao_date
WHERE c.dt_composicao_date >= a.dt_ajuizamento_date;

-- =========================================================
-- 6) CONSOLIDADO DE EVENTOS DE RISCO
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_integrado_juridico_risco_regularizacao_evento AS
SELECT
    id_evento_risco,
    cdpasta,
    cnpj,
    contrato,
    produto,
    safra_ajuizamento_yyyymm,
    dt_ajuizamento_date,
    dt_evento_date,
    mob_evento,
