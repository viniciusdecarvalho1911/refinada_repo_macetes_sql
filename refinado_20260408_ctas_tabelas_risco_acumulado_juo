-- =========================================================
-- 5) PAGAMENTOS - DEBITO
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_cobranca_debito_conta AS
SELECT
    cast(date_format(cast(dt_pagamento as date), '%Y%m') as integer)      AS p_anomes_pagto,
    cast(date_format(cast(dt_pagamento as date), '%Y%m%d') as integer)    AS dt_pagamento_yyyymmdd,
    cast(dt_pagamento as date)                                             AS dt_pagamento_date,

    trim(cast(id_pagamento as varchar))                                    AS id_pagamento,
    trim(cast(contrato as varchar))                                        AS contrato,
    trim(cast(produto as varchar))                                         AS produto,

    cast(coalesce(vl_pago, 0) as decimal(18,2))                            AS vl_pago,

    'DEBITO'                                                               AS origem_pagamento,

    current_timestamp                                                      AS dt_ingestao_modelo,
    'execucao_manual'                                                      AS id_execucao
FROM workspace_db.tabela_bronze_fonte_legado_debito_conta
WHERE dt_pagamento IS NOT NULL
  AND contrato IS NOT NULL
  AND produto IS NOT NULL;

-- =========================================================
-- 6) PAGAMENTOS - BD / BACKOFFICE
-- =========================================================
CREATE OR REPLACE VIEW workspace_db.view_silver_padronizado_cobranca_bd AS
SELECT
    cast(date_format(cast(dt_pagamento as date), '%Y%m') as integer)      AS p_anomes_pagto,
    cast(date_format(cast(dt_pagamento as date), '%Y%m%d') as integer)    AS dt_pagamento_yyyymmdd,
    cast(dt_pagamento as date)                                             AS dt_pagamento_date,

    trim(cast(id_pagamento as varchar))                                    AS id_pagamento,
    trim(cast(contrato as varchar))                                        AS contrato,
    trim(cast(produto as varchar))                                         AS produto,

    cast(coalesce(vl_pago, 0) as decimal(18,2))                            AS vl_pago,

    'BD'                                                                   AS origem_pagamento,

    current_timestamp                                                      AS dt_ingestao_modelo,
    'execucao_manual'                                                      AS id_execucao
FROM workspace_db.tabela_bronze_fonte_backoffice_fluxo_apartado
WHERE dt_pagamento IS NOT NULL
  AND contrato IS NOT NULL
  AND produto IS NOT NULL;


