sql = """
CREATE OR REPLACE VIEW workspace_db.view_gold_mart_cobranca_pagadoria_quicksight AS WITH pagamentos AS ( SELECT contrato, produto, cnpj_raiz, escritorio, mes_ref_yyyymm, vl_pago, vl_desconto_boleto, origem_pagamento FROM workspace_db.view_silver_integrado_cobranca_pagamentos_consolidados WHERE mes_ref_yyyymm = 202604 ), carteira AS ( SELECT contrato, produto, mes_ref_yyyymm, faixa_atraso, saldo_contabil, tipo_carteira FROM workspace_db.view_silver_integrado_cobranca_carteira_vigor WHERE mes_ref_yyyymm = 202604 ), base AS ( SELECT p.mes_ref_yyyymm, p.contrato, p.produto, p.cnpj_raiz, p.escritorio, c.faixa_atraso, c.tipo_carteira, p.origem_pagamento, p.vl_pago, p.vl_desconto_boleto, c.saldo_contabil, CASE WHEN p.origem_pagamento IN ('BOLETO', 'DEBITO_CONTA') THEN p.vl_pago ELSE 0 END AS vl_caixa, CASE WHEN c.faixa_atraso <= 60 AND p.vl_pago > 0 THEN c.saldo_contabil ELSE 0 END AS vl_regul FROM pagamentos p INNER JOIN carteira c ON p.contrato = c.contrato AND p.produto = c.produto AND p.mes_ref_yyyymm = c.mes_ref_yyyymm ) SELECT mes_ref_yyyymm, escritorio, faixa_atraso, tipo_carteira, count(DISTINCT contrato) AS qtd_contratos, sum(vl_pago) AS vl_pago_total, sum(vl_caixa) AS vl_caixa, sum(vl_regul) AS vl_regul, sum(vl_desconto_boleto) AS vl_desconto_total, sum(saldo_contabil) AS saldo_total, cast(sum(vl_regul) as double) / nullif(sum(saldo_contabil), 0) AS eficiencia_regul FROM base GROUP BY mes_ref_yyyymm, escritorio, faixa_atraso, tipo_carteira;
"""
explainer = SqlSemanticExplainer(sql, dialect="presto")
explainer.print_report()

# Se quiser o resultado como dict:
resultado = explainer.explain()
