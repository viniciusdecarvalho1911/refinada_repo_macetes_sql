# 2. jeito “literal”: executar query Athena e ler o resultado no S3

Se você quer **realmente** que o Glue leia o resultado de uma query Athena, o fluxo é este:

```text id="wajd9n"
Glue -> boto3 start_query_execution
     -> polling até SUCCEEDED
     -> pega OutputLocation
     -> lê o arquivo de resultado no S3
     -> escreve no bronze com partitionBy
```

## cuidado importante

Resultado de `SELECT` do Athena sai em **CSV** por padrão. 

Então esse método funciona, mas é mais “gambiarra operacional” do que arquitetura limpa para pipeline recorrente.

## exemplo hardcoded

```python id="25d6w1"
import time
import boto3

from awsglue.context import GlueContext
from awsglue.job import Job
from awsglue.dynamicframe import DynamicFrame
from pyspark.context import SparkContext
from pyspark.sql import functions as F

sc = SparkContext()
glueContext = GlueContext(sc)
spark = glueContext.spark_session
job = Job(glueContext)

job.init("job_bronze_lendo_query_athena", {})

athena = boto3.client("athena", region_name="us-east-1")

DATABASE = "workspace_db"
WORKGROUP = "primary"
ATHENA_OUTPUT = "s3://meu-bucket-athena-results/queries/"
QUERY = """
SELECT
    col1,
    col2,
    anomes,
    dt_ref
FROM workspace_db.minha_tabela_origem
WHERE anomes >= 202401
"""

DST_DATABASE = "workspace_db"
DST_TABLE = "tabela_bronze_fonte_cobranca_minha_entidade"
DST_S3_PATH = "s3://meu-bucket/bronze/cobranca/minha_entidade/"
PARTITION_KEYS = ["anomes", "dt_ref"]

# ---------------------------------------------------------
# 1) executa query Athena
# ---------------------------------------------------------
resp = athena.start_query_execution(
    QueryString=QUERY,
    QueryExecutionContext={"Database": DATABASE},
    ResultConfiguration={"OutputLocation": ATHENA_OUTPUT},
    WorkGroup=WORKGROUP
)

query_execution_id = resp["QueryExecutionId"]

# ---------------------------------------------------------
# 2) espera terminar
# ---------------------------------------------------------
while True:
    status_resp = athena.get_query_execution(QueryExecutionId=query_execution_id)
    state = status_resp["QueryExecution"]["Status"]["State"]

    if state in ["SUCCEEDED", "FAILED", "CANCELLED"]:
        break

    time.sleep(3)

if state != "SUCCEEDED":
    raise Exception(f"Query Athena falhou. Status final: {state}")

output_location = status_resp["QueryExecution"]["ResultConfiguration"]["OutputLocation"]
print("Output Athena:", output_location)

# ---------------------------------------------------------
# 3) lê resultado CSV do Athena
# ---------------------------------------------------------
df_src = (
    spark.read
         .option("header", "true")
         .csv(output_location)
)

# se necessário, ajusta tipos
df_src = (
    df_src
    .withColumn("anomes", F.col("anomes").cast("int"))
    .withColumn("dt_ref", F.col("dt_ref").cast("int"))
)

# ---------------------------------------------------------
# 4) escreve no bronze recriando partições
# ---------------------------------------------------------
(
    df_src.write
        .mode("overwrite")
        .format("parquet")
        .partitionBy(*PARTITION_KEYS)
        .save(DST_S3_PATH)
)

# ---------------------------------------------------------
# 5) publica no catálogo
# ---------------------------------------------------------
df_dst = spark.read.parquet(DST_S3_PATH)
dyf_dst = DynamicFrame.fromDF(df_dst, glueContext, "dyf_dst")

sink = glueContext.getSink(
    connection_type="s3",
    path=DST_S3_PATH,
    enableUpdateCatalog=True,
    updateBehavior="UPDATE_IN_DATABASE",
    partitionKeys=PARTITION_KEYS
)

sink.setFormat("parquet")
sink.setCatalogInfo(
    catalogDatabase=DST_DATABASE,
    catalogTableName=DST_TABLE
)

sink.writeFrame(dyf_dst)

job.commit()
```

